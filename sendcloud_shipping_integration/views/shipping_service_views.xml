<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Shipping service form view-->
    <record id="shipping_service_view_form" model="ir.ui.view">
        <field name="name">shipping.service.view.form</field>
        <field name="model">shipping.service</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="service"/>
                        </group>
                        <group>
                            <field name="available_countries_ids"
                                   widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Shipping service action -->
    <record id="shipping_service_action" model="ir.actions.act_window">
        <field name="name">Sendcloud Shipping Services</field>
        <field name="res_model">shipping.service</field>
        <field name="view_mode">list,form</field>
    </record>
    <!-- Shipping service menu-->
    <menuitem
            id="shipping_service_menu_action"
            action="shipping_service_action"
            parent="sale.menu_sales_config" sequence="4"/>
</odoo>
