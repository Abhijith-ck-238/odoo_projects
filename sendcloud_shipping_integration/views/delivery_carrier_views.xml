<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--  To add delivery sendcloud fields in form view-->
    <record id="view_delivery_carrier_form" model="ir.ui.view">
        <field name="name">
            delivery.carrier.view.form.inherit.sendcloud.shipping.integration
        </field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='destination']" position='before'>
                <page string="Sendcloud Configuration"
                      name="sendcloud_configuration"
                      invisible="delivery_type != 'sendcloud'">
                    <group>
                        <group>
                            <field name="sendcloud_developer_key"
                                   required="delivery_type == 'sendcloud'"
                            />
                            <field name="sendcloud_developer_password"
                                   required="delivery_type == 'sendcloud'"/>
                            <field name="sendcloud_service_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="sender_address_id"
                                   options="{'no_create_edit': True, 'no_create': True}"/>
                        </group>
                    </group>
                    <button name="action_get_shipping_services"
                            string="Get Shipping Services"
                            icon="fa-arrow-right" type="object"/>
                </page>
                <page string="Sender Addresses"
                      invisible="delivery_type != 'sendcloud'">
                    <field name="line_ids">
                        <list string="lines" editable="bottom" create="false">
                            <field name="sender_address"/>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="country_id"/>
                        </list>
                    </field>
                    <button name="action_get_sender_addresses"
                            string="Get Sender Addresses" icon="fa-arrow-right"
                            type="object"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
