<?xml version="1.0" ?>
<odoo>
    <data>
        <!-- User Group Category -->
        <record id="volunteers_donors_management_category" model="ir.module.category">
            <field name="name">Volunteers Donors Management</field>
        </record>
        <!-- Privilege for the groups -->
        <record id="res_groups_privilege_certificate_license" model="res.groups.privilege">
            <field name="name">Certificate</field>
            <field name="category_id" ref="volunteers_donors_management.volunteers_donors_management_category"/>
        </record>
        <!-- User Group -->
        <record id="volunteers_donors_management_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id"
                   ref="volunteers_donors_management.res_groups_privilege_certificate_license"/>
        </record>
    </data>
</odoo>

