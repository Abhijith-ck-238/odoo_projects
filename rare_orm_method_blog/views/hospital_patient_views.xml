<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_patient_view_tree" model="ir.ui.view">
        <name>hospital.patient.view.tree</name>
        <model>hospital.patient</model>
        <arch type="xml">
            <list>
                <field name="display_name"/>
                <field name="name"/>
                <field name="patient_code"/>
                <field name="ward_id"/>
            </list>
        </arch>
    </record>

    <record id="hospital_patient_view_form" model="ir.ui.view">
        <name>hospital.patient.view.form</name>
        <model>hospital.patient</model>
        <arch type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="patient_code"/>
                        </group>
                        <group>
                            <field name="ward_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="display_name" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </arch>
    </record>

    <record id="hospital_patient_action" model="ir.actions.act_window">
        <name>Patients</name>
        <res_model>hospital.patient</res_model>
        <view_mode>list,form</view_mode>
    </record>
</odoo>
