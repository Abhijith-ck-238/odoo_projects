<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="warranty_registration_view_tree" model="ir.ui.view">
        <field name="name">warranty.registration.tree</field>
        <field name="model">warranty.registration</field>
        <field name="arch" type="xml">
            <list string="Warranty Registrations">
                <field name="customer_id"/>
                <field name="sale_order_id"/>
                <field name="product_id"/>
                <field name="start_date"/>
                <field name="expiry_date"/>
                <field name="warranty_type"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'draft'" decoration-danger="state == 'expired'"/>
            </list>
        </field>
    </record>

    <record id="warranty_registration_view_form" model="ir.ui.view">
        <field name="name">warranty.registration.form</field>
        <field name="model">warranty.registration</field>
        <field name="arch" type="xml">
            <form string="Warranty Registration">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="sale_order_id"/>
                            <field name="product_id"/>
                            <field name="serial_no"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="expiry_date"/>
                            <field name="warranty_type"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_warranty_registration" model="ir.actions.act_window">
        <field name="name">Warranty Registrations</field>
        <field name="res_model">warranty.registration</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new warranty registration!
            </p>
        </field>
    </record>

    <menuitem id="menu_warranty_registration"
              name="Warranty Registrations"
              parent="sale.menu_sale_config"
              action="action_warranty_registration"
              sequence="10"/>
</odoo>
