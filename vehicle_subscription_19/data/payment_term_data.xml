<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">
        <record id="account_payment_term_monthly_payment" model="account.payment.term">
            <field name="name">Monthly Payment</field>
            <field name="note">Monthly payment for 4 months</field>
            <field name="line_ids" eval="[
                Command.clear(),
                Command.create({'value': 'percent', 'value_amount': 25.0, 'nb_days': 0}),
                Command.create({'value': 'percent', 'value_amount': 25.0, 'nb_days': 30}),
                Command.create({'value': 'percent', 'value_amount': 25.0, 'nb_days': 60}),
                Command.create({'value': 'percent', 'value_amount': 25.0, 'nb_days': 00})
                ]"/>
        </record>
    </data>
</odoo>