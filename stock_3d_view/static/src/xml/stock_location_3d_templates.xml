<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <!--extending listview button template to add 3D action button-->
    <t t-name="stock_3d_view.ListView.Buttons" t-inherit="web.ListView.Buttons">
       <xpath expr="." position="inside">
            <button type="button" class="btn btn-primary fa fa-lg fa-cubes open_3d_view"
                    style="margin-left: 3px; margin-right: 3px;" t-on-click="OnClickList3DvView">
                3D
            </button>
       </xpath>
   </t>
</templates>
