<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="membership_in_pos.MembershipPopup">
        <Dialog size="'md'" title="props.title" modalRef="modalRef">
            <main class="modal-body">
                    <!-- Adding text field-->
                    <div>
                        <label for="card_code">Card Code:</label>
                        <input  t-ref="cardCode" class='card_code' type="text"/>
                    </div>
                    <!-- Adding button -->
                    <div class="d-flex align-items-center justify-content-center gap-2 mt-2">
                        <div class="btn btn-primary check" t-on-click="Membership_check">
                            <label for="card_check">Check</label>
                            <t t-esc="props.checkText"/>
                        </div>
                    </div>

                    <!-- Adding selection field-->
            <t t-if="state.card">
                <div>
                    <div>
                        <label for="card_code">Customer :</label>
                        <t t-esc="state.card.customer_name"/>
                    </div>
                    <div>
                        <label for="card_code">Membership :</label>
                        <t t-esc="state.card.membership + - + state.card.discount"/>
                    </div>
                </div>
            </t>
            </main>
            <t t-set-slot="footer">
                <button class="button confirm btn btn-lg btn-primary" t-on-click="confirm">
                    <t t-esc="props.confirmText" />
                </button>
               <button class="button cancel btn btn-lg btn-secondary" t-on-click="cancel">
                   <t t-esc="props.cancelText" />
               </button>
            </t>
        </Dialog>
    </t>
</templates>
