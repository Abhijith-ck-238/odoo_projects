<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
       <field name="name">
           res.config.settings.view.form.inherit.membership.in.pos
       </field>
       <field name="model">res.config.settings</field>
       <field name="inherit_id"
              ref="point_of_sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
            <!-- Adding the configuration to settings !-->
            <xpath expr="//block[@id='pos_payment_section']" position="inside">
                <setting id="is_pos_module_pos_membership" help="Adds a button to set a membership">
                        <field name="is_pos_module_pos_membership" readonly="pos_has_active_session == True"/>
                            <div class="content-group mt16" invisible="not is_pos_module_pos_membership">
                                <label string="Membership Product" for="pos_membership_product_id" class="fw-normal me-1"/>
                                <field name="pos_membership_product_id" required="is_pos_module_pos_membership == True"/>
                            </div>
                    </setting>
            </xpath>
        </field>
    </record>
</odoo>
