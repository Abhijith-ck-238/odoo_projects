<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="discuss_channel_view_form_inherit_crosspost" model="ir.ui.view">
        <field name="name">discuss.channel.view.form.inherit.crosspost</field>
        <field name="model">discuss.channel</field>
        <field name="inherit_id" ref="mail.discuss_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="crosspost_send_email" readonly="not is_editable" invisible="channel_type != 'channel'"/>
            </xpath>
        </field>
    </record>
</odoo>
