<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <menuitem action="import_sale_order.gen_sale_import_wizard"
                  id="import_sale_order.gen_sale_wizard_import"
                  parent="sale.sale_order_menu"
                  name="import Sale Order"
                  sequence="50"
                  groups="sales_team.group_sale_salesman,sales_team.group_sale_manager"/>

        <record id="gen_sale_with_lot_wizard_view" model="ir.ui.view">
            <field name="name">Wizard for import So xls file</field>
            <field name="model">gen.sale_with_lot</field>
            <field name="arch" type="xml">
                <form string="Import Sale">
                    <group>
                        <group>
                            <field name="import_option" widget='radio'/>
                            <field name="file" filename="name"/>
                        </group>
                        <group>
                            <field name="stage" widget='radio'/>
                        </group>
                    </group>

                    <group>
                        <field name="sequence_opt"/>
                    </group>
                    <group>
                        <field name="import_prod_option" widget='radio'/>
                    </group>
                    <footer>
                        <button name="import_sale_with_lot" string="Import" class="oe_highlight" type="object"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_gen_sale_with_lot_import" model="ir.actions.act_window">
            <field name="name">Import Sale With Lot</field>
            <field name="res_model">gen.sale_with_lot</field>
            <field name="view_id" ref="gen_sale_with_lot_wizard_view"/>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem action="action_gen_sale_with_lot_import"
                  id="menu_gen_sale_with_lot"
                  parent="sale.sale_order_menu"
                  name="Import Sale With Lot"
                  sequence="50"
                  groups="sales_team.group_sale_salesman,sales_team.group_sale_manager"/>

    </data>
</odoo>