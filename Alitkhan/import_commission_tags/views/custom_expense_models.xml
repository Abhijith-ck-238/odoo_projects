<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
         <record id="custom_expense_model_view" model="ir.ui.view">
            <field name="name">custom.expense.model</field>
            <field name="model">custom.expense.model</field>
            <field name="arch" type="xml">
                <form string="Custom Expense Model">
                    <group>
                    </group>
                    <group>
                         <field name="file_to_upload" />
                         <field name="select_value" widget="radio"></field>
                    </group>
                    <footer>
                        <button string="Import" name="action_custom_expense_models" type="object"/>
                        <button string="Generate Xlsx" name="cron_custom_expense_models" type="object"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="action_custom_expense_model" model="ir.actions.act_window">
            <field name="name">Custom Expense </field>
            <field name="res_model">custom.expense.model</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

<!--        <menuitem action="action_custom_expense_model" id="Custom Expense" parent="hr_expense.menu_hr_expense_my_expenses"/>-->
        <menuitem action="action_custom_expense_model" id="menu_custom_expense" parent="hr_expense.menu_hr_expense_my_expenses"/>
    </data>
</odoo>
