<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="account_analytic_plan_form_inherit" model="ir.ui.view">
            <field name="name">analytic account group inherit</field>
            <field name="model">account.analytic.plan</field>
            <field name="inherit_id"
                   ref="analytic.account_analytic_plan_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='default_applicability']" position="after">
                    <field name="user_id" widget="many2many_tags"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>