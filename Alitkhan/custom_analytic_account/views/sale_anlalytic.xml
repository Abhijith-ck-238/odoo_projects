<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="analytic_account_list_view_inherit" model="ir.ui.view">
        <field name="name">analytic account inherit</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id"
               ref="custom_hr_expense_advance_clearng.account_analytic_account_inherit_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='remaining_budget_amount']" position="after">
                <button
                    type="action"
                    name="%(analytic.account_analytic_line_action)d"
                    string="Cost&amp;Revenue"/>
            </xpath>
        </field>
    </record>
    <record id="view_sale_analytic_account_list" model="ir.ui.view">
        <field name="name">sale.analytic.account.list</field>
        <field name="model">account.analytic.account</field>
        <field eval="7" name="priority"/>
        <field name="arch" type="xml">
            <list string="Analytic Accounts">
                <field name="name" string="Name"/>
                <field name="code"/>
                <field name="partner_id"/>
                <field name="active" invisible="1"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <button
                        type="action"
                        name="%(custom_analytic_account.sale_analytic_line_action)d"
                        string="Cost&amp;Revenue"/>
            </list>
        </field>
    </record>

    <record id="view_sale_analytic_account_list_inherit" model="ir.ui.view">
        <field name="name">analytic.account.inherit.custom.analytic.account</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id"
               ref="custom_analytic_account.view_sale_analytic_account_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="initial_amount"/>
            </xpath>
        </field>
    </record>

    <record id="action_sale_analytic_account_list"
            model="ir.actions.act_window">
        <field name="name">Analytic Accounts</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.analytic.account</field>
        <field name="search_view_id"
               ref="analytic.view_account_analytic_account_search"/>
        <field name="context">{'search_default_active':1}</field>
        <field name="domain">[('group_id.user_id','=', uid)]</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_sale_analytic_account_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a new analytic account
            </p>
        </field>
    </record>
    <menuitem id="menu_analytic_account"
              name="Analytic Account"
              action="action_sale_analytic_account_list"
              parent="sale.menu_sale_report"
              sequence="2"
              groups="custom_analytic_account.group_analytic_user"/>
</odoo>