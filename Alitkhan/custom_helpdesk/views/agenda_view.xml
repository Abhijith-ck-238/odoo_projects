<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="agenda_agenda_view_tree" model="ir.ui.view">
            <field name="name">agenda.agenda.tree</field>
            <field name="model">agenda.agenda</field>
            <field name="arch" type="xml">
                <list>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="reservation_reason"
                           groups="helpdesk.group_helpdesk_user" column_invisible="1"/>
                    <field name="task_id" column_invisible="1"/>
                    <field name="user_id_custom" column_invisible="1"/>
                    <field name="helpdesk_ticket_id" column_invisible="1"/>
                    <field name="province_id" column_invisible="1"/>
                    <field name="vehicle_ids" column_invisible="1"/>
                    <field name="description" column_invisible="1"/>
                    <field name="user_names" column_invisible="1"/>
                    <field name="vehicle_names" column_invisible="1"/>
                    <field name="active" column_invisible="1"/>
                    <field name="has_friday" column_invisible="1"/>
                    <field name="is_this_month_job" column_invisible="1"/>
                    <field name="x_studio_stage" column_invisible="1"/>
                </list>
            </field>
        </record>

        <record id="agenda_agenda_view_form" model="ir.ui.view">
            <field name="name">agenda.agenda.form</field>
            <field name="model">agenda.agenda</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="is_conflicted" invisible="1"/>
                        <div role="alert" class="alert alert-warning p-3 text-center"
                             invisible="not is_conflicted">
                            Some workers on this Agenda are already booked in
                            another Tasks:
                            <button name="view_conflict_fs_tickets"
                                    type="object" class="btn-link"
                                    string="View FS Tickets">
                            </button>
                            <button name="view_conflict_helpdesk_tickets"
                                    type="object" class="btn-link"
                                    string="View Helpdesk Tickets">
                            </button>
                            <button name="view_conflict_agendas" type="object"
                                    class="btn-link"
                                    string="View Agendas">
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="user_ids" widget="many2many_tags"/>
                                <field name="reservation_reason"/>
                                <field name="user_id_custom" invisible="1"/>
                                <field name="helpdesk_ticket_id" invisible="1"/>
                                <field name="province_id" invisible="1"/>
                                <field name="vehicle_ids" invisible="1"/>
                                <field name="description" invisible="1"/>
                                <field name="user_names" invisible="1"/>
                                <field name="vehicle_names" invisible="1"/>
                                <field name="active" invisible="1"/>
                                <field name="has_friday" invisible="1"/>
                                <field name="is_this_month_job" invisible="1"/>
                                <field name="x_studio_stage" invisible="1"/>

                            </group>
                            <group>
                                <field name="x_studio_stage" string="Helpdesk Stage"/>
                                <field name="date_start" string="Task Range" widget="daterange" options="{'end_date_field': 'date_end'}" />
<!--                                <label for="date_start" string="Task Range"/>-->
<!--                                <div class="w-100">-->
<!--                                    <div class="o_row">-->
<!--                                        <field name="date_start"-->
<!--                                               widget="daterange"-->
<!--                                               options="{&quot;related_end_date&quot;: &quot;date_end&quot;}"-->
<!--                                               force_save="1"/>-->
<!--                                        <i class="fa fa-long-arrow-right mx-2"-->
<!--                                           aria-label="Arrow icon"-->
<!--                                           title="Arrow"/>-->
<!--                                        <field name="date_end"-->
<!--                                               widget="daterange"-->
<!--                                               options="{&quot;related_start_date&quot;: &quot;date_start&quot;}"-->
<!--                                               force_save="1"/>-->
<!--                                    </div>-->
<!--                                </div>-->
                                <field name="task_id" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Stand By Pool">
                                <field name="available_user_ids">
                                    <list>
                                        <field name="user_id"/>
                                        <field name="agenda_id" invisible="1"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="user_id"/>
                                                <field name="agenda_id"
                                                       invisible="1"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="agenda_view_search" model="ir.ui.view">
            <field name="name">agenda.agenda.search</field>
            <field name="model">agenda.agenda</field>
            <field name="arch" type="xml">
                <search>
                    <field name="user_ids"/>
                    <field name="user_id_custom" invisible="1"/>
                    <field name="has_friday" invisible="1"/>
                    <field name="is_this_month_job" invisible="1"/>

                    <filter string="Friday Jobs" name="friday_jobs" domain="[
                            ('has_friday', '=', True)
                           ]"/>
                    <filter string="This Month Jobs" name="this_month"
                            domain="[('is_this_month_job', '=', True)
                            ]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Users" name="user_id_custom" domain="[]"
                                context="{'group_by': 'user_id_custom'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="project_task_dependency_view_gantt_inherit" model="ir.ui.view">
            <field name="name">project.task.dependency.view.gantt.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project_enterprise.project_task_dependency_view_gantt"/>
            <field name="arch" type="xml">
                <xpath expr="//gantt/templates/div" position="inside">
                    <div class="row no-gutters">
                        <div class="col">
                            <ul class="pl-1 mb-0">
                                <li>
                                    <strong>Project :</strong>
                                    <t t-esc="project_id.display_name"/>
                                </li>
                                <li>
                                    <strong>Time :</strong>
                                    <t t-esc="planned_date_begin.toFormat('yyyy-MM-dd hh:mm:ss a')"/>-
                                    <t t-esc="date_deadline.toFormat('yyyy-MM-dd hh:mm:ss a')"/>
                                </li>

                            </ul>
                        </div>
                    </div>
                </xpath>

            </field>
        </record>

        <record id="agenda_gantt_view" model="ir.ui.view">
            <field name="name">agenda.gantt.view.extend</field>
            <field name="model">agenda.agenda</field>
            <field name="arch" type="xml">
                    <gantt string="agenda.agenda" date_start="date_start" date_stop="date_end">
                    <field name="task_id" invisible="1"/>
                    <field name="helpdesk_ticket_id" invisible="1"/>
                    <field name="province_id" invisible="1"/>
                    <field name="vehicle_ids" invisible="1"/>
                    <field name="user_ids" invisible="1"/>
                    <field name="description" invisible="1"/>
                    <field name="user_names" invisible="1"/>
                    <field name="vehicle_names" invisible="1"/>
                    <templates>
                        <div t-name="gantt-popover" class="container-fluid">
                            <div class="row no-gutters">
                                <div class="col">
                                    <ul class="pl-1 mb-0">
                                        <li>
                                            <strong>Start Date :</strong>
                                            <t t-esc="date_start.toFormat('yyyy-MM-dd hh:mm:ss a')"/>
                                        </li>
                                        <li>
                                            <strong>Stop Date :</strong>
                                            <t t-esc="date_end.toFormat('yyyy-MM-dd hh:mm:ss a')"/>
                                        </li>
                                        <li>
                                            <strong>Helpdesk Ticket :</strong>
                                            <t t-esc="helpdesk_ticket_id[1]"/>
                                        </li>
                                        <li>
                                            <strong>Province :</strong>
                                            <t t-esc="province_id[1]"/>
                                        </li>
                                        <li>
                                            <strong>Users :</strong>
                                            <t t-esc="user_names"/>
                                        </li>
                                        <li>
                                            <strong>Vehicles :</strong>
                                            <t t-esc="vehicle_names"/>
                                        </li>
                                        <li>
                                            <strong>Reported Defect :</strong>
                                            <t t-esc="description"/>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </templates>
                    </gantt>
            </field>
        </record>


            <record id="helpdesk_agenda_action" model="ir.actions.act_window">
            <field name="name">Agenda</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">agenda.agenda</field>
            <field name="view_mode">gantt,list,form,pivot</field>
<!--            <field name="view_mode">list,gantt,form</field>-->
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'gantt', 'view_id': ref('agenda_gantt_view')}),
                (0, 0, {'view_mode': 'list', 'view_id': ref('agenda_agenda_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('agenda_agenda_view_form')})]"/>
<!--            <field name="view_ids" eval="[(5, 0, 0),-->
<!--                (0, 0, {'view_mode': 'list', 'view_id': ref('agenda_agenda_view_tree')}),-->
<!--                (0, 0, {'view_mode': 'gantt', 'view_id': ref('agenda_gantt_view')}),-->
<!--                (0, 0, {'view_mode': 'form', 'view_id': ref('agenda_agenda_view_form')})]"/>-->
            <field name="search_view_id" ref="agenda_view_search"/>
        </record>

        <record id="action_helpdesk_attachment" model="ir.actions.act_window">
            <field name="name">Attachments</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ir.attachment</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('res_model', '=', 'project.task')]</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('custom_helpdesk.helpdesk_view_document_file_kanban')}),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_helpdesk.helpdesk_view_attachment_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('custom_helpdesk.helpdesk_view_attachment_form')})]"/>
            <field name="search_view_id" ref="custom_helpdesk.ir_attachment_view_search_inherit_helpdesk"/>
        </record>

        <menuitem id="helpdesk_menu_agenda" action="helpdesk_agenda_action"
                  parent="helpdesk.menu_helpdesk_root" name="Agenda"
                  groups="helpdesk.group_helpdesk_user"
        />

        <menuitem id="helpdesk_menu_attachment"
                  action="action_helpdesk_attachment"
                  parent="helpdesk.menu_helpdesk_root"
                  name="Service Report Attachments"
                  groups="helpdesk.group_helpdesk_user"
        />

    </data>
</odoo>