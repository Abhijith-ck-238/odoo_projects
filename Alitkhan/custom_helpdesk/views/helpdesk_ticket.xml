<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="helpdesk_ticket_search_this_month_and_week"
                model="ir.ui.view">
            <field name="name">helpdesk.ticket.search.thi_month.this_week
            </field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id"
                   ref="helpdesk.helpdesk_tickets_view_search"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <filter string="Current Week" name="current_week"
                            domain="[
                            ('create_date', '&lt;=', ((context_today()+relativedelta(weeks=0, weekday=-3)).strftime('%Y-%m-%d'))),
                            ('create_date', '&gt;=', ((context_today()-relativedelta(weeks=1, weekday=-2)).strftime('%Y-%m-%d')))]"/>
                    <filter name="current_month" string="Current Month" domain="[
                         ('create_date', '&gt;=', (context_today()).strftime('%%Y-%%m-01')),
                        ('create_date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%%Y-%%m-%%d'))]"/>
                    <filter name="last_30_days" string="Last 30 Days" domain="[
                         ('create_date', '&lt;=', (context_today()).strftime('%%Y-%%m-%%d')),
                        ('create_date', '&gt;=', datetime.datetime.combine(context_today() + relativedelta(days=-30), datetime.time(11,59,59)))]"/>
                    <filter name="last_14_days" string="Last 14 Days" domain="[
                         ('create_date', '&lt;=', (context_today()).strftime('%%Y-%%m-%%d')),
                        ('create_date', '&gt;=', datetime.datetime.combine(context_today() + relativedelta(days=-14), datetime.time(11,59,59)))]"/>
                </field>
            </field>
        </record>

        <record id="helpdesk_ticket_kanban_add_contract_status"
                model="ir.ui.view">
            <field name="name">helpdesk.ticket.kanban.add.contract.status
            </field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id"
                   ref="helpdesk.helpdesk_ticket_view_kanban"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//templates" position="before">
                        <field name="contract_is_valid"/>
                        <field name="is_contract_in_warranty" invisible="1"/>
                    </xpath>

                    <xpath expr="//footer" position="before">
                        <div>
                            <h5 invisible="contract_is_valid" class="text-danger font-weight-bold">Contract is
                                Expired
                            </h5>
                            <h5 invisible="not contract_is_valid or not is_contract_in_warranty"
                                class="text-success font-weight-bold">Contract is
                                Valid (within warranty).
                            </h5>
                            <h5 invisible="not contract_is_valid or is_contract_in_warranty"
                                class="text-success font-weight-bold">Contract is
                                Valid (out of warranty).
                            </h5>
                        </div>
                    </xpath>

                    <!--<xpath expr="//field[@name = 'properties']" position="after">-->
                    <xpath expr="//div[hasclass('fw-bold')]" position="after">
                        <div>
                            <field name="user_id"/>

                        </div>
                    </xpath>
                    <!--<xpath expr="//footer" position="before">-->
                    <xpath expr="//field[@name='site_id']" position="before">
                        <div>
                            <field name="ticket_type_id"/>
                        </div>
                        <div>
                            <field name="province_id"/>
                        </div>
                    </xpath>
                </data>
            </field>
        </record>

