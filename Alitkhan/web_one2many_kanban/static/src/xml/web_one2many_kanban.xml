<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Extend the default KanbanRecord template -->
    <t t-name="web_one2many_kanban.CustomKanbanRecord" t-inherit="web.KanbanRecord" t-inherit-mode="extension">
        <xpath expr="//article" position="inside">
            <t t-if="one2manyFields and one2manyFields.length">
                <t t-foreach="one2manyFields" t-as="fieldName" t-key="fieldName">
                    <div class="o_one2many_tree">
                        <t t-call="web_one2many_kanban.One2ManyTree">
                            <t t-set="name" t-value="fieldName"/>
                        </t>
                    </div>
                </t>
            </t>
        </xpath>
    </t>
    <!-- Generic One2ManyTree Template -->

    <t t-name="web_one2many_kanban.One2ManyTree">
        <table class="table table-sm o_main_table">
            <thead>
                <tr>
                    <t t-foreach="displayColumns" t-as="col" t-key="col.name">
                        <th style="font-weight:bold;vertical-align:bottom">
                            <t t-esc="col.label"/>
                        </th>
                    </t>
                </tr>
            </thead>
            <tbody>
                <t t-if="records and records.length">
                    <t t-foreach="records" t-as="o" t-key="o.id">
                        <tr>
                            <t t-foreach="displayColumns" t-as="col" t-key="col.name">
                                <td style="vertical-align:bottom">
                                    <t t-esc="o[col.name]"/>
                                </td>
                            </t>
                        </tr>
                    </t>
                </t>
                <t t-else="">
                    <tr>
                        <td colspan="3">No records found</td>
                    </tr>
                </t>
            </tbody>
        </table>
    </t>
</templates>