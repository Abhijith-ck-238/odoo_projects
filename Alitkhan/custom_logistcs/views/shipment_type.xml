<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="shipment_type_view_tree" model="ir.ui.view">
        <field name="name">shipment.type.list</field>
        <field name="model">shipment.type</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="shipment_type_view_form" model="ir.ui.view">
        <field name="name">shipment.type.form</field>
        <field name="model">shipment.type</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="shipment_type_view_search" model="ir.ui.view">
        <field name="name">shipment.type.form</field>
        <field name="model">shipment.type</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_shipment_type" model="ir.actions.act_window">
        <field name="name">Shipment Types</field>
        <field name="res_model">shipment.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_shipment_type" name="Shipment Type" action="action_shipment_type" parent="account.menu_finance_configuration" sequence="6"/>
</odoo>