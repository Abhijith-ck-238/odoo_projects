<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
        <record id="view_move_form" model="ir.ui.view">
            <field name="name">view.move.form.inherit.custom.logistcs</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']//list/field[@name='quantity']"
                       position="before">
                    <field name="shipment_type_id" column_invisible="parent.move_type != 'in_invoice'"/>
                </xpath>
            </field>
        </record>
</odoo>