<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_logistics_report_tree" model="ir.ui.view">
         <field name="name">logistics.report.tree</field>
         <field name="model">logistics.report</field>
         <field name="arch" type="xml">
             <list string="Logistics Analysis">
                    <field name="shipment_id"/>
             </list>
         </field>
    </record>

    <record id="view_logistics_report_pivot" model="ir.ui.view">
         <field name="name">logistics.report.pivot</field>
         <field name="model">logistics.report</field>
         <field name="arch" type="xml">
             <pivot string="Logistics Analysis">
                 <field name="shipment_id" type="row"/>
                 <field name="status" type="row"/>
                 <field name="shipment_value" type="measure"/>
                 <field name="purchase_total" type="measure"/>
                 <field name="fees_percentage" type="measure"/>
                 <field name="bill_total" type="measure"/>
                 <field name="contract_id" type="row"/>
                 <field name="purchase_id" type="row"/>
             </pivot>
         </field>
    </record>

    <record id="view_logistics_report_graph" model="ir.ui.view">
         <field name="name">logistics.report.graph</field>
         <field name="model">logistics.report</field>
         <field name="arch" type="xml">
             <graph string="Logistics Analysis" type="line">
                 <field name="shipment_value" type="measure"/>
                 <field name="purchase_total" type="measure"/>
             </graph>
         </field>
    </record>

