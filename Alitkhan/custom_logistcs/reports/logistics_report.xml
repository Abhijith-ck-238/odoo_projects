    <record id="view_logistics_report_search" model="ir.ui.view">
        <field name="name">logistics.report.search</field>
        <field name="model">logistics.report</field>
        <field name="arch" type="xml">
            <search string="Logistics Analysis">
                <group expand="1" string="Group By">
                    <filter string="Shipment" name="Shipment" context="{'group_by':'shipment_id'}"/>
                     <filter string="Status" name="Status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_logistics_report" model="ir.actions.act_window">
        <field name="name">Logistics Analysis</field>
        <field name="res_model">logistics.report</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_logistics_report_search"/>
        <field name="help">This report performs analysis on your Logistics.</field>
    </record>

    <menuitem
            id="menu_logistics_reporting"
            name="Reporting"
            parent="logistics.menu_root"
            sequence="50" groups="logistics.logistics_manager"/>
    <menuitem
        id="menu_logistics_report"
        name="Logistics"
        parent="menu_logistics_reporting"
        action="custom_logistcs.action_logistics_report"
        sequence="10"/>
</odoo>