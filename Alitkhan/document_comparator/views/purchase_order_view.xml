<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="purchase_order_comp_inh_form" model="ir.ui.view">
            <field name="name">purchase.order.comp.inh.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_button_box')]"
                       position="inside">
                    <button name="open_compare_form" type="object"
                            class="oe_stat_button"
                            icon="fa-book icon"
                            groups="document_comparator.groups_user">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">Compared</span>
                            <span class="o_stat_text">Documents</span>
                        </div>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
