<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="document_comparator_form" model="ir.ui.view">
            <field name="name">document_comparator.form</field>
            <field name="model">document.comparator</field>
            <field name="arch" type="xml">
                <form string="Document Comparator Form">
                    <header>
                        <button type="object" name="compare_items"
                                string="Compare"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Identical"
                                invisible="state != 'match'"/>
                        <widget name="web_ribbon" title="Unidentical"
                                bg_color="bg-danger"
                                invisible="state != 'mismatch'"/>
                        <field name="state" invisible="1"/>
                        <field name="document_type" invisible="1"/>
                        <field name="include_prices" invisible="1"/>

                        <group>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </group>
                        <group>
                            <field name="sale_order"
                                   invisible="not document_type or document_type != 'sale_order'"/>
                            <field name="purchase_order"
                                   invisible="not document_type or document_type != 'purchase_order'"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>

                        <notebook>
                            <page name="order_line" string="Order Line">
                                <field name="order_line">
                                    <form>
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="compare_id"
                                                           invisible="1"/>
                                                    <field name="product_id"/>
                                                    <field name="qty"/>
                                                    <field name="price_unit"
                                                           groups="document_comparator.groups_manager"
                                                           invisible="not compare_id.include_prices"/>
                                                </group>
                                                <group>
                                                    <field name="qty_diff"/>
                                                    <field name="price_diff"
                                                           groups="document_comparator.groups_manager"
                                                           invisible="not compare_id.include_prices"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                    <list editable="top"
                                          decoration-danger="state == 'unregistered'"
                                          decoration-warning="state == 'unmatch'">
                                        <field name="state"
                                               column_invisible="parent.state in ['draft', 'match']"/>
                                        <field name="product_id"/>
                                        <field name="part_number"/>
                                        <field name="qty"/>
                                        <field name="qty_diff"
                                               column_invisible="parent.state in ['draft', 'match']"/>
                                        <field name="price_unit"
                                               groups="document_comparator.groups_manager"
                                               column_invisible="not parent.include_prices"/>
                                        <field name="price_diff"
                                               groups="document_comparator.groups_manager"
                                               column_invisible="parent.state in ['draft', 'match'] or parent.include_prices == False"/>
                                    </list>
                                </field>
                            </page>

                            <page name="missing_order_line"
                                  string="Missing Products"
                                  invisible="not missing_order_line">
                                <field name="missing_order_line"
                                       string="Difference Lines" readonly="1">
                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="compare_id"
                                                       invisible="1"/>
                                                <field name="product_id"/>
                                                <field name="qty_diff"
                                                       string="Quantity"/>
                                                <field name="price_diff"
                                                       string="Unit Price"
                                                       groups="document_comparator.groups_manager"
                                                       invisible="not compare_id.include_prices"/>
                                            </group>
                                        </sheet>
                                    </form>
                                    <list editable="top">
                                        <field name="product_id"/>
                                        <field name="part_number"/>
                                        <field name="qty_diff"
                                               string="Quantity"/>
                                        <field name="price_diff"
                                               groups="document_comparator.groups_manager"
                                               string="Unit Price"
                                               column_invisible="parent.include_prices == False"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="document_comparator_tree" model="ir.ui.view">
            <field name="name">document_comparator.tree</field>
            <field name="model">document.comparator</field>
            <field name="arch" type="xml">
                <list string="Document Comparator Tree">
                    <field name="name"/>
                </list>
            </field>
        </record>
    </data>
</odoo>
