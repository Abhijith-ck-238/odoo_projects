<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="helpdesk_ticket_inh_form" model="ir.ui.view">
            <field name="name">helpdesk_inh.form</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='stage_id']" position="before">
                    <button name="create_sub_ticket" type="object" string="Create Sub Ticket" invisible="child_ticket"/>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="field_service_id" invisible="1"/>
                    <field name="parent_ticket" invisible="1"/>
                    <field name="child_ticket" invisible="1"/>
                    <field name="resource_json" invisible="1"/>
                    <field name="service_report_id" invisible="1"/>
                    <button name="view_service_report" type="object" class="oe_stat_button" icon="fa-file-text"
                            invisible="not service_report_id">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Service</span>
                            <span class="o_stat_text">Report</span>
                        </div>
                    </button>
                    <button name="view_field_service" type="object" class="oe_stat_button" icon="fa-pencil-square-o"
                            invisible="not field_service_id">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Field</span>
                            <span class="o_stat_text">Service</span>
                        </div>
                    </button>
                    <button name="view_parent_ticket" type="object" class="oe_stat_button" icon="fa-ticket"
                            invisible="not parent_ticket">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Parent</span>
                            <span class="o_stat_text">Ticket</span>
                        </div>
                    </button>
                    <button name="view_child_ticket" type="object" class="oe_stat_button" icon="fa-ticket"
                            invisible="not child_ticket">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Child</span>
                            <span class="o_stat_text">Ticket</span>
                        </div>
                    </button>
                </xpath>

                <xpath expr="//sheet" position="before">
                    <div role="alert" class="alert alert-warning p-3 text-center" invisible="not overlap_sn">
                        There is already another opened ticket with the same serial number
                    </div>
                    <div role="alert" class="alert alert-warning p-3 text-center" invisible="not resource_overlap">
                        Some workers on this ticket are already booked in another ticket:
                        <button name="view_overlapped_tickets" type="object" class="btn-link">
                            <field class="align-middle" name="overlap_string"/>
                        </button>
                    </div>
                </xpath>

                <xpath expr="//h1" position="after">
                    <h3>
                        <field name="job_number"/>
                    </h3>
                </xpath>

                <xpath expr="//field[@name='sale_order_id']" position="after">
                    <field name="recieve_date"/>
                    <field name="create_uid"/>
                </xpath>

                <xpath expr="//field[@name='partner_phone']" position="after">
                    <field name="call_number"/>
                </xpath>
                <xpath expr="//label[@for='partner_phone']" position="replace"/>
                <xpath expr="//field[@name='partner_phone']" position="replace"/>
                <!--<xpath expr="//span[@class='fa-exclamation-triangle']" position="replace"></xpath>-->

                <xpath expr="//field[@name='sale_order_id']" position="replace"/>

                <xpath expr="//sheet//group" position="after">
                    <group>
                        <group>
                            <div class="o_row">
                                <label for="sn_search"/>
                                <field name="sn_search"/>
                                <button name="search_by_sn" type="object" string="Search" class="btn-primary"/>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="resource_overlap" invisible="1"/>
                            <field name="overlap_sn" invisible="1"/>
                            <field name="contract_is_valid" invisible="1"/>
                            <field name="call_type"/>
                            <field name="province_id"/>
                            <field name="site_id" options="{'no_create_edit': True}"/>
                            <field name="brand_id" options="{'no_create_edit': True}"/>
                            <field name="unit_id" options="{'no_create_edit': True}"/>
                            <h5 invisible="contract_is_valid" class="text-danger font-weight-bold">Contract is Expired
                            </h5>
                            <h5 invisible="not contract_is_valid" class="text-success font-weight-bold">Contract is
                                Valid
                            </h5>
                            <field name="unit_eoc_date"/>
                            <field name="sn"/>
                            <field name="contract_id" options="{'no_create_edit': True, 'no_create': True}"/>
                            <field name="exception_id"/>
                            <label for="date_start" string="Task Range"/>
                            <div class="w-100">
                                <div class="o_row">
                                    <field name="date_start" widget="daterange"
                                           options="{&quot;related_end_date&quot;: &quot;date_end&quot;}"/>
                                    <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                    <field name="date_end" widget="daterange"
                                           options="{&quot;related_start_date&quot;: &quot;date_start&quot;}"/>
                                </div>
                            </div>
                            <button name="return_check_resources_view" string="Check Resources" type="object"/>
                        </group>
                        <group>
                        </group>
                    </group>



                </xpath>
                <xpath expr="//page[@name='extra_info']" position="replace">
                </xpath>
                <xpath expr="//notebook">
                        <page string="Resources" name="resouces" invisible="not create_uid">
                            <field name="resource_lines">
                                <list editable="top">
                                    <!-- <field name="categ_name"/> -->
                                    <field name="categ_id"/>
                                    <field name="categ_type" optional="show"/>
                                    <field name="qty"/>
                                    <field name="user_ids" widget="many2many_tags" readonly="categ_type == 'vehicle'"
                                           optional="show"/>
                                    <field name="vehicle_ids" widget="many2many_tags" readonly="categ_type == 'human'"
                                           optional="show"/>
                                    <field name="vehicle_mode_id" options="{'no_create': True, 'no_create_edit': True}"
                                           readonly="categ_type == 'human'" optional="show"/>
                                    <field name="note" optional="show"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="categ_id"/>
                                                <field name="categ_type"/>
                                                <field name="qty"/>
                                            </group>
                                            <group>
                                                <field name="user_ids" widget="many2many_tags"/>
                                                <field name="vehicle_ids" widget="many2many_tags"/>
                                                <field name="vehicle_mode_id"/>
                                            </group>
                                            <field name="note"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                </xpath>
            </field>
        </record>
        <record id="itkan_helpdesk_ticket_kanban_ext" model="ir.ui.view">
            <field name="name">itkan.helpdesk.ticket.kanban</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_kanban"/>
            <field name="arch" type="xml">
                <templates position="before">
                    <field name="resource_lines"/>
                    <field name="resources_are_full"/>
                    <field name="resource_json" invisible="True"/>
                </templates>
                <xpath expr="//field[@name='activity_ids'][@widget='kanban_activity']" position="replace"/>
                <xpath expr="//field[@name='kanban_state'][@widget='state_selection']" position="before">
                    <field name="activity_ids" widget="kanban_activity" class="ms-2" on_change="1"/>
                </xpath>

                <xpath expr="//div[hasclass('fw-bold')]" position="before">
                    <div>
                        <field name="job_number"/>
                    </div>
                </xpath>

                <xpath expr="//field[@name='commercial_partner_id']" position="replace">
                    <field name="site_id"/>
                </xpath>

                <xpath expr="//footer" position="before">
                    <div style="display: flex; flex-wrap: wrap; gap: 12px;">
                        <t t-foreach="JSON.parse(record.resource_json.raw_value)" t-as="line">
                            <div t-attf-class="#{line.categ_type == 'human' ? 'text-info' : 'text-warning'} font-weight-bold mr-4"
                                 t-if="line.remaining_qty != 0" t-esc="line.name + ': ' + line.remaining_qty "/>
                        </t>
                    </div>
                </xpath>

            </field>
        </record>

        <record id="helpdesk_ticket_search_itkan" model="ir.ui.view">
            <field name="name">helpdesk.ticket.search.itkan</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_tickets_view_search"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="job_number"/>
                </field>
            </field>
        </record>

    </data>
</odoo>