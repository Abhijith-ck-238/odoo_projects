<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="purchase_product_lot_form" model="ir.ui.view">
            <field name="name">purchase.product.lot.form</field>
            <field name="model">purchase.product.lot</field>
            <field name="arch" type="xml">
                <form string="Lot/Serial">
                    <sheet>
                        <div class="oe_title">
                            <label class="oe_edit_only" for="name" string="Lot/Serial"/>
                            <h1><field name="name" placeholder="Lot/Serial"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="product_id" readonly="1"/>
                                <field name="product_qty" readonly="1"/>
                            </group>
                            <group>
                                <field name="lot_id" readonly="1"/>
                                <field name="ref"/>
                            </group>
                            <field name="note"/>
                        </group>
                        <notebook>
                            <page name="date" string="Dates">
                                <group>
                                    <group>
                                        <field name="use_date"/>
                                    </group>
                                    <group>
                                        <field name="alert_date"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>