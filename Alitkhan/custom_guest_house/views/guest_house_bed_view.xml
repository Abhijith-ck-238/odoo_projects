<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="guest_house_bed_view_tree" model="ir.ui.view">
        <field name="name">guest.house.bed.list</field>
        <field name="model">guest.house.bed</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="guest_house_id"/>
                <field name="is_reserved"/>
                <field name="province_id"/>
            </list>
        </field>
    </record>

    <record id="guest_house_bed_view_form" model="ir.ui.view">
        <field name="name">guest.house.bed.form</field>
        <field name="model">guest.house.bed</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <header>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name">Bed Number</label>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="guest_house_id"/>
                            <field name="province_id"/>
                        </group>
                        <group>
                            <field name="is_reserved"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="guest_house_bed_view_search" model="ir.ui.view">
        <field name="name">guest.house.bed.search</field>
        <field name="model">guest.house.bed</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_guest_house_bed" model="ir.actions.act_window">
        <field name="name">Guest House Bed</field>
        <field name="res_model">guest.house.bed</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="guest_house_bed_view_tree_main" model="ir.ui.view">
        <field name="name">guest.house.bed.list.main</field>
        <field name="model">guest.house.bed</field>
        <field name="arch" type="xml">
            <list string="Channel" create="0" delete="0">
                <field name="is_reserved" widget="reservation_icon" string="Availability"/>
                <field name="name"/>
                <field name="guest_house_id"/>
                <field name="province_id"/>
                <field name="reservation_ids" widget="many2many_tags" />
            </list>
        </field>
    </record>

    <record id="guest_house_bed_view_form_main" model="ir.ui.view">
        <field name="name">guest.house.bed.form.main</field>
        <field name="model">guest.house.bed</field>
        <field name="arch" type="xml">
            <form string="Form Views" create="0" edit="0">
                <header>
                    <button string="Reserve Bed" type="object" name="action_reserve_bed" class="btn btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name">Bed Number</label>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="guest_house_id"/>
                            <field name="province_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reservations">
                            <field name="reservation_ids">
                                <list create="0" edit="0" delete="0" default_order="date_from asc">
                                    <field name="name"/>
                                    <field name="employee_id"/>
                                    <field name="arabic_name"/>
                                    <field name="department_id"/>
                                    <field name="division_id"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="guest_house_bed_view_search_main" model="ir.ui.view">
        <field name="name">guest.house.bed.search</field>
        <field name="model">guest.house.bed</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
                <group expand="0" string="Group By">
                        <filter name="group_guest" string="Guest House" domain="[]" context="{'group_by': 'guest_house_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_guest_house_bed_user" model="ir.actions.act_window">
        <field name="name">Beds</field>
        <field name="res_model">guest.house.bed</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('custom_guest_house.guest_house_bed_view_tree_main')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('custom_guest_house.guest_house_bed_view_form_main')})]"/>
        <field name="search_view_id" ref="guest_house_bed_view_search_main"/>
        <field name="context">{'search_default_group_guest': True}</field>
    </record>

    <menuitem id="menu_guest_house_bed" name="Guest House Bed" action="action_guest_house_bed" parent="menu_guest_house_configuration" sequence="0"/>
     <menuitem id="menu_guest_house_bed_main" name="Bed" action="action_guest_house_bed_user" parent="guest_house_menu_root" sequence="0"/>
</odoo>