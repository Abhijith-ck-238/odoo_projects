<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="guest_house_view_tree" model="ir.ui.view">
        <field name="name">guest.house.list</field>
        <field name="model">guest.house</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                 <field name="province_id"/>
                <field name="total_bed"/>
                <field name="available_bed"/>
            </list>
        </field>
    </record>

    <record id="guest_house_view_form" model="ir.ui.view">
        <field name="name">guest.house.form</field>
        <field name="model">guest.house</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <header>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name">Guest House Name</label>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="province_id"/>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="total_bed"/>
                            <field name="available_bed"/>
                        </group>
                    </group>
                    <notebook>
                    <page string="Beds">
                        <field name="bed_ids">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="is_reserved"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="guest_house_view_search" model="ir.ui.view">
        <field name="name">guest.house.search</field>
        <field name="model">guest.house</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_guest_house" model="ir.actions.act_window">
        <field name="name">Guest House</field>
        <field name="res_model">guest.house</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="guest_house_menu_root" name="Guest House Management" groups="group_guest_house_user,group_guest_house_admin"/>
    <menuitem id="menu_guest_house_configuration" name="Configuration" parent="guest_house_menu_root" sequence="2" groups="group_guest_house_admin"/>
    <menuitem id="menu_guest_house" name="Guest House" action="action_guest_house" parent="menu_guest_house_configuration" sequence="0"/>
</odoo>