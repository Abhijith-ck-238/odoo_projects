<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="bed_reservation_view_tree" model="ir.ui.view">
        <field name="name">bed.reservation.list</field>
        <field name="model">bed.reservation</field>
        <field name="arch" type="xml">
            <list string="Channel" delete="0">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="arabic_name"/>
                <field name="department_id"/>
                <field name="division_id"/>
                <field name="guest_house_id"/>
                <field name="bed_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
            </list>
        </field>
    </record>

    <record id="bed_reservation_view_form" model="ir.ui.view">
        <field name="name">bed.reservation.form</field>
        <field name="model">bed.reservation</field>
        <field name="arch" type="xml">
            <form string="Form Views" delete="0">
                <header>
                    <button string="Cancel Reservation" name="action_cancel_reservation" type="object" invisible="state != 'reserved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="reserved,cancelled"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name">Reservation Number</label>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="arabic_name"/>
                            <field name="department_id"/>
                            <field name="division_id"/>
                        </group>
                        <group>
                            <field name="guest_house_id"/>
                            <field name="bed_ids" invisible="1"/>
                            <field name="bed_id"/>
                            <label for="date_from" string="Reservation Range"/>
                            <div class="w-100">
                                <div class="o_row">
                                    <field name="date_from"/>
                                    <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                    <field name="date_to"/>
                                </div>
                            </div>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <record id="bed_reservation_view_search" model="ir.ui.view">
        <field name="name">bed.reservation.search</field>
        <field name="model">bed.reservation</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
            </search>
        </field>
    </record>

    <record id="action_bed_reservation_all" model="ir.actions.act_window">
        <field name="name">All Reservation</field>
        <field name="res_model">bed.reservation</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_bed_reservation_own" model="ir.actions.act_window">
        <field name="name">My Reservation</field>
        <field name="res_model">bed.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
    </record>
    <record id="action_bed_reservation_cancelled" model="ir.actions.act_window">
        <field name="name">Cancelled Reservation</field>
        <field name="res_model">bed.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'cancelled')]</field>
    </record>

    <menuitem id="menu_bed_reservation" name="Bed Reservation" parent="guest_house_menu_root" sequence="0"/>
    <menuitem id="menu_bed_reservation_own" name="My Reservation" action="action_bed_reservation_own" parent="menu_bed_reservation" sequence="1"/>
    <menuitem id="menu_bed_reservation_all" name="All Reservation" action="action_bed_reservation_all" parent="menu_bed_reservation" sequence="1" groups="group_guest_house_admin"/>
    <menuitem id="menu_bed_reservation_cancelled" name="Cancelled Reservation" action="action_bed_reservation_cancelled" parent="menu_bed_reservation" sequence="2"
              groups="group_guest_house_admin"/>
</odoo>
