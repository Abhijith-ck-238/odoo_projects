<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="bed_reservation_view_wizard" model="ir.ui.view">
        <field name="name">bed.reservation.wizard</field>
        <field name="model">reservation.wizard</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <label for="start_date" string="Reservation Range"/>
                            <div class="w-100">
                                <div class="o_row">
                                    <field name="start_date" widget="datetime" options="{&quot;related_end_date&quot;: &quot;end_date&quot;}"/>
                                    <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                    <field name="end_date" widget="datetime" options="{&quot;related_start_date&quot;: &quot;start_date&quot;}"/>
                                </div>
                            </div>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Reserve" name="action_reserve" type="object" class="btn btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bed_reservation_wizard" model="ir.actions.act_window">
        <field name="name">Reservation</field>
        <field name="res_model">reservation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>