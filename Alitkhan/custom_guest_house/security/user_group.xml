<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="module_category_guest_house_management" model="ir.module.category">
            <field name="name">Guest House Management</field>
            <field name="description">Helps you to manage the Training</field>
        </record>

        <record id="group_guest_house_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_guest_house_management"/>
        </record>

        <record id="group_guest_house_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_guest_house_management"/>
            <field name="implied_ids" eval="[(4, ref('custom_guest_house.group_guest_house_user'))]"/>
        </record>
    </data>
</odoo>