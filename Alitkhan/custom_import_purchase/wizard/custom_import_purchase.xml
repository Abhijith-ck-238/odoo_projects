<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="custom_gen_purchase_wizard_view" model="ir.ui.view">
            <field name="name">wizard for import csv xls file</field>
            <field name="model">gen.purchase</field>
            <field name="inherit_id" ref="import_purchase.gen_purchase_wizard_view"/>
            <field name="arch" type="xml">
                <field name="import_option" position="after">
                    <field name="new_import_option" widget="radio"/>
                </field>
                <field name="import_option" position="replace">
                    <field name="import_option" invisible="1"/>
                </field>
                <field name="import_prod_option" position="after">
                    <field name="new_import_prod_option" widget="radio"/>
                </field>
                <field name="import_prod_option" position="replace">
                    <field name="import_prod_option" invisible="1"/>
                </field>
            </field>
        </record>
    </data>
</odoo>