<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="letter_stage_view_tree" model="ir.ui.view">
        <field name="name">letter.stage.list</field>
        <field name="model">letter.stage</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="sequence"/>
            </list>
        </field>
    </record>

    <record id="letter_stage_view_form" model="ir.ui.view">
        <field name="name">letter.stage.form</field>
        <field name="model">letter.stage</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="move_from_user_ids" widget="many2many_tags"/>
                            <field name="send_activity_for_modality_manager"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="move_to_user_ids" widget="many2many_tags"/>
                            <field name="require_approval_letter"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="letter_stage_view_search" model="ir.ui.view">
        <field name="name">letter.stage.form</field>
        <field name="model">letter.stage</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_letter_stage" model="ir.actions.act_window">
        <field name="name">Letter Stages</field>
        <field name="res_model">letter.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_letter_stage" name="Letter Stage" action="action_letter_stage" parent="letter_configuration" sequence="3"/>
</odoo>