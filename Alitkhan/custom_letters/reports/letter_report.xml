<odoo>
    <record id="view_letter_report_tree" model="ir.ui.view">
        <field name="name">letter.report.tree</field>
        <field name="model">letter.report</field>
        <field name="arch" type="xml">
            <list string="Letters Analysis">
                <field name="letter_id"/>
            </list>
        </field>
    </record>
    <record id="view_letter_report_pivot" model="ir.ui.view">
        <field name="name">letter.report.pivot</field>
        <field name="model">letter.report</field>
        <field name="arch" type="xml">
            <pivot string="Letters Analysis" disable_linking="True">
                <field name="letter_id" type="row"/>
                <field name="stage_id" type="column"/>
                <field name="letter_type_id" type="column"/>
                <field name="contract_id" type="column"/>
                <field name="modality_id" type="column"/>
                <field name="late_letters" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="view_letter_report_graph" model="ir.ui.view">
        <field name="name">letter.report.graph</field>
        <field name="model">letter.report</field>
        <field name="arch" type="xml">
            <graph string="Letter Analysis" type="line">
                <field name="late_letters" type="measure"/>
            </graph>
        </field>
    </record>
<!--    <record id="letter_report_view_dashboard" model="ir.ui.view">-->
