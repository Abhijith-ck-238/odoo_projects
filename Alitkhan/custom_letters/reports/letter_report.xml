    <record id="view_letter_report_search" model="ir.ui.view">
        <field name="name">letter.report.search</field>
        <field name="model">letter.report</field>
        <field name="arch" type="xml">
            <search string="Letters Analysis">
                <group expand="1" string="Group By">
                    <filter string="Letter" name="Letter"
                            context="{'group_by':'letter_id'}"/>
                    <filter string="Stage" name="Stage"
                            context="{'group_by':'stage_id'}"/>
                    <filter string="Letter Type" name="Letter Type"
                            context="{'group_by':'letter_type_id'}"/>
                    <filter string="Contract" name="Contract"
                            context="{'group_by':'contract_id'}"/>
                    <filter string="Modality" name="Modality"
                            context="{'group_by':'modality_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_letter_report" model="ir.actions.act_window">
        <field name="name">Letters Analysis</field>
        <field name="res_model">letter.report</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_letter_report_search"/>
        <field name="help">This report performs analysis on your Lettres.
        </field>
    </record>
    <menuitem id="menu_letter_reporting" name="Reporting"
              parent="custom_letters.letter_menu_root" sequence="50"
              groups="group_letters_administrator"/>
    <menuitem id="menu_letter_report" name="Letters"
              parent="menu_letter_reporting"
              action="custom_letters.action_letter_report" sequence="10"/>
</odoo>
