<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="lc_type_view_tree" model="ir.ui.view">
        <field name="name">lc.type.list</field>
        <field name="model">lc.type</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="lc_type_view_form" model="ir.ui.view">
        <field name="name">lc.type.form</field>
        <field name="model">lc.type</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            <chatter/>
            </form>
        </field>
    </record>

    <record id="lc_type_view_search" model="ir.ui.view">
        <field name="name">lc.type.form</field>
        <field name="model">lc.type</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_lc_type" model="ir.actions.act_window">
        <field name="name">L/C Type</field>
        <field name="res_model">lc.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="pledge_configuration" name="Configuration" parent="pledge_assets.menu_root" sequence="30" groups="pledge_assets.pledge_user"/>
    <menuitem id="lc_type" name="L/C Type" action="action_lc_type" parent="pledge_configuration" sequence="1"/>
</odoo>
