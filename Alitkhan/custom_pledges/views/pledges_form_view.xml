        <record id="pledge_view_search" model="ir.ui.view">
            <field name="name">pledge.pledge.search</field>
            <field name="model">pledge.pledge</field>
            <field name="arch" type="xml">
                <search string="Pledges">
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <filter string="Pending Amendments" name="pending_amendments"
                            domain="[('count_pending_amendments', '>', 0)]"/>
                </search>
            </field>
        </record>

