<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pledge_stage_view_tree" model="ir.ui.view">
        <field name="name">pledge.stage.list</field>
        <field name="model">pledge.stage</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="sequence"/>
            </list>
        </field>
    </record>

    <record id="pledge_stage_view_form" model="ir.ui.view">
        <field name="name">pledge.stage.form</field>
        <field name="model">pledge.stage</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="move_from_user_ids" widget="many2many_tags"/>
                            <field name="is_from_user_notified"/>
                            <field name="other_users_notified" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="move_to_user_ids" widget="many2many_tags"/>
                            <field name="is_to_user_notified"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="pledge_stage_view_search" model="ir.ui.view">
        <field name="name">pledge.stage.form</field>
        <field name="model">pledge.stage</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_pledge_stage" model="ir.actions.act_window">
        <field name="name">Pledge Stage</field>
        <field name="res_model">pledge.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_pledge_stage" name="Pledge Stage" action="action_pledge_stage" parent="pledge_configuration" sequence="2"/>
</odoo>
