<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="contract_site_view_tree"
                model="ir.ui.view">
            <field name="name">contract site tree view</field>
            <field name="model">contract.site</field>
            <field name="inherit_id"
                   ref="contracts.contract_site_tree"/>
            <field name="arch" type="xml">
                <field name="site_province" position="after">
                    <field name="doh_id"/>
                </field>
            </field>
        </record>

        <record id="contract_site_view_form"
                model="ir.ui.view">
            <field name="name">contract site form view</field>
            <field name="model">contract.site</field>
            <field name="inherit_id"
                   ref="contracts.contract_site_form"/>
            <field name="arch" type="xml">
                <field name="site_province" position="after">
                    <field name="doh_id"/>
                </field>
            </field>
        </record>
    </data>
</odoo>