<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="interval_tree_view" model="ir.ui.view">
            <field name="name">interval.interval.tree.view</field>
            <field name="model">interval.interval</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="value" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="interval_view" model="ir.ui.view">
            <field name="name">interval.interval.view</field>
            <field name="model">interval.interval</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="value"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="interval_action_window" model="ir.actions.act_window">
            <field name="name">Intervals</field>
            <field name="res_model">interval.interval</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Interval
                </p>
            </field>
        </record>

        <menuitem name="PM Intervals" id="intervals"
                  parent="contracts.menu_settings"
                  action="interval_action_window"/>


    </data>
</odoo>