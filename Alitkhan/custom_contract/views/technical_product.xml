<odoo>
    <record id="technical_product_contract_tree_view" model="ir.ui.view">
        <field name="name">technical.product.contract.tree</field>
        <field name="model">technical.product</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Products">
                <field name="name"/>
                <field name="default_code"/>
                <field name="partner_id"/>
                <field name="modality"/>
            </list>
        </field>
    </record>

    <record id="technical_product_contract_form_view" model="ir.ui.view">
        <field name="name">technical.product.contract.form</field>
        <field name="model">technical.product</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Technical Products">
                <sheet>
                    <div class="oe_title">
                        <label class="oe_edit_only" for="name"
                               string="Product Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Lunch"/>
                        </h1>
                    </div>
                    <group name="product_details">
                        <group string="General Information">
                            <field name="partner_id"/>
                            <field name="modality"/>
                            <label for="default_code"/>
                            <div>
                                <field name="default_code"/>
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="technical_products_action_window" model="ir.actions.act_window">
            <field name="name">Technical Products</field>
            <field name="res_model">technical.product</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"default_is_technical_product": 1,'default_type': 'consu'}
            </field>
            <field name="domain">[('is_technical_product', '=', True)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create a new technical
                    product
                </p>
            </field>
        </record>
        <menuitem name="Technical Product" id="technical_product_contracts_menu"
                  parent="contracts.menu_root" action="technical_products_action_window"
                  sequence="1"/>
</odoo>
