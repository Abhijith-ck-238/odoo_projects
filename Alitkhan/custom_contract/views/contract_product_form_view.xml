<odoo>
    <data>
        <record id="contract_product_tree_view" model="ir.ui.view">
            <field name="name">contract.product.tree.view</field>
            <field name="model">contract.product</field>
            <field name="arch" type="xml">
                <list>
                    <field name="is_contract_in_warranty" column_invisible="1"/>
                     <field name="product_id" column_invisible="1"/>
<!--                    <field name="product_id"-->
<!--                           column_invisible="parent.product_show_option == 'show_product_char'"/>-->
                    <field name="product_char"/>
                    <field name="price"/>
                    <field name="qty" optional="1"/>
                    <field name="site"/>
                    <field name="province"/>
                    <field name="functional_location"/>
                    <field name="supplier"/>
                    <field name="modality"/>
                    <field name="part_number"/>
                    <field name="sn"/>
                    <field name="password_validity" optional="1"/>
                    <field name="password_validity_date" optional="1"/>
                    <field name="warranty" optional="1"/>
                    <field name="maintainence" optional="1"/>
                    <field name="starting_date"/>
                    <field name="pac_date"/>
                    <field name="eoc_date"/>
                    <field name="contract_type"/>
                    <field name="config"/>
                    <field name="parent_product_id"/>
                    <button string="Configuration" name="action_display_sub_units"
                            type="object">
                    </button>
                </list>
            </field>
        </record>

        <record id="contract_product_form_view" model="ir.ui.view">
            <field name="name">contract.product.form.view</field>
            <field name="model">contract.product</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="is_contract_in_warranty"
                                   invisible="1"/>
                                                 <field name="product_id"/>

<!--                            <field name="product_id"-->
<!--                                   column_invisible="parent.product_show_option == 'show_product_char'"/>-->
<!--                            <field name="product_char"-->
<!--                                   column_invisible="parent.product_show_option == 'show_product'"/>-->
                            <field name="product_char"/>
                            <field name="is_contract_in_warranty"
                                   invisible="1"/>
                            <field name="price"/>
                            <field name="qty"/>
                            <field name="site"/>
                            <field name="province"/>
                            <field name="functional_location"/>
                            <field name="supplier"/>
                            <field name="modality"/>
                            <field name="part_number"/>
                        </group>
                        <group>
                            <field name="sn"/>
                            <field name="password_validity" optional="1"/>
                            <field name="password_validity_date" optional="1"/>
                            <field name="warranty" optional="1"/>
                            <field name="maintainence" optional="1"/>
                            <field name="starting_date"/>
                            <field name="pac_date"/>
                            <field name="eoc_date"/>
                            <field name="contract_type"/>
                            <field name="config"/>
                            <field name="parent_product_id"/>
                            <button string="Configuration"
                                    name="action_display_sub_units"
                                    type="object">
                            </button>
                        </group>
                    </group>
                </form>
            </field>
        </record>

        <record id="product_product_tree_view"
                model="ir.ui.view">
            <field name="name">product.product.tree.view.inherit.custom.contrcat</field>
            <field name="model">product.product</field>
            <field name="inherit_id"
                   ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='standard_price']"
                       position="replace"/>
                <xpath expr="//field[@name='lst_price']"
                       position="replace"/>
            </field>
        </record>

        <record id="contract_product_line_form_view_product_limit" model="ir.ui.view">
            <field name="name">contract.product.tree.view</field>
            <field name="model">contract.contract</field>
            <field name="inherit_id"
                   ref="studio_customization.odoo_studio_contract_ca3b85fd-ba6f-479d-894d-2acbb397ff0f"/>
<!--            <field name="groups"-->
<!--                   eval="[(4,ref('custom_contract.product_access_limited_users'))]"/>-->
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_lines']/form/sheet/group[1]/group[1]/field[@name='product_id']"
                       position="replace">
                    <field name="product_id"
                           column_invisible="parent.old_data"
                           context="{'form_view_ref': 'custom_contract.product_view_inheritts', 'list_view_ref': 'custom_contract.product_product_tree_view'}"/>
                </xpath>
            </field>
        </record>

        <record id="contract_product_form_view_inherit"
                model="ir.ui.view">
            <field name="name">contract.product.form.viewinherit</field>
            <field name="model">contract.product</field>
            <field name="inherit_id"
                   ref="contracts.contract_product_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='contract_id']"
                       position="after">
                    <field name="pac_document" widget="many2many_binary"/>
                    <field name="dac_document" widget="many2many_binary"/>
                    <field name="handing_over_document" widget="many2many_binary"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
