<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="config_wizard_view" model="ir.ui.view">
            <field name="name">wizard for config</field>
            <field name="model">config.wizard</field>
            <field name="arch" type="xml">
                <form string="Config Window">
                    <group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                    <field name="product_lines">
                        <form>
                            <group>
                                <group>
                                    <field name="product_id" readonly="1"/>
                                </group>
                                <group>
                                    <field name="qty" readonly="1"/>
                                </group>
                            </group>
                        </form>


                        <list>
                            <field name="product_id"/>
                            <field name="qty"/>
                        </list>
                    </field>
                    <footer>
                        <button string="Cancel" class="btn-primary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="config_wizard" model="ir.actions.act_window">
            <field name="name">Config Wizard</field>
            <field name="res_model">config.wizard</field>
            <field name="view_id" ref="config_wizard_view"/>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
