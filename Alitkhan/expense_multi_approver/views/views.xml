<odoo>
	<data>

		<record id="hr_expense_sheet_form" model="ir.ui.view">
			<field name="name">hr.expense.sheet.form</field>
			<field name="model">hr.expense.sheet</field>
			<field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form" />
			<field name="arch" type="xml">
				<field name="user_id" position="replace">
					<field name="user_ids" widget="many2many_tags" readonly="state != 'draft'"/>
					<!-- <field name="next_approval_user"/> -->
				</field>

				 <!-- Hide accounting_date cause its needed in page -->
                <field name="accounting_date" position="attributes">
                    <attribute name="invisible">1</attribute>
                </field>

                <!-- Hide employee_journal_id  cause its needed in page-->
                <field name="employee_journal_id" position="attributes">
                    <attribute name="invisible">1</attribute>
                </field>

				<field name="payment_method_line_id" position="attributes">
					<attribute name="invisible">1</attribute>
				</field>

				<xpath expr="//page[@name='expenses']" position="after">
					 <page name="other_info" string="Other Info">
					<group>
						<field name="employee_journal_id" string="Expense Journal"
                                   groups="account.group_account_invoice,account.group_account_readonly"
                                   options="{'no_open': True, 'no_create': True}"
                                   invisible="payment_mode != 'own_account'" readonly="not is_editable"
                                   context="{'default_company_id': company_id}"/>
					</group>
					<group>
						<field name="accounting_date" optional="hide"
							   invisible="state not in ['approve', 'post', 'done'] or payment_mode == 'company_account'"
                                   readonly="not is_editable"/>
					</group>
						 <group>
							 <field name="payment_method_line_id" string="Bank Journal"
                                   options="{'no_open': True, 'no_create': True}"
                                   invisible="payment_mode != 'company_account'"
                                   readonly="not is_editable"
                                   required="payment_mode == 'company_account'"/>
						 </group>
		   		</page>

					<page name="approvals" string="Approvals">
						<field name="approval_lines" readonly="state != 'draft'">
							<list editable="bottom" delete="0">
								<field name="sequence" widget="handle"/>
								<field name="user_id"/>
								<field name="approved"/>
								<field name="approved_by"/>
								<field name="approved_date"/>
							</list>
						</field>
					</page>

				</xpath>
			</field>
		</record>
	</data>
</odoo>
