<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_employee_form_inherit_policy_button" model="ir.ui.view">
        <field name="name">hr.employee.policy.smartbutton</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_view_employee_policies"
                        class="oe_stat_button"
                        icon="fa-list">
                    <field name="policy_count" widget="statinfo" string="Policies"/>
                </button>
            </xpath>

        </field>
    </record>
</odoo>
