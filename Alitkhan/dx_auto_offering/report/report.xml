    <record id="report_offer" model="ir.actions.report">
        <field name="name">DX Offer</field>
        <field name="model">quotation.offer</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dx_auto_offering.report_quotation_offer</field>
        <field name="report_file">dx_auto_offering.report_quotation_offer</field>
        <field name="print_report_name">'DX Offer - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_quotation_offer"/>
        <field name="binding_type">report</field>
    </record>


</odoo>
