<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Budget Policy Tag List View -->
    <record id="view_budget_policy_tag_tree" model="ir.ui.view">
        <field name="name">budget.policy.tag.tree</field>
        <field name="model">budget.policy.tag</field>
        <field name="arch" type="xml">
            <list string="Budget Policy Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Budget Policy Tag Form View -->
    <record id="view_budget_policy_tag_form" model="ir.ui.view">
        <field name="name">budget.policy.tag.form</field>
        <field name="model">budget.policy.tag</field>
        <field name="arch" type="xml">
            <form string="Budget Policy Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_budget_policy_tag" model="ir.actions.act_window">
        <field name="name">Budget Policy Tags</field>
        <field name="res_model">budget.policy.tag</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first budget policy tag
            </p>
            <p>
                Use tags to categorize and organize your budget policies for better tracking and reporting.
            </p>
        </field>
    </record>

    <!-- Menu Item - Add under Expense Budgets menu -->
    <menuitem id="menu_budget_policy_tag"
              name="Policy Tags"
              parent="menu_hr_expense_budget_root"
              action="action_budget_policy_tag"
              groups="account.group_account_manager"
              sequence="30"
    />
</odoo>
