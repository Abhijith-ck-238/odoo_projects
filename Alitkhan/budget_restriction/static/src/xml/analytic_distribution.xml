<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

   <t t-name="budget_restriction.AnalyticDistributionPopup"
      t-inherit="analytic.AnalyticDistributionPopup">

       <xpath expr="//thead" position="replace">
           <thead>
               <tr class="border-bottom">
                   <th>Analytic Account</th>
                   <th class="numeric_column_width">Percentage</th>
                   <th class="deleteColumn w-20px"/>
               </tr>
           </thead>
       </xpath>

       <xpath expr="//tbody" position="replace">
           <tbody>
               <tr t-foreach="state.formattedData"
                   t-as="line"
                   t-key="line.id"
                   t-att-name="'line_' + line_index">

                   <Record t-props="recordProps(line)" t-slot-scope="data">
                       <td>
                           <Field name="'analytic_account_id'"
                                  record="data.record"
                                  canOpen="false"
                                  canCreate="false"
                                  canCreateEdit="false"
                                  canQuickCreate="false"/>
                       </td>
                       <td class="numeric_column_width">
                           <Field name="'percentage'"
                                  record="data.record"/>
                       </td>
                       <td class="w-20px">
                           <span class="fa fa-trash-o cursor-pointer"
                                 t-on-click.stop="() => this.deleteLine(line_index)"/>
                       </td>
                   </Record>
               </tr>
               <tr>
                   <td t-on-click.stop.prevent="addLine"
                       class="o_field_x2many_list_row_add"
                       colspan="3">
                       <a href="#" t-ref="addLineButton" tabindex="0">
                           Add a Line
                       </a>
                   </td>
               </tr>
           </tbody>
       </xpath>
   </t>

   <t t-name="budget_restriction.AnalyticDistribution"
      t-inherit="analytic.AnalyticDistribution"
      t-inherit-mode="extension">
           <xpath expr="//div[contains(@class, 'o_input_dropdown')]//t[@t-call='analytic.AnalyticDistributionPopup']"
              position="replace">
           <t t-if="props.record._config.resModel=='hr.expense.budget.policy'"  t-call="budget_restriction.AnalyticDistributionPopup"/>
           <t t-else="" t-call="analytic.AnalyticDistributionPopup"/>
       </xpath>


   </t>

</templates>
