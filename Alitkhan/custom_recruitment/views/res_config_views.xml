<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.custom.recruitment</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="35"/>
            <field name="inherit_id" ref="hr_recruitment.res_config_settings_view_form" />
            <field name="arch" type="xml">
            <xpath expr="//block[@name='recruitment_process_div']" position="after">
                    <h2>Show Hidden Fields</h2>
                        <div class="row mt16 o_settings_container" name="show_hidden_fields_div">
                            <div class="col-12 col-lg-6 o_setting_box" title="Show the hidden fields in the application.">
                                <div class="o_setting_left_pane">
                                    <field name="is_fields_visible"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="is_fields_visible" string="Show Hidden Fields"/>
                                    <div class="text-muted">
                                        Show the hidden fields in the application.
                                    </div>
                                </div>
                            </div>
                        </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
