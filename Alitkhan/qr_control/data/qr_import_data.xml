<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="sequence_qr_import" model="ir.sequence">
            <field name="name">Q&amp;R Import</field>
            <field name="code">qr.import</field>
            <field name="prefix">Q&amp;R/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="sequence_product_reservation" model="ir.sequence">
            <field name="name">Product Reservation</field>
            <field name="code">reserved.product</field>
            <field name="prefix">R/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
