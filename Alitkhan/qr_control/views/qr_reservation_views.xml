<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record model="ir.ui.view" id="qr_reservation_view_kanban">
            <field name="name">reserved.product.kanban</field>
            <field name="model">reserved.product</field>
            <field name="priority">10</field>
            <field name="arch" type="xml">
                <kanban class="o_modules_kanban" sample="1">
                    <field name="id"/>
                    <field name="import_id"/>
                    <field name="reserved_partner_id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="reserved_partner_id"/>
                                    </strong>

                                    <ul>
                                        <li>
                                            <t t-if="record.reserved_partner_id.raw_value">
                                                Reserved for :
                                                <field name="reserved_partner_id"/>
                                            </t>
                                        </li>
                                        <li>
                                            <t t-if="record.import_id.raw_value">
                                                Import :
                                                <field name="import_id"/>
                                            </t>
                                        </li>
                                        <li>
                                            <t t-if="record.sale_id.raw_value">
                                                Sale Order :
                                                <field name="sale_id"/>
                                            </t>
                                        </li>
                                        <li>
                                            <t t-if="record.user_id.raw_value">
                                                Salesman :
                                                <field name="user_id"/>
                                            </t>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="qr_reservation_form" model="ir.ui.view">
            <field name="name">qr.imports.form</field>
            <field name="model">reserved.product</field>
            <field name="arch" type="xml">
                <form string="Q&amp;R Reservation">
                    <header>
                        <field name="sale_id" invisible="1"/>
                        <button name="action_create_so" string="Create Sale Order" type="object" class="oe_highlight" invisible="not sale_id"/>
<!--                        <button name="action_create_so" string="Create Sale Order" type="object" class="oe_highlight" attrs="{'invisible': [('sale_id','!=',False)]}"/>-->
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label class="oe_edit_only" for="name" string="Reference"/>
                            <h1><field name="name" placeholder="Reference"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="import_id"/>
                                <field name="sale_id"/>
                            </group>
                            <group>
                                <field name="reserved_partner_id"/>
                                <field name="user_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="reservation_lines" string="Reservation Lines">
                                <field name="reserve_product_ids">
                                    <list string="Reservation Lines">
                                        <field name="product_id"/>
                                        <field name="qty_reserved"/>
                                        <field name="qr_product_id" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="qr_reservation_tree" model="ir.ui.view">
            <field name="model">reserved.product</field>
            <field name="arch" type="xml">
                <list string="Q&amp;R Reservation">
                    <field name="reserved_partner_id"/>
                    <field name="import_id"/>
                    <field name="sale_id"/>
                    <field name="user_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="qr_reservation_view_search" model="ir.ui.view">
            <field name="name">reserved.product.search</field>
            <field name="model">reserved.product</field>
            <field name="priority">32</field>
            <field name="arch" type="xml">
                <search string="Product Reservations">
                    <separator/>
                    <field string="Reserved for" name="reserved_partner_id"
                           filter_domain="[('reserved_partner_id', 'ilike', self)]"/>
                    <field string="Salesman" name="user_id"
                           filter_domain="[('user_id', 'ilike', self)]"/>
                    <group expand="1" string="Group By">
                        <filter string="Reserved for" name="groupby_reserved_partner_id"
                                context="{'group_by': 'reserved_partner_id'}"/>
                        <filter string="Q&amp;R Import" name="groupby_import_id"
                                context="{'group_by': 'import_id'}"/>
                        <filter string="Salesman" name="groupby_user_id"
                                context="{'group_by': 'user_id'}"/>
                    </group>

                </search>
            </field>
        </record>

        <record id="qr_reservation_line_form" model="ir.ui.view">
            <field name="name">qr.reservation.line.form</field>
            <field name="model">reserved.product.line</field>
            <field name="arch" type="xml">
                <form string="Q&amp;R Reservation Line">
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="reserved_product_id"/>
                            <field name="reserved_partner_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="qty_reserved"/>
                            <field name="qr_product_id"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                </form>
            </field>
        </record>

        <record id="qr_reservation_line_tree" model="ir.ui.view">
            <field name="name">qr.reservation.line.tree</field>
            <field name="model">reserved.product.line</field>
            <field name="arch" type="xml">
                <list string="Q&amp;R Reservation Line">
                    <field name="product_id"/>
                    <field name="qty_reserved"/>
                    <field name="reserved_product_id"/>
                    <field name="reserved_partner_id"/>
                    <field name="user_id"/>
                    <field name="qr_product_id" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="action_qr_reservation" model="ir.actions.act_window">
            <field name="name">Q&amp;R Reservations</field>
            <field name="res_model">reserved.product</field>
            <field name="view_mode">kanban,list,graph,pivot,form</field>
            <field name="search_view_id" ref="qr_control.qr_reservation_view_search"/>
             <field name="help">Q&amp;R Reservations</field>
        </record>

    </data>
</odoo>
