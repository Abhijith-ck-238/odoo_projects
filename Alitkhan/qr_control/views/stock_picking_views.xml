<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.ui.view" id="view_stock_free_quant_tree">
        <field name="name">stock.quant.tree</field>
        <field name="model">stock.quant</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Pickings" decoration-danger="inventory_quantity &lt; 0"  create="false" duplicate="false" delete="false" import="0">
                <field name="product_id" invisible="context.get('single_product', False)"/>
                <field name="location_id" invisible="context.get('hide_location', False)"/>
                <field name="lot_id" groups="stock.group_production_lot"
                       invisible="context.get('hide_lot', False)"/>
                <field name="package_id" groups="stock.group_tracking_lot"/>
                <field name="owner_id" groups="stock.group_tracking_owner"/>
                <field name="free_qty" string="Available"/>
                <field name="reserved_quantity" string="Reserved" optional="hde"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name='company_id' groups="base.group_multi_company"/>
                <field name="inventory_quantity" invisible="1"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="view_incoming_pickings_tree">
        <field name="name">stock.picking.tree</field>
        <field name="model">stock.picking</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Pickings" create="false" duplicate="false" delete="false" import="0"
            decoration-info="state == 'draft'" decoration-muted="state == 'cancel'" decoration-danger="state not in ('cancel', 'done') and scheduled_date &lt; current_date">
                <field name="name"/>
                <field name="location_id" options="{'no_create': True}" string="From" groups="stock.group_stock_multi_locations" optional="show"/>
                <field name="location_dest_id" options="{'no_create': True}" string="To" groups="stock.group_stock_multi_locations" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="user_id" optional="hide"/>
                <field name="date" invisible="1"/>
                <field name="qty_incoming"/>
                <field name="lot_ids" widget="many2many_tags"/>
                <field name="scheduled_date" optional="show"/>
                <field name="origin" optional="show"/>
                <field name="group_id" invisible="1"/>
                <field name="backorder_id" optional="hide"/>
                <field name="state" optional="show"/>
                <field name="priority" optional="hide"/>
                <field name="picking_type_id" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="activity_exception_decoration" widget="activity_exception"/>
            </list>
        </field>
    </record>
</odoo>