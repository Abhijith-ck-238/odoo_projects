<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_move_form" model="ir.ui.view">
            <field name="name">view.move.form.inherit.custom.purcahse</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']//list/field[@name='tax_ids']"
                       position="after">
                    <field name="shipment_id" column_invisible="parent.move_type != 'in_invoice'" context="{'list_view_ref': 'custom_logistcs.logistics_shipment_tree_search_more'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>