<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="purchase_order_view_form_inherit" model="ir.ui.view">
        <field name="name">purchase.stock.order.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase_stock.purchase_order_view_form_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='purchase_delivery_invoice']/group/group"
                   position="inside">
                <field name="team_id"/>
                <field name="warehouse_id"/>
            </xpath>
        </field>
    </record>
    <record id="purchase_order_offering_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.offering.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="itkan_offering.offering_purchase_inh_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='related_offering_record']"
                   position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
        </field>
    </record>
    <record id="purchase_order_view_list_inherit" model="ir.ui.view">
        <field name="name">purchase.stock.order.list.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="bill_total"/>
                <field name="paid_amount"/>
                <field name="open_order"/>
                <field name="remaining"/>
            </xpath>
        </field>
    </record>
    <record id="purchase_order_form_analytic" model="ir.ui.view">
        <field name="name">purchase.order.form.analytic</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                 <field name="analytic_precision" invisible="1"/>
                   <label for="analytic_distribution" string="Analytic Distribution" groups="analytic.group_analytic_accounting"/>
                <div groups="analytic.group_analytic_accounting">
                    <div class="o_row">
                        <field name="analytic_distribution" widget="analytic_distribution" nolabel="1"/>
                        <button id="button_save" name="action_save_analytic_distribution" string="Save"
                                type="object" class="btn-primary" style="margin-left: 8px;"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>