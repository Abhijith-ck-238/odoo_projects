<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record model="ir.ui.view" id="purchase_team_view_tree">
            <field name="name">purchase.team.tree.view</field>
            <field name="model">purchase.team</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="warehouse_id"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="purchase_team_view_form">
            <field name="name">purchase.team.form.view</field>
            <field name="model">purchase.team</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="warehouse_id"/>
                        </group>
                        <notebook>
                            <page string="Members">
                                <field name="member_ids" widget="many2many"
                                       options="{'not_delete': True}">
                                    <kanban quick_create="false" create="true"
                                            delete="true">
                                        <field name="id"/>
                                        <field name="name"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click"
                                                     style="max-width: 200px">
                                                    <div class="o_kanban_record_top">
                                                        <img t-att-src="kanban_image('res.users', 'image_128', record.id.raw_value)"
                                                             class="oe_avatar oe_kanban_avatar_smallbox o_image_40_cover mb0"
                                                             alt="Avatar"/>
                                                        <div class="o_kanban_record_headings ml8">
                                                            <strong class="o_kanban_record_title">
                                                                <field name="name"/>
                                                            </strong>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="purchase_team_action" model="ir.actions.act_window">
            <field name="name">Purchase Team</field>
            <field name="res_model">purchase.team</field>
        </record>
        <menuitem
                name="Purchase Team"
                parent="purchase.menu_purchase_config"
                id="menu_purchase_team"
                action="purchase_team_action"/>
    </data>
</odoo>