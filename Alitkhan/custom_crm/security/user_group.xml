<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="module_category_crm" model="ir.module.category">
            <field name="name">CRM</field>
            <field name="description">Helps you to manage the CRM</field>
        </record>

        <record id="group_crm_own_documents" model="res.groups">
            <field name="name">CRM / Own Documents</field>
            <field name="category_id" ref="module_category_crm"/>
            <field name="users" eval="[(4,ref('__export__.res_users_684_26798fab'))]"/>
        </record>

        <record id="group_crm_administrator" model="res.groups">
            <field name="name">CRM / Administrator</field>
            <field name="category_id" ref="module_category_crm"/>
        </record>

        <record id="group_crm_sales_reporting" model="res.groups">
            <field name="name">CRM / Sales Reporting</field>
            <field name="category_id" ref="module_category_crm"/>
            <field name="users" eval="[(4,ref('__export__.res_users_684_26798fab'))]"/>
        </record>

        <record id="crm_rule_personal_lead" model="ir.rule">
            <field name="name">Personal Leads</field>
            <field ref="crm.model_crm_lead" name="model_id"/>
            <field name="domain_force">['|','|', ('user_id','=',user.id),('user_id','=',False), ('team_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(3, ref('sales_team.group_sale_salesman')),(4, ref('custom_crm.group_crm_own_documents'))]"/>
        </record>

        <record id="crm_rule_all_lead" model="ir.rule">
            <field name="name">All Leads</field>
            <field ref="crm.model_crm_lead" name="model_id"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(3, ref('sales_team.group_sale_salesman_all_leads')),(4, ref('custom_crm.group_crm_administrator'))]"/>
        </record>

        <record id="crm_rule_report_sales_team" model="ir.rule">
            <field name="name">CRM Report for Sales Team</field>
            <field ref="crm.model_crm_lead" name="model_id"/>
            <field name="domain_force">['|', ('team_id.user_id','=',user.id), ('team_id.member_ids', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_crm.group_crm_sales_reporting'))]"/>
        </record>
    </data>
</odoo>