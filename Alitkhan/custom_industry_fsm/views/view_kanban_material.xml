<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="product_product_kanban_view_fsm" model="ir.ui.view">
            <field name="name">product.product.fsm.kanban</field>
            <field name="model">product.product</field>
            <field name="inherit_id"
                   ref="industry_fsm_sale.industry_fsm_sale_product_catalog_kanban_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='o_kanban_qty_available']"
                       position="attributes">
                    <attribute name="t-if">1</attribute>
                </xpath>
            </field>
        </record>


        <record id="view_product_product_kanban_material_for_helpdesk_support_center"
                model="ir.ui.view">
            <field name="name">view.product.template.kanban.material</field>
            <field name="model">product.product</field>
            <field name="priority">999</field>
            <field name="arch" type="xml">
                <kanban edit="0" class="o_kanban_mobile o_fsm_material_kanban">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="product_template_attribute_value_ids"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="o_kanban_record"
                                 style="min-height: 100px;">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('product.product', 'image_128', record.id.raw_value)"
                                         alt="Product"
                                         class="o_image_64_contain"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <div class="o_kanban_record_top" style="justify-content: space-between;">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <div>
                                                    <strong>
                                                        <span t-esc="record.name.value"/>
                                                    </strong>
                                                </div>
                                            </strong>
                                            <div class="o_kanban_tags_section">
                                                <field name="product_template_attribute_value_ids"
                                                       groups="product.group_product_variant"/>
                                                <span t-if="record.default_code.value">[<field name="default_code"/>]</span>
                                            </div>
                                        </div>
                                        <strong style="font-size:2.5rem; margin-top:25px;"><field name="fsm_quantity"/></strong>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    </data>
</odoo>