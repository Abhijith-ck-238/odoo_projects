<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="group_project_user_limited" model="res.groups">
            <field name="name">Task Limited User</field>
            <field name="category_id" ref="base.module_category_services_project"/>
        </record>

        <record id="group_fsm_own_ticket_user" model="res.groups">
            <field name="name">Field Service/Own Ticket</field>
            <field name="category_id" ref="base.module_category_services_field_service"/>
            <field name="menu_access" eval="[(4, ref('industry_fsm.fsm_menu_root')),(4, ref('industry_fsm.fsm_tasks_menu')),
            (4, ref('industry_fsm.fsm_menu_settings'))]"/>
        </record>

        <record model="ir.rule" id="field_service_users_rule">
            <field name="name">Project: Followers on the task of the project</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[ ('tasks.message_partner_ids', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('industry_fsm.group_fsm_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

