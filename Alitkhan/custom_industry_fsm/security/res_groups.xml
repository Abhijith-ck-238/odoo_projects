        <record id="sale_order_access_unit_rule" model="ir.rule">
            <field name="name">Sale Order Access Unit</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('access_unit_ids.id','in', user.employee_id.access_units.ids),('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4,ref('access_units.access_unites_limited_users'))]"/>
        </record>

        <record id="sale_order_access_unit_rule_own_document" model="ir.rule">
            <field name="name">Sale Order Access Unit Own Document</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('access_unit_ids.id','in', user.employee_id.access_units.ids),('user_id', '=', user.id)]</field>
        </record>

        <record id="sale_order_access_unit_rule_all_document" model="ir.rule">
            <field name="name">Sale Order Access Unit All Document</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('access_unit_ids.id','in', user.employee_id.access_units.ids)]</field>
        </record>

        <record id="sales_team.group_sale_salesman_all_leads" model="res.groups">
            <field name="rule_groups" eval="[(3, ref('sale.sale_order_see_all')),
            (4, ref('custom_industry_fsm.sale_order_access_unit_rule_all_document'))]"/>
        </record>

        <record id="sales_team.group_sale_salesman" model="res.groups">
            <field name="rule_groups" eval="[(3, ref('sale.sale_order_personal_rule')),
            (4, ref('custom_industry_fsm.sale_order_access_unit_rule_own_document'))]"/>
        </record>
    </data>
