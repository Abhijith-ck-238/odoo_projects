<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_sale" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.sale.stock.sale</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@id='connectors_setting_container']" position="after">
                    <block title="Sale Order Confirmation Notify User" id="confirmation_notify_user_container">
                        <setting id="notify_users_setting" help="Selects Users needs to be notified on SO confirmation">
                            <field name="confirm_activity_user_ids" widget="many2many_tags"/>
                        </setting>
                    </block>
                    <block title="Lot Expiry Alert User" id="lot_expiry_alert_user_container">
                        <setting id="lot_expiry_alert_user_setting" help="Selects Users needs to be alerted on Lot Expiration">
                            <field name="lot_expiry_alert_user_ids" widget="many2many_tags"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>

    </data>
</odoo>