<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record model="ir.ui.view" id="product_template_product_name_without_spaces">
            <field name="name">product.template.product_name_without_spaces</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='unit_id']" position="after">
                    <field name="compressed_name" force_save="1" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
