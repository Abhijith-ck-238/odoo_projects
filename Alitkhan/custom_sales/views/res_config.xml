<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_sale_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.sale</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="35"/>
            <field name="inherit_id" ref="sale.res_config_settings_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//block[@id='lot_expiry_alert_user_container']" position="after">
                    <block title="Bank Account" id="bank_account_container">
                        <setting id="bank_account_setting" help="Selects Bank Account">
                            <field name="bnk_account_id"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
