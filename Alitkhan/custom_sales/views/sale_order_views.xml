<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_search_inherit_exchange_value"
            model="ir.ui.view">
        <field name="name">sale.order.search.inherit.exchange.value</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="total_of_exchange_products"/>
                <filter string="Exchange value is set" name=""
                        domain="[('total_of_exchange_products', '!=', False)]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="Payment Status" name="payment_state" domain="[]"
                        context="{'group_by': 'invoice_payment_state'}"/>
            </xpath>
        </field>
    </record>

    <record id="sale_report_view_pivot" model="ir.ui.view">
        <field name="name">sale.report.pivot</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <pivot string="Sales Analysis" disable_linking="True"
                   display_quantity="true">
                <field name="categ_id" type="row"/>
<!--                <field name="order_id" type="measure"/>-->
                <field name="price_subtotal" type="measure"/>
                <field name="price_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="sale_order_inherits_form" model="ir.ui.view">
        <field name="name">sale_order_inherits_form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
             <xpath expr="//button[@name='action_preview_sale_order']"
                   position="before">
                <button name="view_related_contracts" type="object"
                        class="oe_stat_button" icon="fa-file-text icon"
                        invisible="not contract_id"
                        groups="__export__.res_groups_167_73baca6a">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Contracts</span>
                    </div>
                </button>
            </xpath>

<!--            <xpath expr="//button[3]" position="replace">-->
<!--                <button name="%(sale.action_view_sale_advance_payment_inv)d"-->
<!--                        string="Create Invoice"-->
<!--                        type="action" class="btn-primary"-->
<!--                        invisible="[('invoice_status', '!=', 'to invoice')]"-->
<!--                        groups="account.group_account_invoice"/>-->
<!--            </xpath>-->
<!--            <xpath expr="//button[4]" position="replace">-->
<!--                <button name="%(sale.action_view_sale_advance_payment_inv)d"-->
<!--                        string="Create Invoice"-->
<!--                        type="action"-->
<!--                        context="{'default_advance_payment_method': 'percentage'}"-->
<!--                        invisible=" ['|',('invoice_status', '!=', 'no'), ('state', '!=', 'sale')]"-->
<!--                        groups="account.group_account_invoice"/>-->
<!--            </xpath>-->


            <xpath expr="//form/sheet/group[1]/group[1]/field[@name='partner_id']"
                   position="after">
                <field name="is_cancel_btn_visible" invisible="1" />
            </xpath>

            <xpath expr="//form/header/button[@name='action_cancel']"
                   position="replace">
                <button name="action_cancel" type="object" string="Cancel"
                        invisible="not is_cancel_btn_visible"/>
            </xpath>

            <xpath expr="//form/header/button[@name='action_cancel']"
                   position="after">
                <button name="action_create_contract" type="object"
                        string="Create Contract" groups="__export__.res_groups_167_73baca6a" invisible="contract_id"
                />
<!--                <button name="action_create_contract" type="object"-->
<!--                        string="Create Contract"-->
<!--                        groups="__export__.res_groups_167_73baca6a"-->
<!--                        invisible="not contract_id"-->
<!--                />-->
            </xpath>

            <xpath expr="//group[@name='sale_info']" position="inside">
            <field name="analytic_account_id"/>
        </xpath>

        </field>
    </record>

    <record id="sale_order_inherits_form_new" model="ir.ui.view">
        <field name="name">sale_order_inherits_form_new</field>
        <field name="model">sale.order</field>
        <field name="inherit_id"
               ref="itkan_custom_sales_order.sale_order_view_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='offering_so_info']/group[1]/group[1]/field[@name='project_num']"
                   position="after">
                <field name="iq"/>
            </xpath>
            <xpath expr="//page[@name='offering_so_info']/group[1]/group[1]/field[@name='date']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale_order_offering_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.offering.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="itkan_offering.offering_sale_inh_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='related_offering_record']"
                       position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
        </field>
    </record>

