<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="custom_picking_operation_report_inherit" inherit_id="stock.report_picking">
            <xpath expr="//t[@t-call='web.external_layout']" position="before">
                <t t-set="is_delivery_slip" t-value="True"/>
            </xpath>

            <xpath expr="//tr[@t-foreach='o.move_line_ids_without_package.sorted(lambda ml: (ml.location_id.complete_name, ml.location_dest_id.complete_name))']"
                   position="attributes">
                <attribute name="style">border-bottom:1px solid #e1e1e1;</attribute>
            </xpath>

            <!-- Add bottom border to each package row -->
            <xpath expr="//tr[@t-foreach='o.package_level_ids.sorted(key=lambda p: p.package_id.name)']"
                   position="attributes">
                <attribute name="style">border-bottom:1px solid #e1e1e1;</attribute>
            </xpath>

            <xpath expr="//table[@class='table table-borderless mt16']//thead" position="before">
                <tr>
                    <td colspan="6" style="border-top:1px solid #e1e1e1; padding:0;"></td>
                </tr>
            </xpath>

            <xpath expr="//table[@class='table table-borderless'][.//tr[@t-foreach='o.package_level_ids.sorted(key=lambda p: p.package_id.name)']]/thead"
                   position="before">
                <tr>
                    <td colspan="3" style="border-top:1px solid #e1e1e1; padding:0;"></td>
                </tr>
            </xpath>


        </template>
    </data>
</odoo>