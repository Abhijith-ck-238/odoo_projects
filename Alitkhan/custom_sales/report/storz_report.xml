<odoo>
    <data>
        <odoo>
    <data>
        <record id="action_report_saleorder" model="ir.actions.report">
            <field name="name">Storz Exchange</field>
            <field name="model">sale.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_sales.storz_report_saleorder</field>
            <field name="report_file">custom_sales.storz_report_saleorder</field>
            <field name="print_report_name">(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or 'Order - %s' % (object.name)</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>

