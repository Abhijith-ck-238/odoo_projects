<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="custom_delivery_report_inherit_1" inherit_id="stock.report_delivery_document">

            <xpath expr="//t[@t-call='custom_stock.custom_external_layout_stock']" position="before">
                <t t-set="is_delivery_slip" t-value="True"/>
            </xpath>
            <xpath expr="//t[@t-set='address']" position="replace">
                <t t-set="address"/>
            </xpath>

            <!-- Remove information block -->
            <xpath expr="//t[@t-set='information_block']" position="replace">
                <t t-set="information_block"/>
            </xpath>

            <xpath expr="//div[hasclass('page')]" position="replace">
                <div class="page">
                    <div t-if="docs.partner_id.name" class="text-start" style="margin-top: -5px; margin-bottom: 15px;">
                        <strong>Customer Name:</strong>
                        <br/>
                        <span t-field="docs.partner_id.name"/>
                        <div t-field="docs.partner_id"
                             t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: ['street','city', 'phone'], &quot;no_marker&quot;: True, &quot;phone_icons&quot;: True}"/>
                    </div>
                    <h2>
                        <span t-field="o.name"/>
                    </h2>
                    <div class="row mt32 mb32">
                        <div t-if="o.origin" class="col-auto" name="div_origin">
                            <strong>Order:</strong>
                            <p t-field="o.origin"/>
                        </div>
                        <div t-if="o.state" class="col-auto ms-4" name="div_sched_date">
                            <strong>Shipping Date:</strong>
                            <t t-if="o.state == 'done'">
                                <p t-field="o.date_done"/>
                            </t>
                            <t t-if="o.state != 'done'">
                                <p t-field="o.scheduled_date"/>
                            </t>
                        </div>
                    </div>
                    <table class="table table-sm" align="center" t-if="o.state!='done'" name="stock_move_table">
                        <thead>
                            <tr>
                                <td colspan="4" style="border-top:1px solid #e1e1e1; padding:0;"/>
                            </tr>
                            <tr style="border-bottom:1px solid #e1e1e1;">
                                <th name="th_sm_no" style="text-align:center;33%;">
                                    <strong>NO.</strong>
                                </th>
                                <th name="th_sm_product" style="text-align:center;33%;">
                                    <strong>Product</strong>
                                </th>
                                <th name="th_sm_product" style="text-align:center;33%;">
                                    <strong>Receipt</strong>
                                </th>
                                <th name="th_sm_quantity" style="text-align:center;width:33%;">
                                    <strong>Quantity</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="lines"
                               t-value="o.move_ids_without_package.filtered(lambda x: x.product_uom_qty)"/>
                            <t t-set="no" t-value="0"/>
                            <tr t-foreach="lines" t-as="move" style="border-bottom:1px solid #e1e1e1;">
                                <t t-set="no" t-value="no+1"/>
                                <td style="text-align:center;">
                                    <span>
                                        <t t-esc="no"/>
                                    </span>
                                </td>
                                <t t-if="move.display_type == 'line_section'">
                                    <td style="text-align:center;background-color:grey;" colspan="2">
                                        <span style="font-style:bold;color:white;" t-field="move.product_id.name"/>
                                    </td>
                                </t>
                                <t t-else="">
                                    <td style="text-align:center;50%;">
                                        <span t-field="move.product_id"/>
                                        <p t-if="move.description_picking != move.product_id.name">
                                            <span t-field="move.description_picking"/>
                                        </p>
                                    </td>
                                    <td style="text-align:center;50%;">
                                        <img src="/custom_sales/static/src/images/checkbox.png" width="16" height="16"/>
                                    </td>
                                    <td style="text-align:center;50%;">
                                        <span t-field="move.product_uom_qty"/>
                                        <span t-field="move.product_uom"/>
                                    </td>
                                </t>
                            </tr>
                        </tbody>
                    </table>
                    <table class="table table-borderless " t-if="o.move_line_ids and o.state=='done'"
                           name="stock_move_line_table">
                        <t t-set="has_serial_number" t-value="o.move_line_ids.mapped('lot_id')"/>
                        <thead>
                            <tr>
                                <td colspan="4" style="border-top:1px solid #e1e1e1; padding:0;"/>
                            </tr>
                            <tr style="border-bottom:1px solid #e1e1e1;">
                                <th name="th_sm_no" style="text-align:center;33%;">
                                    <strong>NO.</strong>
                                </th>
                                <th name="th_sml_product">
                                    <strong>Product</strong>
                                </th>
                                <th name="lot_serial" t-if="has_serial_number"
                                    groups="stock.group_lot_on_delivery_slip">
                                    Lot/Serial Number
                                </th>
                                <th name="th_sm_product" style="text-align:center;33%;">
                                    <strong>Receipt</strong>
                                </th>
                                <th name="th_sml_quantity" class="text-center">
                                    <strong>Quantity</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Reintroduce has_packages logic to avoid breaking other inherited views -->
                            <t t-if="o.has_packages" name="has_packages">
                                <t t-set="packages" t-value="o.move_line_ids.mapped('result_package_id')"/>
                                <t t-foreach="packages" t-as="package" style="border-bottom:1px solid #e1e1e1;">
                                    <t t-call="stock.stock_report_delivery_package_section_line"/>
                                    <t t-set="package_move_lines"
                                       t-value="o.move_line_ids.filtered(lambda l: l.result_package_id == package)"/>
                                    <t t-if="has_serial_number">
                                        <tr t-foreach="package_move_lines" t-as="move_line">
                                            <t t-set="num" t-value="num+1"/>
                                            <td style="text-align:center;">
                                                <span>
                                                    <t t-esc="num"/>
                                                </span>
                                            </td>
                                            <td>
                                                <span t-field="move_line.product_id"/>
                                                <p t-if="move_line.move_id.description_picking != move_line.product_id.name">
                                                    <span t-field="move_line.move_id.description_picking"/>
                                                </p>
                                            </td>
                                            <td t-if="move_line.lot_id.name" groups="stock.group_lot_on_delivery_slip">
                                                <span t-field="move_line.lot_id.name"/>
                                            </td>
                                            <td t-elif="has_serial_number" groups="stock.group_lot_on_delivery_slip">
                                                <span t-field="move_line.lot_name"/>
                                            </td>
                                            <td style="text-align:center;50%;">
                                                <img src="/custom_sales/static/src/images/checkbox.png" width="16"
                                                     height="16"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="move_line.qty_done"/>
                                                <span t-field="move_line.product_uom_id"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <t t-set="aggregated_lines"
                                           t-value="package_move_lines._get_aggregated_product_quantities(strict=True)"/>
                                        <t t-call="stock.stock_report_delivery_aggregated_move_lines"/>
                                    </t>
                                </t>
                                <t t-set="move_lines"
                                   t-value="o.move_line_ids.filtered(lambda l: not l.result_package_id)"/>
                                <t t-set="aggregated_lines"
                                   t-value="o.move_line_ids._get_aggregated_product_quantities(except_package=True)"/>
                                <t t-if="move_lines or aggregated_lines" name="no_package_move_lines">
                                    <t t-call="stock.stock_report_delivery_no_package_section_line"
                                       name="no_package_section"/>
                                    <t t-if="has_serial_number">
                                        <tr t-foreach="move_lines" t-as="move_line"
                                            style="border-bottom:1px solid #e1e1e1;">
                                            <t t-set="num" t-value="num+1"/>
                                            <td style="text-align:center;">
                                                <span>
                                                    <t t-esc="num"/>
                                                </span>
                                            </td>
                                            <td>
                                                <span t-field="move_line.product_id"/>
                                                <p t-if="move_line.move_id.description_picking != move_line.product_id.name">
                                                    <span t-field="move_line.move_id.description_picking"/>
                                                </p>
                                            </td>
                                            <td t-if="move_line.lot_id.name" groups="stock.group_lot_on_delivery_slip">
                                                <span t-field="move_line.lot_id.name"/>
                                            </td>
                                            <td t-elif="has_serial_number" groups="stock.group_lot_on_delivery_slip">
                                                <span t-field="move_line.lot_name"/>
                                            </td>
                                            <td style="text-align:center;50%;">
                                                <img src="/custom_sales/static/src/images/checkbox.png" width="16"
                                                     height="16"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="move_line.qty_done"/>
                                                <span t-field="move_line.product_uom_id"/>
                                            </td>
                                        </tr>
                                    </t>

                                    <t t-elif="aggregated_lines">
                                        <t t-call="stock.stock_report_delivery_aggregated_move_lines"/>
                                    </t>
                                </t>
                            </t>
                            <!-- No destination packages -->
                            <t t-else="">
                                <t t-if="has_serial_number">
                                    <t t-set="num" t-value="0"/>
                                    <tr t-foreach="o.move_line_ids" t-as="move_line"
                                        style="border-bottom:1px solid #e1e1e1;">
                                        <t t-set="num" t-value="num+1"/>
                                        <td style="text-align:center;">
                                            <span>
                                                <t t-esc="num"/>
                                            </span>
                                        </td>
                                        <td>
                                            <span t-field="move_line.product_id"/>
                                            <p t-if="move_line.move_id.description_picking != move_line.product_id.name">
                                                <span t-field="move_line.move_id.description_picking"/>
                                            </p>
                                        </td>
                                        <td t-if="move_line.lot_id.name" groups="stock.group_lot_on_delivery_slip">
                                            <span t-field="move_line.lot_id.name"/>
                                        </td>
                                        <td t-elif="has_serial_number" groups="stock.group_lot_on_delivery_slip">
                                            <span t-field="move_line.lot_name"/>
                                        </td>
                                        <td style="text-align:center;50%;">
                                            <img src="/custom_sales/static/src/images/checkbox.png" width="16"
                                                 height="16"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-field="move_line.qty_done"/>
                                            <span t-field="move_line.product_uom_id"/>
                                        </td>
                                    </tr>
                                </t>
                                <t t-else="">
                                    <t t-set="aggregated_lines"
                                       t-value="o.move_line_ids._get_aggregated_product_quantities()"/>
                                    <t t-set="num" t-value="0"/>
                                    <tr t-foreach="o.move_line_ids" t-as="move_line"
                                        style="border-bottom:1px solid #e1e1e1;">
                                        <t t-set="num" t-value="num+1"/>
                                        <td style="text-align:center;">
                                            <span>
                                                <t t-esc="num"/>
                                            </span>
                                        </td>
                                        <td>
                                            <span t-field="move_line.product_id"/>
                                            <p t-if="move_line.move_id.description_picking != move_line.product_id.name">
                                                <span t-field="move_line.move_id.description_picking"/>
                                            </p>
                                        </td>
                                        <td t-if="has_serial_number and move_line.lot_id.name"
                                            groups="stock.group_lot_on_delivery_slip">
                                            <span t-field="move_line.lot_id.name"/>
                                        </td>
                                        <td t-elif="has_serial_number" groups="stock.group_lot_on_delivery_slip">
                                            <span t-field="move_line.lot_name"/>
                                        </td>
                                        <td style="text-align:center;50%;">
                                            <img src="/custom_sales/static/src/images/checkbox.png" width="16"
                                                 height="16"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-field="move_line.qty_done"/>
                                            <span t-field="move_line.product_uom_id"/>
                                        </td>
                                    </tr>
                                    <!--<t t-call="stock.stock_report_delivery_aggregated_move_lines"/>-->
                                </t>
                            </t>
                        </tbody>
                    </table>
                    <p>
                        <t t-if="o.backorder_ids and o.backorder_ids.filtered(lambda x: x.state not in ('done', 'cancel'))">
                            All items couldn't be shipped, the remaining ones will be shipped as soon as they become
                            available.
                        </t>
                    </p>
                    <div style="margin-left: 50px;margin-top: 35px;margin-bottom: 40px;">
                        <div class="row" style="height:40px;">
                            <div class="col">
                                <span>
                                    <p style="font-size:16px;">
                                        <span><strong>Recipient Signature:</strong>____________________________
                                        </span>
                                    </p>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>

        </template>
    </data>
</odoo>