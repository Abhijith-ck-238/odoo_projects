<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_overdue_sales_pdf">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page">
                    <div class="row mt64 mb32">
                        <div class="col-md-12">
                            <h2 class="text-center">
                                <span text-align="center">
                                    Overdue Sales Report
                                </span>
                            </h2>
                        </div>
                    </div>
                    <div class="row pt-2">
                        <div class="col-md-12">
                            <t>
                                <table class="table table-borderless">
                                    <thead>
                                        <tr>
                                            <th class="text-center" style="font-weight:bold;">#</th>
                                            <th class="text-center" style="font-weight:bold;">Sale Order</th>
                                            <th class="text-center" style="font-weight:bold;">Reference</th>
                                            <th class="text-center" style="font-weight:bold;">Customer</th>
                                            <th class="text-center" style="font-weight:bold;">Due Date</th>
                                            <th class="text-center" style="font-weight:bold;">Sales Person</th>
                                            <th class="text-center" style="font-weight:bold;">Total</th>
                                            <th class="text-center" style="font-weight:bold;">Amount Due</th>
                                            <th class="text-center" style="font-weight:bold;">Amount Remaining</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="i" t-value="1"/>
                                        <t t-foreach="data" t-as="o">
                                            <tr class="text-center">
                                                <td text-align="center">
                                                    <t t-esc="i"/>
                                                    <t t-set="i" t-value="i+1"/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-esc="o['source_document']"/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-esc="o['reference']"/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-esc="o['customer']"/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-esc="o['due_date']"/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-esc="o['sales_person']"/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-if="o['is_fi']">
                                                        <span>F.I </span>
                                                    </t>
                                                    <t t-esc="o['total']" t-options='{"widget": "monetary", "display_currency": o["currency"]}'/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-esc="o['amount_due']" t-options='{"widget": "monetary", "display_currency": o["currency"]}'/>
                                                </td>
                                                <td text-align="center">
                                                    <t t-esc="o['remaining']" t-options='{"widget": "monetary", "display_currency": o["currency"]}'/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                        </div>
                    </div>
                    <div style="height:20px;"/>
                    <table border="0" style="width:100%;">
                        <tbody>
                            <t t-foreach="total" t-as="o">
                                <tr class="text-center">
                                    <th text-align="center">
                                        <span>Due Total in <t t-esc="o.name"/>(<t t-esc="o.symbol"/>) : </span>
                                    </th>
                                    <td text-align="center">
                                        <t t-esc="total[o]" t-options='{"widget": "monetary", "display_currency": o }'/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
