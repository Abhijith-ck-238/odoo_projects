                         <table class="table table-borderless o_main_table"
                               style="border-collapse: collapse; width: 100%; font-size:18px;border: none;">
                            <thead>
                                 <tr>
                                    <td colspan="6" style="border-top: 1px solid #ccc; padding: 0; height: 1px;"></td>
                                </tr>
                                <tr>
                                    <th class="text-left"
                                        style="padding: 6px;font-weight: bold;">
                                        Description
                                    </th>
                                    <th class="text-right"
                                        style="padding: 6px;font-weight: bold;">
                                        Quantity
                                    </th>
                                    <th class="text-right"
                                        style="padding: 6px;font-weight: bold;">
                                        Unit Price
                                    </th>
                                    <th t-if="display_discount"
                                        class="text-right" style="padding: 6px;"
                                        groups="product.group_discount_per_so_line">
                                        Disc.%
                                    </th>
                                    <th class="text-right"
                                        style="padding: 6px;font-weight: bold;">
                                        Taxes
                                    </th>
                                    <th class="text-right"
                                        style="padding: 6px;">
                                        <!--                                             <t groups="account.group_show_line_subtotals_tax_excluded">Amount</t> -->
                                        <strong><t>Amount</t></strong>
                                        <t groups="account.group_show_line_subtotals_tax_included">
                                            Total Price
                                        </t>
                                    </th>
                                </tr>
                                 <tr>
                                    <td colspan="6" style="border-bottom: 1px solid #ccc; padding: 0; height: 1px;"></td>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.order_line" t-as="line"
                                   t-index="line_index">
                                    <tr t-att-class="'o_line_section' if line.display_type == 'line_section' else 'o_line_note' if line.display_type == 'line_note' else ''"
                                        style="border-top: 1px solid #d3d3d3;">
                                        <t t-if="not line.display_type">
                                            <td style="padding: 6px;">
                                                <span t-field="line.name"/>
                                            </td>
                                            <td class="text-right"
                                                style="padding: 6px;white-space: nowrap;">
                                                <span t-field="line.product_uom_qty"/>
                                                <span t-field="line.product_uom"
                                                      groups="uom.group_uom"/>
                                            </td>
                                            <td class="text-right"
                                                style="padding: 6px;">
                                                <span t-field="line.price_unit"/>
                                            </td>
                                            <td t-if="display_discount"
                                                class="text-right"
                                                style="padding: 6px;"
                                                groups="product.group_discount_per_so_line">
                                                <span t-field="line.discount"/>
                                            </td>
                                            <td class="text-right"
                                                style="padding: 6px;">
                                                <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                            </td>
                                            <td class="text-right"
                                                style="padding: 6px;">
                                                <!--                                                 <span t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/> -->
                                                <span t-field="line.price_subtotal"/>
                                                <span t-field="line.price_total"
                                                      groups="account.group_show_line_subtotals_tax_included"/>
                                            </td>
                                        </t>
                                        <t t-if="line.display_type == 'line_section'">
                                            <td colspan="99"
                                                style="padding: 6px;">
                                                <strong t-field="line.name"/>
                                            </td>
                                        </t>
                                        <t t-if="line.display_type == 'line_note'">
                                            <td colspan="99"
                                                style="padding: 6px;">
                                                <span t-field="line.name"/>
                                            </td>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                                <!--  Subtotal  -->
                        <t t-if="docs and docs[0] == doc">
                             <div class="text-right" style="margin-top:20px; margin-left:100px;">
                            <table class="table table-borderless" style="width:35%; float:right;">
                                <tr class="border-black o_subtotal">
                                    <td style="padding: 6px;"/>
                                    <!--  Description  -->
                                    <td style="padding: 6px;"/>
                                    <!--  Quantity  -->
                                    <td style="padding: 6px;"/>
                                    <!--  Unit Price  -->
                                    <td class="text-right"
                                        style="font-weight:bold; color: grey; padding: 6px; border-top: 1px solid black;">
                                        Subtotal
                                    </td>
                                    <!--  Taxes column (label)  -->
                                    <td class="text-right"
                                        style="font-weight:bold; padding: 6px; border-top: 1px solid black;">
                                        <span t-field="doc.amount_untaxed"
                                              t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                    <!--  Amount column (value)  -->
                                </tr>
                                <!--  Tax Groups for Odoo 18  -->
                                <t t-if="doc.tax_totals and doc.tax_totals.get('subtotals')">
                                    <t t-foreach="doc.tax_totals['subtotals']"
                                       t-as="subtotal">
                                        <t t-foreach="subtotal.get('tax_groups', [])"
                                           t-as="tax_group">
                                            <tr>
                                                <td style="padding: 6px;"/>
                                                <td style="padding: 6px;"/>
                                                <td style="padding: 6px;"/>
                                                <td class="text-right"
                                                    style="color: grey; padding: 6px;">
                                                    <span t-esc="tax_group.get('tax_group_name', '')"/>
                                                </td>
                                                <!--  Taxes column (label)  -->
                                                <td class="text-right o_price_total"
                                                    style="padding: 6px;">
                                                    <span t-esc="tax_group.get('tax_group_amount', 0)"
                                                          t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                                </td>
                                                <!--  Amount column (value)  -->
                                            </tr>
                                        </t>
                                    </t>
                                </t>
                                <!--  Total  -->
                                <tr class="border-black o_total">
                                    <td style="padding: 6px;"/>
                                    <!--  Description  -->
                                    <td style="padding: 6px;"/>
                                    <!--  Quantity  -->
                                    <td style="padding: 6px;"/>
                                    <!--  Unit Price  -->
                                    <td class="text-right"
                                        style="font-weight:bold; color: grey; border-top: 1px solid black; padding: 6px;">
                                        Total
                                    </td>
                                    <!--  Taxes column (label)  -->
                                    <td class="text-right"
                                        style="font-weight:bold; border-top: 1px solid black; padding: 6px;">
                                        <span t-field="doc.amount_total"
                                              t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                    <!--  Amount column (value)  -->
                                </tr>
                            </table>
                             </div>
                        </t>
                        <div t-if="doc.signature" class="mt32 ml64 mr4"
                             name="signature">
                            <div class="offset-8">
                                <strong>Signature</strong>
                            </div>
                            <div class="offset-8">
                                <img t-att-src="image_data_uri(doc.signature)"
                                     style="max-height: 4cm; max-width: 8cm;"/>
                            </div>
                            <div class="offset-8 text-center">
                                <p t-field="doc.signed_by"/>
                            </div>
                        </div>

                        <div class="oe_structure"/>

                        <p t-field="doc.note"/>
                        <p t-if="doc.payment_term_id.note">
                            <span t-field="doc.payment_term_id.note"/>
                        </p>
                        <p id="fiscal_position_remark"
                           t-if="doc.fiscal_position_id and doc.fiscal_position_id.sudo().note">
                            <strong>Fiscal Position Remark:</strong>
                            <span t-field="doc.fiscal_position_id.sudo().note"/>
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>


    <record id="sales_supplier_report" model="ir.actions.report">
    <field name="name">Supplier Sale Order</field>
    <field name="model">sale.order</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">custom_sales.supplier_report_document</field>
    <field name="report_file">custom_sales.supplier_report_document</field>
    <field name="print_report_name">'Supplier Sale Order - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
