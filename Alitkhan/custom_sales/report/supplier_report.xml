<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="supplier_report_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="account_move.invoice_report_custom_external_layout_new">
                    <t t-set="doc"
                       t-value="o.with_context(lang=o.partner_id.lang)"/>
                    <div class="page">
                        <div class="oe_structure"/>
                        <div style="margin-top:8px; margin-bottom:12px;">
                        <strong style="margin-right:5px;">Customer Name:</strong><br/>
                        <span t-field="doc.partner_id.name"/>
                        <!-- Address Block -->
                        <div>
                            Address: <span t-field="doc.partner_id.street"/>
                        </div>
                        <div t-field="doc.partner_id.street2" t-if="doc.partner_id.street2"/>
                        <div>
                            <span t-field="doc.partner_id.city" t-if="doc.partner_id.city"/>
                            <span t-if="doc.partner_id.state_id">,
                                <span t-field="doc.partner_id.state_id.name"/>
                            </span>
                            <span t-if="doc.partner_id.zip">
                                <span t-field="doc.partner_id.zip"/>
                                </span>
                            </div>
                                <div t-field="doc.partner_id.country_id.name" t-if="doc.partner_id.country_id"/>
                                <!-- VAT -->
                                <p class="m-0" t-if="doc.partner_id.vat">
                                    <t t-esc="doc.company_id.country_id.vat_label or 'Tax ID'"/>:
                                    <span t-field="doc.partner_id.vat"/>
                                </p>
                            </div>

<!--                        <div style="margin-top:8px; margin-bottom:12px;">-->
<!--                            <strong>Customer Name:</strong>-->
<!--                            <div class="m-0" t-field="doc.partner_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>-->
<!--                                <div class="m-0" t-field="doc.partner_id.city"/>-->
<!--                            <p class="m-0" t-if="doc.partner_id.vat">-->
<!--                                <t t-esc="doc.company_id.country_id.vat_label or 'Tax ID'"/>:-->
<!--                                <span t-field="doc.partner_id.vat"/>-->
<!--                            </p>-->
<!--                        </div>-->
                        <t t-if="doc.partner_shipping_id == doc.partner_invoice_id
                                 and doc.partner_invoice_id != doc.partner_id
                                 or doc.partner_shipping_id != doc.partner_invoice_id">
                            <t t-set="information_block">
                                <strong t-if="doc.partner_shipping_id == doc.partner_invoice_id">
                                    Invoicing and Shipping Address:
                                </strong>
                                <strong t-if="doc.partner_shipping_id != doc.partner_invoice_id">
                                    Invoicing Address:
                                </strong>
                                <div t-field="doc.partner_invoice_id"
                                     t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                                <t t-if="doc.partner_shipping_id != doc.partner_invoice_id">
                                    <strong>Shipping Address:</strong>
                                    <div t-field="doc.partner_shipping_id"
                                         t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                                </t>
                            </t>
                        </t>

                        <h2 class="mt16">
                            <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                                <span t-if="doc.state not in ['draft','sent']" style="color: #808080;">
                                    Order #
                                </span>
                                <span t-if="doc.state in ['draft','sent']" style="color: #808080;">
                                    Quotation #
                                </span>
                            </t>
                            <t t-if="env.context.get('proforma', False) or is_pro_forma">
                                <span>Pro-Forma Invoice #</span>
                            </t>
                            <span t-field="doc.name"/>
                        </h2>

                        <div class="row mt32 mb32" id="informations">
                            <div t-if="doc.client_order_ref"
                                 class="col-auto mw-100 mb-2 me-4">
                                <strong>Your Reference:</strong>
                                <p class="m-0" t-field="doc.client_order_ref"/>
                            </div>
                            <div t-if="doc.date_order and doc.state not in ['draft','sent']"
                                 class="col-auto mw-100 mb-2 me-4">
                                <strong>Order Date:</strong>
                                <p class="m-0" t-field="doc.date_order" t-options='{"widget": "date"}'/>
                            </div>
                            <div t-if="doc.date_order and doc.state in ['draft','sent']"
                                 class="col-auto mw-100 mb-2 me-4">
                                <strong>Quotation Date:</strong>
                                <p class="m-0" t-field="doc.date_order"
                                   t-options='{"widget": "date"}'/>
                            </div>
                            <div t-if="doc.validity_date and doc.state in ['draft', 'sent']"
                                 class="col-auto mw-100 mb-2 me-4"
                                 name="expiration_date">
                                <strong>Expiration:</strong>
                                <p class="m-0" t-field="doc.validity_date"/>
                            </div>
                            <div t-if="doc.user_id.name"
                                 class="col-auto mw-100 mb-2">
                                <strong>Salesperson:</strong>
                                <p class="m-0" t-field="doc.user_id"/>
                            </div>
                        </div>

                        <t t-set="bank_account_id" t-value="request.env['ir.config_parameter'].sudo().get_param('custom_sales.bnk_account_id')"/>
                        <t t-set="bank_account" t-value="request.env['res.partner.bank'].browse(int(bank_account_id))"/>

                        <table class="table table-sm"
                               style="width:40%; font-size: x-small; float: right; border-collapse: collapse; border: 1px solid #d3d3d3;">
                            <tr class="text-bold">
                                <td style="background: lightgray; border: 1px solid #d3d3d3;">
                                    Bank:
                                </td>
                                <td style="border: 1px solid #d3d3d3;">
                                    <p class="m-0" t-field="bank_account.bank_id.name"/>
                                </td>
                            </tr>
                            <tr class="text-bold">
                                <td style="background: lightgray; border: 1px solid #d3d3d3;">
                                    Bank Address:
                                </td>
                                <td style="border: 1px solid #d3d3d3;">
                                    <t t-if="bank_account.bank_id.street">
                                        <p class="m-0" t-field="bank_account.bank_id.street"/>
                                    </t>
                                    <t t-if="bank_account.bank_id.street2">
                                        <p class="m-0" t-field="bank_account.bank_id.street2"/>
                                    </t>
                                    <t t-if="bank_account.bank_id.city">
                                        <p class="m-0" t-field="bank_account.bank_id.city"/>
                                    </t>
                                    <t t-if="bank_account.bank_id.state">
                                        <p class="m-0" t-field="bank_account.bank_id.state.name"/>
                                    </t>
                                    <t t-if="bank_account.bank_id.zip">
                                        <p class="m-0" t-field="bank_account.bank_id.zip"/>
                                    </t>
                                    <t t-if="bank_account.bank_id.country">
                                        <p class="m-0" t-field="bank_account.bank_id.country.name"/>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td style="background: lightgray; border: 1px solid #d3d3d3;">
                                    IBAN:
                                </td>
                                <td style="border: 1px solid #d3d3d3;">
                                    <p class="m-0" t-field="bank_account.bank_id.bic"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="background: lightgray; border: 1px solid #d3d3d3;">
                                    Account Holder Name:
                                </td>
                                <td style="border: 1px solid #d3d3d3;">
                                    <p class="m-0" t-field="bank_account.acc_holder_name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="background: lightgray; border: 1px solid #d3d3d3;">
                                    Account Number:
                                </td>
                                <td style="border: 1px solid #d3d3d3;">
                                    <p class="m-0" t-field="bank_account.acc_number"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="background: lightgray; border: 1px solid #d3d3d3;">
                                    Swift:
                                </td>
                                <td style="border: 1px solid #d3d3d3;">
                                    <p class="m-0" t-field="bank_account.swift"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="background: lightgray; border: 1px solid #d3d3d3;">
                                    Currency:
                                </td>
                                <td style="border: 1px solid #d3d3d3;">
                                    <p class="m-0" t-field="bank_account.currency_id.name"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Is there a discount on at least one line? -->
                        <t t-set="display_discount"
                           t-value="any([l.discount for l in doc.order_line])"/>
