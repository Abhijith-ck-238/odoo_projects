<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_set_invoice_payment_state" model="ir.cron">
            <field name="name">Set invoice payment state</field>
            <field name="model_id" ref="model_sale_order"/>
            <field name="state">code</field>
            <field name="code">model.set_invoice_payment_state()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>

        <record id="ir_cron_send_invoice_overdue_mail" model="ir.cron">
            <field name="name">Send Invoice Overdue Mails</field>
            <field name="model_id" ref="model_sale_order"/>
            <field name="state">code</field>
            <field name="code">model.action_send_invoice_overdue_mails()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
