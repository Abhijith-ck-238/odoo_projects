<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="mail_template_overdue_sales" model="mail.template">
            <field name="name">Overdue Sales</field>
            <field name="model_id" ref="base.model_ir_cron"/>
            <field name="subject">Overdue Sales Report - {{ctx.get('team', '')}}</field>
            <field name="email_from">{{user.email_formatted}}</field>
            <field name="email_to">{{ctx.get('email_to', '')}}</field>
            <field name="email_cc">{{ctx.get('email_cc', '')}}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>Dear All,</p>
                    <p>Please find the attachment for overdue sales.</p>
                </div>
            </field>
            <field name="lang">en_US</field>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>
