        <record id="hr_holidays.hr_leave_rule_employee" model="ir.rule">
            <field name="name">Time Off - Internal Users</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]
            </field>
            <field name="perm_create" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4,ref('base.group_user'))]"/>
        </record>

        <record id="hr_leave_allocation_rule_officer" model="ir.rule">
            <field name="name">Approver : See all Time off to approve</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">
                 ['|','|','|','|','|','|','|','|','|','|',
                ('employee_id.timeoff_deputy.user_id','=',
                user.id),('employee_id.leave_manager_id', '=',user.id),
                ('employee_id.parent_id.user_id', '=', user.id),
                ('employee_id.direct_manager_id','=',user.id),
                ('employee_id.second_direct_manager_id','=',user.id),
                ('employee_id.director_id','=',user.id),
                ('employee_id.leave_manager_id.employee_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.parent_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.direct_manager_id.employee_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.second_direct_manager_id.employee_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.director_id.employee_id.timeoff_deputy.user_id','=',user.id)
                ]
            </field>
            <field name="perm_create" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4,ref('custom_timeoff.group_hr_officer'))]"/>
        </record>

        <record id="hr_leave_allocation_rule_officer_report" model="ir.rule">
            <field name="name">Approver : See all Time off to approve</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_report_calendar"/>
            <field name="domain_force">
                 ['|','|','|','|','|','|','|','|','|','|',
                ('employee_id.timeoff_deputy.user_id','=',
                user.id),('employee_id.leave_manager_id', '=',user.id),
                ('employee_id.parent_id.user_id', '=', user.id),
                ('employee_id.direct_manager_id','=',user.id),
                ('employee_id.second_direct_manager_id','=',user.id),
                ('employee_id.director_id','=',user.id),
                ('employee_id.leave_manager_id.employee_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.parent_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.direct_manager_id.employee_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.second_direct_manager_id.employee_id.timeoff_deputy.user_id','=',user.id),
                ('employee_id.director_id.employee_id.timeoff_deputy.user_id','=',user.id)
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4,ref('custom_timeoff.group_hr_officer'))]"/>
        </record>


        <record id="hr_leave_allocation_rule_manager_read" model="ir.rule">
            <field name="name">Allocations: see all time off: read all</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
            <field name="domain_force">[('employee_id.parent_id.user_id', '=',
                user.id)]
            </field>
            <field name="perm_create" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups"
                   eval="[(4, ref('custom_timeoff.group_hr_holidays_time_off_manager'))]"/>
        </record>

        <record id="hr_holidays.hr_leave_allocation_rule_officer_update"
                model="ir.rule">
            <field name="name">Allocations: see all time off:
                create/write/unlink own + managed employee + without department
                + same or managed department
            </field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
            <field name="domain_force">['|',
                '|', ('employee_id.user_id', '=', user.id),
                ('employee_id.parent_id.user_id', '=', user.id),
                '|', '|', ('department_id', '=', False),
                ('department_id.member_ids.user_id', 'in', [user.id]),
                ('department_id.manager_id.user_id', '=', user.id)]
            </field>
            <field name="groups"
                   eval="[(4,ref('hr_holidays.group_hr_holidays_user')),(4, ref('custom_timeoff.group_hr_holidays_time_off_manager'))]"/>
        </record>


        <record id="hr_holidays.hr_leave_rule_officer_update" model="ir.rule">
            <field name="name">Time Off All Approver create/write</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[
                ('holiday_type', '=', 'employee'),
                '|',
                '&amp;',
                ('employee_id.user_id', '=', user.id),
                ('state', '!=', 'validate'),
                '|',
                ('employee_id.user_id', '!=', user.id),
                ('employee_id.user_id', '=', False)
                ]
            </field>
            <field name="perm_read" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups"
                   eval="[(4, ref('hr_holidays.group_hr_holidays_user')),(4, ref('custom_timeoff.group_hr_holidays_time_off_manager'))]"/>
        </record>

        <record id="hr_leave_support_center" model="ir.rule">
            <field name="name">Time Off Support Center</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[ '|',
                ('employee_id.user_id', '=', user.id),
                ('employee_id.new_divisions.id', '=', user.emp_id.new_divisions.id)]
            </field>
<!--            <field name="perm_write" eval="False"/>-->
<!--            <field name="perm_create" eval="False"/>-->
<!--            <field name="perm_unlink" eval="False"/>-->

            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups"
                   eval="[(4, ref('custom_timeoff.group_hr_holidays_time_off_support_center'))]"/>
        </record>

        <record id="hr_leave_report_support_center" model="ir.rule">
            <field name="name">Hr Leave Report - Time Off Support Center</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_report_calendar"/>
            <field name="domain_force">[ '|',
                ('employee_id.user_id', '=', user.id),
                ('employee_id.new_divisions.id', '=', user.emp_id.new_divisions.id)]
            </field>
            <field name="perm_read" eval="True"/>
<!--            <field name="perm_write" eval="False"/>-->
<!--            <field name="perm_create" eval="False"/>-->
<!--            <field name="perm_unlink" eval="False"/>-->
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>

            <field name="groups"
                   eval="[(4, ref('custom_timeoff.group_hr_holidays_time_off_support_center'))]"/>
        </record>


    </data>
</odoo>
