<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="group_hr_officer" model="res.groups">
            <field name="name">Officer</field>
            <field name="category_id" ref="base.module_category_human_resources_time_off"/>
        </record>

        <record id="group_hr_holidays_time_off_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id"
                   ref="base.module_category_human_resources_time_off"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_hr_holidays_time_off_support_center" model="res.groups">
            <field name="name">Support center</field>
            <field name="category_id"
                   ref="base.module_category_human_resources_time_off"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
