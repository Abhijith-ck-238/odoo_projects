<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="hr_leave_type_extend" model="ir.ui.view">
            <field name="name">hr.leave.type.extend.form</field>
            <field name="model">hr.leave.type</field>
            <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='request_unit']" position="after">
                    <field name="notify_department_manager_after"/>
                </xpath>
            </field>
        </record>

        <record id="leave_approver.edit_holiday_status_form_inherit" model="ir.ui.view">
            <field name="name">hr.leave.type.form</field>
            <field name="model">hr.leave.type</field>
            <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='responsible_ids']" position="replace">
                    <field name="responsible_ids"
                           invisible="[( 'leave_validation_type', 'in', ['no_validation', 'manager', 'direct_director', 'direct_manager', 'time_off_responsible'])]"
                           required="[( 'leave_validation_type', 'in', ['hr', 'both'])]"
                    />
                </xpath>
            </field>
        </record>
    </data>
</odoo>
