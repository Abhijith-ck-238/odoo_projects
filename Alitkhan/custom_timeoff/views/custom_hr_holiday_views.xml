<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="hr_leave_tree_view_extend" model="ir.ui.view">
            <field name="name">hr leave tree extend</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_approve']" position="replace">
                    <button string="Approve" name="action_approve" type="object"
                            icon="fa-check text-success"
                            invisible="state != 'confirm'"
                            groups="hr_holidays.group_hr_holidays_responsible,custom_timeoff.group_hr_officer"/>
                </xpath>
                <xpath expr="//button[@name='action_validate']" position="replace">
                    <button string="Validate" name="action_validate" type="object"
                            icon="fa-check text-success"
                            invisible="state != 'validate1'"
                            groups="hr_holidays.group_hr_holidays_manager,custom_timeoff.group_hr_officer"/>
                </xpath>
            </field>
        </record>

        <record id="hr_leave_view_form_inherit_approval_extend" model="ir.ui.view">
            <field name="name">hr leave approver form extend</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="leave_approver.hr_leave_view_form_inherit_approval"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='action_refuse']" position="replace">
                    <button string="Refuse" name="action_refuse" type="object"
                            invisible="can_approve == False or state not in ['confirm','validate','validate1', 'direct_manager', '2direct_manager', 'manager', 'director', 'hr','time_off_officer','time_off_responsible']"/>
                </xpath>
            </field>
        </record>


        <menuitem
                id="hr_holidays.menu_hr_holidays_approvals"
                name="Managers"
                parent="hr_holidays.menu_hr_holidays_root"
                sequence="2"
        />
        <menuitem
                id="hr_holidays.hr_holidays_menu_manager_approve"
                name="To Approve"
                parent="hr_holidays.menu_hr_holidays_approvals"
                groups="hr_holidays.group_hr_holidays_user,custom_timeoff.group_hr_officer"
        />
        <menuitem
                id="hr_holidays.menu_open_department_leave_approve"
                name="Time Off"
                parent="hr_holidays.hr_holidays_menu_manager_approve"
                action="hr_holidays.hr_leave_action_action_approve_department"
        />
        <menuitem
                id="hr_holidays.hr_holidays_menu_manager_all"
                name="All"
                parent="hr_holidays.menu_hr_holidays_approvals"
                groups="hr_holidays.group_hr_holidays_manager,hr_holidays.group_hr_holidays_user,custom_timeoff.group_hr_officer"
                sequence="2"/>

        <menuitem
                id="hr_holidays.menu_open_employee_leave"
                name="Time Off"
                parent="hr_holidays.hr_holidays_menu_manager_all"
                groups="hr_holidays.group_hr_holidays_manager,hr_holidays.group_hr_holidays_user,custom_timeoff.group_hr_officer"
                action="hr_holidays.hr_leave_action_holiday_allocation_id"
                sequence="1"/>

         <menuitem
                id="hr_holidays_menu_manager_approve_allocations"
                name="Allocations"
                parent="hr_holidays.hr_holidays_menu_manager_all"
                action="hr_holidays.hr_leave_allocation_action_approve_department"
                sequence="15"/>



        <menuitem
                id="hr_holidays.menu_hr_holidays_dashboard"
                name="Everyone"
                parent="hr_holidays.menu_hr_holidays_root"
                groups="hr_holidays.group_hr_holidays_manager,hr_holidays.group_hr_holidays_user,custom_timeoff.group_hr_officer,custom_timeoff.group_hr_holidays_time_off_support_center"
                sequence="2"
                action="hr_holidays.action_hr_holidays_dashboard"/>

        <menuitem
                id="hr_holidays.menu_hr_holidays_configuration"
                name="Configuration"
                parent="hr_holidays.menu_hr_holidays_root"
                groups="hr_holidays.group_hr_holidays_manager,hr_holidays.group_hr_holidays_user,custom_timeoff.group_hr_officer"
                sequence="5"/>




         <menuitem
        id="hr_holidays.menu_hr_holidays_management"
         active="False"/>



    <menuitem
        id="hr_holidays.hr_holidays_menu_manager_approve_allocations"
        active="False"/>


    </data>
</odoo>

