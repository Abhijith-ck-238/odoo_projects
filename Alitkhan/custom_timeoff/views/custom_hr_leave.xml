        <menuitem
                id="hr_holidays.menu_hr_holidays_report"
                name="Reporting"
                parent="hr_holidays.menu_hr_holidays_root"
                groups="hr_holidays.group_hr_holidays_manager,custom_timeoff.group_hr_holidays_time_off_support_center"
                sequence="4"/>
    </data>
