<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="group_team_approver" model="res.groups">
            <field name="name">New Team Approver</field>
            <field name="implied_ids" eval="[(4, ref('hr_expense.group_hr_expense_team_approver'))]"/>
            <field name="category_id" ref="base.module_category_human_resources_expenses"/>
        </record>

        <record id="ir_rule_hr_expense_sheet_not_approver" model="ir.rule">
            <field name="name">Expense Sheet</field>
            <field name="model_id" ref="hr_expense.model_hr_expense_sheet"/>
<!--            <field name="domain_force">[ '|', '|', '|',('user_ids', 'in', user.id), ('user_id', '=', user.id),-->
<!--                ('employee_id.user_id', '=', user.id),('budget_reponsibles','in',user.id) ]-->
<!--            </field>-->
             <field name="domain_force">[ '|', '|', ('user_id', '=', user.id),
                ('employee_id.user_id', '=', user.id),('budget_reponsibles','in',user.id) ]
            </field>
            <field name="groups"
                   eval="[(4, ref('custom_hr_expense_advance_clearng.group_team_approver'))]"/>
        </record>

        <record id="ir_rule_hr_expense_sheet" model="ir.rule">
            <field name="name">Expense</field>
            <field name="model_id" ref="hr_expense.model_hr_expense"/>
            <field name="domain_force">['|','|','|', ('employee_id.user_id', '=', user.id),
                ('sheet_id.budget_reponsibles','in',user.id)
                ,('sheet_id.user_id','=',user.id),('sheet_id.employee_id.user_id','=',user.id) ]
            </field>
            <field name="groups"
                   eval="[(4, ref('custom_hr_expense_advance_clearng.group_team_approver'))]"/>
        </record>
    </data>
</odoo>
