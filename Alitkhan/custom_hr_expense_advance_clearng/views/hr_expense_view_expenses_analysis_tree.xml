<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hr_expense_view_expenses_analysis_tree_inherit" model="ir.ui.view">
    <field name="name">hr.expense.list.inherit</field>
    <field name="model">hr.expense</field>
    <field name="inherit_id" ref="hr_expense.hr_expense_view_expenses_analysis_tree"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='total_amount']" position="attributes">
            <attribute name="options">{'currency_field': 'currency_id'}</attribute>
        </xpath>
         <xpath expr="//field[@name='total_amount_currency']" position="attributes">
            <attribute name="options">{'currency_field': 'company_currency_id'}</attribute>
        </xpath>
    </field>
</record>
</odoo>
