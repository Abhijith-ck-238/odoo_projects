<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
<record id="view_stock_valuation_layer_list_custom" model="ir.ui.view">
            <field name="name">stock.valuation.layer.list.custom</field>
            <field name="model">stock.valuation.layer</field>
            <field name="inherit_id"
                   ref="stock_account.stock_valuation_layer_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="js_class">custom_valuation_list</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
