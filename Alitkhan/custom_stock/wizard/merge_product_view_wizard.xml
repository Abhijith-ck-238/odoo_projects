<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="merge_product_view_extend" model="ir.ui.view">
            <field name="name">merge.product.view</field>
            <field name="model">merge.product.wizard</field>
            <field name="inherit_id" ref="deltatech_product_do_merge.merge_product_wizard_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='object_ids']" position="replace">
                    <field name="object_ids" nolabel="1"
                           context="{'tree_view_ref': 'custom_stock.product_product_tree_view_extend'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
