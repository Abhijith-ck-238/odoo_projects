<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="account_move_view_inherit_move" model="ir.ui.view">
        <field name="name">account.move.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_post']" position="after">
                <button name="action_link_purchase_order"
                        string="LINK PURCHASE ORDER"
                        class="oe_highlight" type="object"
                        invisible="state in 'cancel' or 'type' in 'out_invoice'"/>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="ref" string="Reference"/>
            </xpath>
        </field>
    </record>
    <record id="view_invoice_tree_inherit" model="ir.ui.view">
        <field name="name">account.invoice.list.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_residual_signed']" position="attributes">
                <attribute name="optional"/>
            </xpath>
            <xpath expr="//field[@name='amount_residual_signed']" position="after">
                <field name="amount_residual" string="Amount Due in currency"/>
                <field name="company_currency_id" column_invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='ref']" position="after">
                <field name="partner_id" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>