    <template id="sale_stock_report_invoice_document_proforma"
              inherit_id="account_move.report_invoice_document_proforma">
        <xpath expr="//div[@class='row'][last()]" position="after">
            <t t-set="lot_values" t-value="o._get_invoiced_lot_values()"/>
            <t t-if="lot_values">
                <div class="mt-4">
                    <h5>Serial/Lot Numbers</h5>
                    <table groups="sale_stock.group_lot_on_invoice"
                           class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-center">SN/LN</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="lot_values" t-as="snln_line">
                                <tr>
                                    <td>
                                        <span t-esc="snln_line['product_name']"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-esc="snln_line['quantity']"/>
                                        <span t-esc="snln_line['uom_name']"
                                              groups="uom.group_uom"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-esc="snln_line['lot_name']"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </xpath>
    </template>

    <!-- Report action record -->
    <record id="invoice_report_proforma" model="ir.actions.report">
        <field name="name">Supplier PRO-FORMA Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_move.report_invoice_document_proforma</field>
        <field name="report_file">account_move.report_invoice_document_proforma</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
