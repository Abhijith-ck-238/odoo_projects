<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="module_category_product_reservation" model="ir.module.category">
            <field name="name">Product Reservation</field>
            <field name="description">Helps you to manage the Product Reservation</field>
        </record>

        <record id="group_product_reservation_user" model="res.groups">
            <field name="name">Product Reservation User</field>
            <field name="category_id" ref="module_category_product_reservation"/>
        </record>

        <record id="group_product_reservation_administrator" model="res.groups">
            <field name="name">Product Reservation Administrator</field>
            <field name="category_id" ref="module_category_product_reservation"/>
            <field name="implied_ids" eval="[(4, ref('custom_product_reservation.group_product_reservation_user'))]"/>
        </record>
    </data>
</odoo>
