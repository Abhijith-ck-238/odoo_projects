<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="lower_ks_ticket_view_tree" model="ir.ui.view">
        <field name="name">lower.ks.ticket.list</field>
        <field name="model">lower.ks.ticket</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="partner_id"/>
                <field name="ticket_type_id"/>
            </list>
        </field>
    </record>

    <record id="lower_ks_ticket_view_form" model="ir.ui.view">
        <field name="name">lower.ks.ticket.form</field>
        <field name="model">lower.ks.ticket</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <header>
                    <field name="stage_id" widget="statusbar"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active != 'True'"/>
                    <div class="oe_title">
                        <label for="name">Task Description</label>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="user_ids" widget="many2many_tags"/>
                            <field name="ticket_type_id"/>
                            <label for="start_date" string="Task Range" invisible="action_done"/>
                            <div class="w-100" invisible="action_done">
                                <div class="o_row">
                                    <field name="start_date" widget="daterange"
                                           options="{&quot;related_end_date&quot;: &quot;end_date&quot;}"/>
                                    <i class="fa fa-long-arrow-right mx-2"
                                       aria-label="Arrow icon" title="Arrow"/>
                                    <field name="end_date" widget="daterange"
                                           options="{&quot;related_start_date&quot;: &quot;start_date&quot;}"/>
                                </div>
                            </div>
                            <label for="start_ddate" string="Task Range" invisible="not action_done"/>
                            <div class="w-100" invisible="not action_done">
                                <div class="o_row">
                                    <field name="start_ddate" widget="daterange"
                                           options="{&quot;related_end_date&quot;: &quot;end_date&quot;}"/>
                                    <i class="fa fa-long-arrow-right mx-2"
                                       aria-label="Arrow icon" title="Arrow"/>
                                    <field name="end_ddate" widget="daterange"
                                           options="{&quot;related_start_date&quot;: &quot;start_date&quot;}"/>
                                </div>
                            </div>
                            <field name="work_sector_id"/>
                            <field name="source_id"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="work_done"/>
                            <field name="attachment_ids"
                                   widget="many2many_binary"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="account_id"/>
                            <field name="province_id"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Add a note..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="lower_ks_ticket_view_kanban" model="ir.ui.view">
        <field name="name">lower.ks.ticket.kanban</field>
        <field name="model">lower.ks.ticket</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                    class="o_kanban_small_column o_kanban_training_ticket"
                    quick_create="false" default_order="priority desc">
                <field name="name"/>
                <field name="ticket_type_id"/>
                <field name="priority"/>
                <field name="color"/>
                <field name="active"/>
                <field name="message_needaction_counter"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <progressbar field="activity_state"
                             colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>

                <templates>
                    <t t-name="menu">
                        <t t-if="widget.editable">
                            <a role="menuitem" type="open"
                               class="dropdown-item">Edit
                            </a>
                        </t>
                        <t t-if="widget.deletable">
                            <a role="menuitem" type="delete"
                               class="dropdown-item">Delete
                            </a>
                        </t>
                        <a role="menuitem" type="object" name="toggle_active"
                           class="dropdown-item">
                            <t t-if="record.active.raw_value">Archive</t>
                            <t t-else="">Restore</t>
                        </a>
                        <field name="color" widget="kanban_color_picker"/>
                    </t>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div>
                                <strong>
                                    <field name="name"/>
                                    (#<field name="id"/>)
                                </strong>
                            </div>

                            <div>
                                <field name="ticket_type_id"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_right">
                                    <t t-if="record.message_needaction_counter.raw_value">
                                        <span class='oe_kanban_mail_new'
                                              title='Important Messages'>
                                            <i class='fa fa-comments'
                                               role="img"
                                               aria-label="Messages"/>
                                            <t t-esc="record.message_needaction_counter.raw_value"/>
                                        </span>
                                    </t>
                                    <div>
                                        <field name="priority"
                                               widget="priority"/>
                                        <field name="activity_ids"
                                               widget="kanban_activity"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="oe_clear"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="lower_ks_ticket_view_search" model="ir.ui.view">
        <field name="name">lower.ks.ticket.search</field>
        <field name="model">lower.ks.ticket</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="lower_ks_view_form_inherit" model="ir.ui.view">
        <field name="name">lower.ks.view.form.inherit</field>
        <field name="model">lower.ks.ticket</field>
        <field name="inherit_id"
               ref="custom_lower_ks.lower_ks_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_sector_id']" position="after">
                <field name="speciality_id" widget="many2many_tags"
                       options="{'color_field': 'color'}"/>
            </xpath>
            <xpath expr="//field[@name='province_id']" position="after">
                <field name="priority" widget="priority"/>
            </xpath>
        </field>
    </record>

    <record id="action_lower_ka_ticket" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">lower.ks.ticket</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_lower_ks_tickets" name="Tickets"
              action="action_lower_ka_ticket" parent="lower_ks_menu_root"
              sequence="0"/>
</odoo>
