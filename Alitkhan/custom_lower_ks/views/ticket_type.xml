<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="lower_ks_ticket_type_view_tree" model="ir.ui.view">
        <field name="name">lower.ks.ticket.type.list</field>
        <field name="model">lower.ks.ticket.type</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="lower_ks_ticket_type_view_form" model="ir.ui.view">
        <field name="name">lower.ks.ticket.type.form</field>
        <field name="model">lower.ks.ticket.type</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lower_ks_ticket_type_view_search" model="ir.ui.view">
        <field name="name">lower.ks.ticket.type.search</field>
        <field name="model">lower.ks.ticket.type</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_lower_ks_ticket_type" model="ir.actions.act_window">
        <field name="name">Ticket Type</field>
        <field name="res_model">lower.ks.ticket.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lower_ks_ticket_type" name="Ticket Type" action="action_lower_ks_ticket_type" parent="lower_ks_configuration" sequence="5"/>
</odoo>