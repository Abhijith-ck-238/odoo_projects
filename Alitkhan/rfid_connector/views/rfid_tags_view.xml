<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="rfid_tags_tree" model="ir.ui.view">
            <field name="model">rfid.tag.epc</field>
            <field name="arch" type="xml">
                <list string="RFID Tags">
                    <field name="sequence"/>
                    <field name="epc_id"/>
                    <field name="product_id"/>
                    <field name="reference"/>
                    <field name="lot_id" invisible="1"/>
                    <field name="lot"/>
                    <field name="picking_id"/>
                </list>
            </field>
        </record>

        <record id="rfid_tags_view_search" model="ir.ui.view">
            <field name="name">rfid.tags</field>
            <field name="model">rfid.tag.epc</field>
            <field name="priority">32</field>
            <field name="arch" type="xml">
                <search string="Product Reservations">
                    <field name="epc_id"/>
                    <field name="product_id"/>
                    <field name="lot_id"/>
                </search>
            </field>
        </record>

        <record id="action_rfid_tags" model="ir.actions.act_window">
            <field name="name">RFID Tags</field>
            <field name="res_model">rfid.tag.epc</field>
            <field name="view_mode">list</field>
            <field name="search_view_id" ref="rfid_connector.rfid_tags_view_search"/>
             <field name="help">RFID Tags</field>
        </record>

        <menuitem
            id="menu_rfid_tags"
            name="RFID Tags"
            sequence="100"
            parent="stock.menu_stock_inventory_control"
            action="action_rfid_tags"/>

    </data>
</odoo>