<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="stock_production_lot_form_view_inherit" model="ir.ui.view">
        <field name="name">stock.production.lot.form.view.inherit</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id"
               ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="js_class">rfid_lot_tag_print</attribute>
            </xpath>
            <xpath expr="//sheet"
                   position="before">
                <header>
                    <div class="btn btn-secondary print_lot_data">Print RFID Tag</div>
                </header>
            </xpath>
        </field>
    </record>
</odoo>