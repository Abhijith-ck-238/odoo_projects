                                        </td>
                                        <td style="border: 1px solid black; border-top: none; padding: 2px; text-align: center; vertical-align: top;height: 60px;">
                                            <p style="font-family: 'Arial';font-size: 13px; font-weight: bold; line-height: 1.1;"
                                               t-field="o.template_id.sign_of_agent"/>
