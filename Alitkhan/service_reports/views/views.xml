<odoo>
  <data>

    <!-- actions opening views on models -->

    <record model="ir.actions.act_window" id="service_reports.service_reports_action_window">
      <field name="name">Service Reports Window</field>
      <field name="res_model">service.report</field>
      <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.act_window" id="service_reports.company_template_action_window">
      <field name="name">Company Template Window</field>
      <field name="res_model">service.report.company</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- Top menu item -->

    <menuitem name="Service Reports" id="service_reports.menu_root" groups="service_reports.service_report_manager"/>


    <!-- actions -->
    
    <menuitem name="Service Reports" id="service_reports.menu_main" parent="service_reports.menu_root"
              action="service_reports.service_reports_action_window" />


    <menuitem name="Company Template" id="service_reports.company_template" parent="service_reports.menu_root"
      action="service_reports.company_template_action_window"/>
  </data>
</odoo>