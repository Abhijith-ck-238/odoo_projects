<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
        <record id="module_category_itkan_project" model="ir.module.category">
            <field name="name">Itkan Project</field>
            <field name="description">Helps you to manage the Itkan Project</field>
        </record>

        <record id="group_itkan_project_user" model="res.groups">
            <field name="name">Itkan Project User</field>
            <field name="category_id" ref="module_category_itkan_project"/>
        </record>

        <record id="group_itkan_project_edit_deadline_user" model="res.groups">
            <field name="name">Edit Deadline User</field>
            <field name="category_id" ref="module_category_itkan_project"/>
        </record>

        <record id="group_itkan_project_administrator" model="res.groups">
            <field name="name">Itkan Project Administrator</field>
            <field name="category_id" ref="module_category_itkan_project"/>
        </record>

        <record model="ir.rule" id="project_subtask_user_rule">
            <field name="name">project.subtask.user.rule</field>
            <field name="model_id" ref="model_project_subtask"/>
            <field name="domain_force">['|', ('user_ids','in', user.id), ('user_ids','=',False)]</field>
            <field name="groups" eval="[(4, ref('custom_itkan_project.group_itkan_project_user'))]"/>
        </record>

        <record model="ir.rule" id="itkan_project_user_rule">
            <field name="name">itkan.project.user.rule</field>
            <field name="model_id" ref="model_itkan_project"/>
            <field name="domain_force">['|','|', ('project_committee_users','in', user.id), ('project_manager','=',user.id), ('sales_project_manager','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_itkan_project_user'))]"/>
        </record>

         <record model="ir.rule" id="project_checklist_line_user_rule_managers">
            <field name="name">project.checklist.line.user.rule.mangers</field>
            <field name="model_id" ref="model_project_checklist_line"/>
            <field name="domain_force">['|',('project_id.project_manager','=',user.id), ('project_id.sales_project_manager','=',user.id),('project_id.hide_checklist', '=', False)]</field>
            <field name="groups" eval="[(4, ref('group_itkan_project_user'))]"/>
             <field name="perm_read" eval="1"/>
             <field name="perm_write" eval="0"/>
             <field name="perm_create" eval="0"/>
             <field name="perm_unlink" eval="0"/>
        </record>
        <record model="ir.rule" id="project_checklist_line_user_rule_committee">
            <field name="name">project.checklist.line.user.rule.committee</field>
            <field name="model_id" ref="model_project_checklist_line"/>
            <field name="domain_force">[('project_id.project_committee_users','=', user.id),('project_id.show_checklist', '=', True),('project_id.project_manager','!=',user.id), ('project_id.sales_project_manager','!=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_itkan_project_user'))]"/>
             <field name="perm_read" eval="1"/>
             <field name="perm_write" eval="0"/>
             <field name="perm_create" eval="0"/>
             <field name="perm_unlink" eval="0"/>
        </record>

        <record model="ir.rule" id="project_checklist_line_user_rule">
            <field name="name">project.checklist.line.user.rule</field>
            <field name="model_id" ref="model_project_checklist_line"/>
            <field name="domain_force">[('members','in', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_itkan_project_user'))]"/>
            <field name="perm_read" eval="1"/>
             <field name="perm_write" eval="1"/>
             <field name="perm_create" eval="0"/>
             <field name="perm_unlink" eval="0"/>
        </record>
</odoo>