<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="project_department_view_tree" model="ir.ui.view">
        <field name="name">project.department.list</field>
        <field name="model">project.department</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="team_members" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="project_department_view_form" model="ir.ui.view">
        <field name="name">project.department.form</field>
        <field name="model">project.department</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="team_members" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="project_department_view_search" model="ir.ui.view">
        <field name="name">project.department.search</field>
        <field name="model">project.department</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_project_department" model="ir.actions.act_window">
        <field name="name">Project Department</field>
        <field name="res_model">project.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_department" name="Project Department" action="action_project_department" parent="menu_itkan_project_configuration" sequence="5"/>
</odoo>