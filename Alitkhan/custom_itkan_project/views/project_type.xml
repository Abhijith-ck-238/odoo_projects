<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="project_type_view_tree" model="ir.ui.view">
        <field name="name">project.type.list</field>
        <field name="model">project.type</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="project_type_view_form" model="ir.ui.view">
        <field name="name">project.type.form</field>
        <field name="model">project.type</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                    <field name="checklist_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="is_subtask"/>
                            <field name="days_for_project"/>
                            <field name="days_to_notify_before_deadline"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="project_type_view_search" model="ir.ui.view">
        <field name="name">project.type.search</field>
        <field name="model">project.type</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_project_type" model="ir.actions.act_window">
        <field name="name">Project Type</field>
        <field name="res_model">project.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_type" name="Project Type" action="action_project_type" parent="menu_itkan_project_configuration" sequence="5"/>
</odoo>