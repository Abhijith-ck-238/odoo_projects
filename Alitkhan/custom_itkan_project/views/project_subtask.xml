<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="project_subtask_view_tree" model="ir.ui.view">
        <field name="name">project.subtask.list</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="is_checked"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="state"/>
                <field name="project_id"/>
            </list>
        </field>
    </record>

    <record id="project_subtask_view_form" model="ir.ui.view">
        <field name="name">project.subtask.form</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="is_checked"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="project_subtask_view_search" model="ir.ui.view">
        <field name="name">project.subtask.search</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
                <group expand="1" string="Group By">
                    <filter string="Project" name="Project" context="{'group_by':'project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_project_subtask" model="ir.actions.act_window">
        <field name="name">Subtask</field>
        <field name="res_model">project.subtask</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_subtask" name="Subtask" action="action_project_subtask" parent="menu_itkan_project" sequence="5"/>
</odoo>