    <record id="view_itkan_project_report_search" model="ir.ui.view">
        <field name="name">itkan.project.report.search</field>
        <field name="model">itkan.project.report</field>
        <field name="arch" type="xml">
            <search string="Itkan Project Analysis">
                <group expand="1" string="Group By">
                    <filter string="Project" name="Project" context="{'group_by':'project_id'}"/>
                     <filter string="Department" name="Department" context="{'group_by':'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_itkan_project_report" model="ir.actions.act_window">
        <field name="name">Itkan Project Analysis</field>
        <field name="res_model">itkan.project.report</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_itkan_project_report_search"/>
        <field name="help">This report performs analysis on your Itkan Projects.</field>
    </record>

    <menuitem
            id="menu_itkan_reporting"
            name="Reporting"
            parent="custom_itkan_project.itkan_project_menu_root"
            sequence="50" groups="group_itkan_project_administrator"/>
        <menuitem
            id="menu_itkan_projectn_report"
            name="Itkan Project"
            parent="menu_itkan_reporting"
            action="custom_itkan_project.action_itkan_project_report"
            sequence="10"/>

</odoo>