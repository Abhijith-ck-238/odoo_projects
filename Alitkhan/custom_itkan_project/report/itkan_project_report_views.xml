<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_itkan_project_report_tree" model="ir.ui.view">
         <field name="name">itkan.project.report.tree</field>
         <field name="model">itkan.project.report</field>
         <field name="arch" type="xml">
             <list string="Itkan Project Analysis">
                    <field name="project_id"/>
             </list>
         </field>
    </record>

    <record id="view_itkan_project_report_pivot" model="ir.ui.view">
         <field name="name">itkan.project.report.pivot</field>
         <field name="model">itkan.project.report</field>
         <field name="arch" type="xml">
             <pivot string="Itkan Project Analysis" disable_linking="True">
                 <field name="project_id" type="row"/>
                 <field name="department_id" type="row"/>
                 <field name="progress" type="measure"/>
                 <field name="done_checklist" type="measure"/>
                 <field name="pending_tasks" type="measure"/>
                 <field name="late_steps" type="measure"/>
             </pivot>
         </field>
    </record>

    <record id="view_itkan_project_report_pivot_inherit" model="ir.ui.view">
        <field name="name">view.itkan.project.report.pivot.inherit.itkan.project</field>
        <field name="model">itkan.project.report</field>
        <field name="inherit_id" ref="custom_itkan_project.view_itkan_project_report_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pending_tasks']" position="after">
                <field name="late_steps" type="measure"/>
                <field name="project_type_id" type="row"/>
                <field name="checklist_name" type="row"/>
            </xpath>
        </field>
    </record>

    <record id="view_itkan_project_report_graph" model="ir.ui.view">
         <field name="name">itkan.project.report.graph</field>
         <field name="model">itkan.project.report</field>
         <field name="arch" type="xml">
             <graph string="Itkan Project Analysis" type="line">
                 <field name="progress" type="measure"/>
                 <field name="done_checklist" type="measure"/>
                 <field name="pending_tasks" type="measure"/>
                 <field name="late_steps" type="measure"/>
             </graph>
         </field>
    </record>

