<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
            <field name="name">
                hr.expensenses.config.settings.view.form.inherit
            </field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id"
                   ref="hr_expense.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='expenses_setting_container']" position="inside">
                    <div class="row mt16 o_settings_container">
                        <div class="col-lg-6 col-12 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="accounting_users_to_notify"
                                       string="Accounting Users to Notify"/>
                                <div class="text-muted">
                                    Accounting users can be notified about the
                                    Budget Approval.
                                </div>
                                <field name="accounting_users_to_notify"
                                       widget="many2many_tags"/>
                            </div>
                        </div>
                        <div class="col-lg-6 col-12 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="budget_check_approver"
                                       string="Budget Check Approver"/>
                                <div class="text-muted">
                                    Users can be notified about the Budget
                                    Check.
                                </div>
                                <field name="budget_check_approver"
                                       widget="many2many_tags"/>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.custom.expense</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='main_currency_setting_container']/setting[@id='main_currency']" position="after">
                    <setting string="Limited Currency" help="Limited Currency for expense">
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="limited_currency_ids" class="col-lg-3 o_light_label"/>
                                <field name="limited_currency_ids" options="{'no_create_edit': True, 'no_open': True}" widget="many2many_tags"/>
                            </div>
                        </div>
                    </setting>
                </xpath>

                <xpath expr="//block[@name='main_currency_setting_container']" position="after">
                    <h2>Budget Reminder Users</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box" title="Users for budget reminding notification.">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Budget Reminder Users</span>
                                <div class="text-muted">
                                   Budget Reminder Users
                                </div>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <field name="budget_reminder_user_ids" widget="many2many_tags"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
