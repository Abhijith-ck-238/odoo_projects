<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="product.ProductCatalogOrderLine" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_product_catalog_quantity')]/button[0]" position="attributes">
            <button class="btn btn-primary border"
                        t-on-click.stop="this.env.decreaseQuantity">
                    <i class="fa fa-minus center"/>
                </button>
        </xpath>
    </t>

</templates>
