<odoo>  
    <data>

        <record id="shipment_routes_form" model="ir.ui.view">
            <field name="name">shipment_routes.form</field>
            <field name="model">shipment.route</field>
            <field name="arch" type="xml">
                <form string="">
                    <header>
                    </header>
                    <sheet>
                        <group> 
                            <field name="location_id"/>
                            <field name="date"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="shipment_route_tree" model="ir.ui.view">
            <field name="name">shipment_route.tree</field>
            <field name="model">shipment.route</field>
            <field name="arch" type="xml">
                <list string="Shipment Routes">
                    <field name="shipment_id"/>
                    <field name="location_id"/>
                    <field name="date"/>
                    <field name="notes"/>
                    
                </list>
            </field>
        </record>

    </data>
</odoo>