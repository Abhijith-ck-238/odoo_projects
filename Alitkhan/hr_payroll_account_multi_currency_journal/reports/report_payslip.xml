<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_payslip_inherit" inherit_id="hr_payroll.report_payslip">
        <!-- Fix for line.total in the line_ids loop -->
        <xpath expr="//td[@id='payslip_line_total']/span[@t-out='line.total']" position="attributes">
            <attribute name="t-options">{"widget": "monetary", "display_currency": o.journal_id.currency_id or o.company_id.currency_id}</attribute>
        </xpath>

        <!-- Fix for line.amount in the line_ids loop -->
        <xpath expr="//td[@id='payslip_line_amount']/span[@t-out='line.amount']" position="attributes">
            <attribute name="t-options">{"widget": "monetary", "display_currency": o.journal_id.currency_id or o.company_id.currency_id}</attribute>
        </xpath>

        <!-- Fix for worked_days.amount if it exists in the parent template -->
        <xpath expr="//td[@id='worked_days_amount']" position="attributes">
            <attribute name="t-options">{"widget": "monetary", "display_currency": o.journal_id.currency_id or o.company_id.currency_id}</attribute>
        </xpath>

        <!-- Fix for ytd display if ytd computation is enabled -->
        <xpath expr="//td[@id='payslip_line_ytd']/span[@t-esc='line.ytd']" position="attributes">
            <attribute name="t-options">{"widget": "monetary", "display_currency": o.journal_id.currency_id or o.company_id.currency_id}</attribute>
        </xpath>
    </template>
</odoo>