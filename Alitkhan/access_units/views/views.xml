<odoo>
  <data>
    <!-- explicit list view definition -->

    <record model="ir.ui.view" id="access_units.list">
      <field name="name">access_units list</field>
      <field name="model">access.units</field>
      <field name="arch" type="xml">
        <list editable="top">
          <field name="name"/>
        </list>
      </field>
    </record>


    <!-- actions opening views on models -->

    <record model="ir.actions.act_window" id="access_units.action_window">
      <field name="name">Access Units Window</field>
      <field name="res_model">access.units</field>
      <field name="view_mode">list</field>
    </record>


    <!-- server action to the one above -->
