        action = {
          "type": "ir.actions.act_window",
          "view_mode": "tree,form",
          "res_model": model._name,
        }
      </field>
    </record>
-->

    <!-- menu categories -->
    <menuitem name="Access units" id="access_units.menu_1" parent="hr.menu_hr_root"
      action="access_units.action_window" groups="access_units.administrator_users"/>

