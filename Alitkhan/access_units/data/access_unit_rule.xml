<odoo>
  <data>

    <record id="product_record_rule" model="ir.rule">
      <field name="name">access.unit.product.template.rule</field>
      <field name="model_id" ref="product.model_product_template"/>
      <field name="domain_force">
        [('unit_id','in', user.employee_id.access_units.ids)]
      </field>
    </record>

    <record id="saleorder_record_rule" model="ir.rule">
      <field name="name">access.unit.sale.order.rule</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="domain_force">
        ['|', ('access_unit_ids.id','in', user.employee_id.access_units.ids), ('create_uid', '=', user.id)]
      </field>
    </record>

    <record id="purchase_order_record_rule" model="ir.rule">
      <field name="name">access.unit.purchase.order.rule</field>
      <field name="model_id" ref="purchase.model_purchase_order"/>
      <field name="domain_force">
        ['|', ('access_unit_ids.id','in', user.employee_id.access_units.ids), ('create_uid', '=', user.id)]
      </field>
    </record>

    <record id="access_unites_limited_users" model="res.groups">
      <field name="name">Access Units Limited Users</field>
      <field name="category_id" ref="base.module_category_hidden"/>
      <field name="rule_groups" eval="[(4, ref('access_units.product_record_rule')), (4, ref('access_units.purchase_order_record_rule'))]"/>
    </record>

    <record id="user_users" model="res.groups">
      <field name="name">Access Units User</field>
      <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <record id="administrator_users" model="res.groups">
      <field name="name">Access Units Administrator</field>
      <field name="category_id" ref="base.module_category_hidden"/>
      <field name="implied_ids" eval="[(4, ref('access_units.user_users') )]"/>
      <field name="users" eval="[(4, 2)]"/>
      <field name="comment">
        Only the members of this group can edit the access units of the products and employees
        NOTE !!! You may need to upgrade the Access Units Module Every time you update the Employee's access units
      </field>

    </record>

    <record id="sale_ignore_access_units" model="res.groups">
      <field name="category_id" ref="base.module_category_sales_sales"/>
      <field name="name">Ignore Access Units</field>
      <field name="rule_groups" eval="[(4, ref('sale.sale_order_see_all') )]"/>
      <field name="users" eval="[(4, 2)]"/>
    </record>

    <!-- OVERIDE THE ORIGINAL SALE ORDER RULES -->
    <!-- <record id="sale.sale_order_see_all" model="ir.rule">
      <field name="groups" eval="[(3, ref('sales_team.group_sale_salesman_all_leads') ), (4, ref('access_units.sale_ignore_access_units') )]"/>
    </record> -->

    <record id="sales_team.group_sale_salesman_all_leads" model="res.groups">
      <field name="rule_groups" eval="[(3, ref('sale.sale_order_see_all') ), (4, ref('access_units.saleorder_record_rule') )]"/>
    </record>

    <record id="sale_confirm_sale_order" model="res.groups">
      <field name="category_id" ref="base.module_category_sales_sales"/>
      <field name="name">Confirm Sale Order</field>
      <field name="users" eval="[(4, 2)]"/>
      <field name="comment">Only members of this groups can confirm the sale order</field>
    </record>

  </data>
</odoo>