<odoo>
    <data>


        <record id="product_template_inh_form" model="ir.ui.view">
            <field name="name">product_template_inh.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//page[@name='variants']" position="after">
                    <page name="Hierarchy" string="Hierarchy">
                        <group>
                            <field name="hierarchy"/>
                            <field name="parent_product" widget="many2many_tags" />
                            <field name="zone"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>