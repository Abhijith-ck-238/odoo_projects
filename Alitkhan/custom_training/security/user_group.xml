<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="module_category_training" model="ir.module.category">
            <field name="name">Training</field>
            <field name="description">Helps you to manage the Training</field>
        </record>

        <record id="group_training_limited_user" model="res.groups">
            <field name="name">Training / Limited User</field>
            <field name="category_id" ref="module_category_training"/>
        </record>

        <record id="group_training_officer" model="res.groups">
            <field name="name">Training Officer</field>
            <field name="category_id" ref="module_category_training"/>
        </record>

        <record id="group_training_administrator" model="res.groups">
            <field name="name">Training Administrator</field>
            <field name="category_id" ref="module_category_training"/>
            <field name="implied_ids" eval="[(4, ref('custom_training.group_training_officer'))]"/>
        </record>

        <record model="ir.rule" id="training_ticket_user_rule">
            <field name="name">training.ticket.user.rule</field>
            <field name="model_id" ref="model_training_ticket"/>
            <field name="domain_force">['|','|',('create_uid','=', user.id), ('timeoff_deputy','=',user.id), ('modality_users','in',user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_training.group_training_limited_user'))]"/>
        </record>
    </data>
</odoo>