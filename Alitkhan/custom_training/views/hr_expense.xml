<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_expense_sheet_form_inherit" model="ir.ui.view">
        <field name="name">view.hr.expense.sheet.form.inherit.training</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="training_id" groups="custom_training.group_training_limited_user,custom_training.group_training_officer,custom_training.group_training_administrator"/>
            </xpath>
        </field>
    </record>
</odoo>