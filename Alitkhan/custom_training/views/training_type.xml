<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="training_type_view_tree" model="ir.ui.view">
        <field name="name">training.type.list</field>
        <field name="model">training.type</field>
        <field name="arch" type="xml">
            <list string="Channel" editable="bottom">
                <field name="name"/>
                <field name="allowed_stage_ids" widget="many2many_tags"/>
                <field name="require_letters_certificate"/>
                <field name="activity_users_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="training_type_view_form" model="ir.ui.view">
        <field name="name">training.type.form</field>
        <field name="model">training.type</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
               <chatter/>
            </form>
        </field>
    </record>

    <record id="training_type_view_search" model="ir.ui.view">
        <field name="name">training.type.form</field>
        <field name="model">training.type</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_training_type" model="ir.actions.act_window">
        <field name="name">Training Type</field>
        <field name="res_model">training.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="training_configuration" name="Configuration" parent="training_menu_root" sequence="1" groups="custom_training.group_training_administrator"/>
    <menuitem id="training_type" name="Training Type" action="action_training_type" parent="training_configuration" sequence="1"/>
<!--    <menuitem id="menu_training_config" name="Settings" parent="training_configuration"-->
<!--            sequence="0" action="action_training_configuration"/>-->
</odoo>