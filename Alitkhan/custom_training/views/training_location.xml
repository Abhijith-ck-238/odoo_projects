<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="training_location_view_tree" model="ir.ui.view">
        <field name="name">training.location.list</field>
        <field name="model">training.location</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="training_location_view_form" model="ir.ui.view">
        <field name="name">training.location.form</field>
        <field name="model">training.location</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            <chatter/>
            </form>
        </field>
    </record>

    <record id="training_location_view_search" model="ir.ui.view">
        <field name="name">training.location.form</field>
        <field name="model">training.location</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_training_location" model="ir.actions.act_window">
        <field name="name">Training Location</field>
        <field name="res_model">training.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_training_location" name="Training location" action="action_training_location" parent="training_configuration" sequence="3"/>
</odoo>