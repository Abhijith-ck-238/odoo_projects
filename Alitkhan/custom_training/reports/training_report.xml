<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_training_report_tree" model="ir.ui.view">
         <field name="name">training.report.tree</field>
         <field name="model">training.report</field>
         <field name="arch" type="xml">
             <list string="Training Analysis">
                    <field name="training_id"/>
             </list>
         </field>
    </record>

    <record id="view_training_report_pivot" model="ir.ui.view">
         <field name="name">training.report.pivot</field>
         <field name="model">training.report</field>
         <field name="arch" type="xml">
             <pivot string="Training Analysis" disable_linking="True">
                 <field name="training_id" type="row"/>
                 <field name="stage_id" type="column"/>
                 <field name="contract_id" type="column"/>
                 <field name="training_type_id" type="column"/>
                 <field name="analytic_account_id" type="column"/>
                 <field name="modality_id" type="column"/>
                 <field name="partner_id" type="column"/>
                 <field name="date" type="column"/>
                 <field name="training_location_id" type="column"/>
                 <field name="site_sector_id" type="column"/>
                 <field name="attendees_count" type="measure"/>
             </pivot>
         </field>
    </record>

    <record id="view_training_report_graph" model="ir.ui.view">
         <field name="name">training.report.graph</field>
         <field name="model">training.report</field>
         <field name="arch" type="xml">
             <graph string="Training Analysis" type="line">
                <field name="attendees_count" type="measure"/>
             </graph>
         </field>
    </record>

