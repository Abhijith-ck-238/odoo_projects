    <record id="view_training_report_search" model="ir.ui.view">
        <field name="name">training.report.search</field>
        <field name="model">training.report</field>
        <field name="arch" type="xml">
            <search string="Traianing Analysis">
                <group expand="1" string="Group By">
                    <filter string="Training" name="Training" context="{'group_by':'training_id'}"/>
                    <filter string="Stage" name="Stage" context="{'group_by':'stage_id'}"/>
                    <filter string="Contract" name="Contract" context="{'group_by':'contract_id'}"/>
                    <filter string="Training Type" name="Training Type" context="{'group_by':'training_type_id'}"/>
                    <filter string="Budget" name="Budget" context="{'group_by':'analytic_account_id'}"/>
                    <filter string="Modality" name="Modality" context="{'group_by':'modality_id'}"/>
                    <filter string="Vendor" name="Vendor" context="{'group_by':'partner_id'}"/>
                    <filter string="Date" name="Date" context="{'group_by':'date'}"/>
                    <filter string="Location" name="Location" context="{'group_by':'training_location_id'}"/>
                    <filter string="Site Sector" name="Site Sector" context="{'group_by':'site_sector_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_training_report" model="ir.actions.act_window">
        <field name="name">Training Analysis</field>
        <field name="res_model">training.report</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_training_report_search"/>
        <field name="help">This report performs analysis on your Training.</field>
    </record>

    <menuitem
            id="menu_training_reporting"
            name="Reporting"
            parent="custom_training.training_menu_root"
            sequence="50" groups="group_training_administrator"/>
    <menuitem
        id="menu_training_report"
        name="Training"
        parent="menu_training_reporting"
        action="custom_training.action_training_report"
        sequence="10"/>
</odoo>