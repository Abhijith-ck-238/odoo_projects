            <field name="res_model">training.ticket</field>

        </record>

        <record id="mail_activity_purchase_order_create"
                model="mail.activity.type">
            <field name="name">Purchase for Training Ticket</field>
            <field name="res_model">training.ticket</field>
        </record>
    </data>
</odoo>