<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="mail_activity_training_budget_approval"
                model="mail.activity.type">
            <field name="name">Reminder for Training Budget Approval</field>
            <field name="res_model">budget.analytic</field>

        </record>

        <record id="mail_activity_training_notify_user"
                model="mail.activity.type">
