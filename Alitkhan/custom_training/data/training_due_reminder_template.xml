<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="mail_template_training_date" model="mail.template">
            <field name="name">Training Date</field>
            <field name="model_id" ref="custom_training.model_training_ticket"/>
            <field name="subject">Date for training of contract {{ctx['contract']}}</field>
            <field name="email_from">{{ user.email_formatted }}</field>
            <field name="email_to">{{ ctx['email_to'] }}</field>
            <!--            <field name="email_to">${ctx['email_to']|safe}</field>-->
            <field name="email_cc"></field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>Dear All,</p>
                    <p>
                        Date for the training
                        <a t-att-href="ctx.get('url', '#')">
                            <strong>
                                <t t-out="ctx['training']"/>
                            </strong>
                        </a>
                        will be meet in
                        <t t-out="ctx['date']"/>
                        days, for your actions.
                    </p>
                    <p>Best Regards</p>
                </div>
            </field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="False"/>
            <!--<field name="user_signature" eval="False"/>-->
        </record>
    </data>
</odoo>