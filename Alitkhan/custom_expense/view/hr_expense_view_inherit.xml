<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="hr_expense_view_form_custom_payment_mode" model="ir.ui.view">
        <field name="name">hr.expense.view.form.custom.payment.mode</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">

            <!-- Hide the existing label + div wrapping the native payment_mode radio -->
            <xpath expr="//label[@for='payment_mode']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[@id='payment_mode']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Insert our new custom_payment_mode radio button after the hidden block -->
            <xpath expr="//div[@id='payment_mode']" position="after">
                <label for="custom_payment_mode" string="Paid By"/>
                <div id="custom_payment_mode_div">
                    <field name="custom_payment_mode"
                           widget="radio"/>
                </div>
            </xpath>

        </field>
    </record>

    <!-- ============================================================
         Inherit Expense List View
         - Hide native payment_mode column, show custom_payment_mode
    ============================================================ -->
    <record id="hr_expense_list_view_custom_payment_mode" model="ir.ui.view">
        <field name="name">hr.expense.list.custom.payment.mode</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_expenses_analysis_tree"/>
        <field name="arch" type="xml">
            <!-- Hide original payment_mode column -->
            <xpath expr="//field[@name='payment_mode']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <!-- Add custom_payment_mode column right after -->
            <xpath expr="//field[@name='payment_mode']" position="after">
                <field name="custom_payment_mode"
                       optional="show"
                       readonly="not is_editable"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_expense_sheet_list_inherit" model="ir.ui.view">
        <field name="name">hr.expense.sheet.list.custom</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_tree"/>
        <field name="arch" type="xml">
            <!-- Hide original payment_mode column -->
            <xpath expr="//field[@name='payment_mode']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <!-- Add custom_payment_mode column right after -->
            <xpath expr="//field[@name='payment_mode']" position="after">
                <field name="custom_payment_mode"
                       optional="show" />
            </xpath>
        </field>
    </record>


    <record id="action_update_custom_payment_mode" model="ir.actions.server">
        <field name="name">Update Custom Payment Mode</field>
        <field name="model_id" ref="hr_expense.model_hr_expense"/>
        <field name="binding_model_id" ref="hr_expense.model_hr_expense"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = model.action_update_custom_payment_mode()
        </field>
    </record>
</odoo>