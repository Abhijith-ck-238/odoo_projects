<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="serial_number_view_tree" model="ir.ui.view">
        <field name="name">serial.number.list</field>
        <field name="model">serial.number</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="serial_number_view_form" model="ir.ui.view">
        <field name="name">serial.number.form</field>
        <field name="model">serial.number</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="serial_number_view_search" model="ir.ui.view">
        <field name="name">serial.number.form</field>
        <field name="model">serial.number</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_serial_number" model="ir.actions.act_window">
        <field name="name">Serial Number</field>
        <field name="res_model">serial.number</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_serial_number" name="Serial Number" action="action_serial_number" parent="tac_ks_configuration" sequence="4"/>
</odoo>