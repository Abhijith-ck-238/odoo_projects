    <record id="component_product_view_form" model="ir.ui.view">
        <field name="name">component.product.form</field>
        <field name="model">component.product</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                             <field name="ticket_id" invisible="1"/>
                            <field name="product_ids" invisible="1"/>
                            <field name="product_id"/>
                            <field name="serial_number_id"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="tac_ks_view_form_inherit"
            model="ir.ui.view">
        <field name="name">tac.ks.view.form.inherit</field>
        <field name="model">tac.ks.ticket</field>
        <field name="inherit_id" ref="custom_tac_ks.tac_ks_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page" position="after">
                <page name="product_checklist" string="Technical Awareness">
                    <field name="product_line_ids">
                        <list editable="bottom">
                            <field name="ticket_id" invisible="1"/>
                            <field name="product_ids" invisible="1"/>
                            <field name="product_id"/>
                            <field name="serial_number_id"/>
                            <button name="action_show_checklist" class="btn btn-primary" string="Show Checklist" type="object"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="images" widget="many2many_binary"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_tac_ka_ticket" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">tac.ks.ticket</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_tac_ks_tickets" name="Tickets" action="action_tac_ka_ticket" parent="tac_ks_menu_root" sequence="0"/>
</odoo>