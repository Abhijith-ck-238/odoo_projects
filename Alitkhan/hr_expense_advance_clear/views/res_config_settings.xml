<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_pledges" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.hr.expense</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="hr_expense.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='expenses_setting_container']" position="after">
                    <block>
                         <setting string="Restored Day" help="Set the database restored date" id="hr_expense_restored_date"
                             groups="base.group_system">
                        <field name="restored_date"/>
                    </setting>

                    <setting string="Force edit old data"
                             help="By enabling this,users can update the old data if necessary"
                             id="hr_expense_restored_date" groups="base.group_system">
                        <field name="force_edit_old_data" widget="upgrade_boolean"/>
                    </setting>
                    </block>

                </xpath>
            </field>
        </record>
    </data>
</odoo>