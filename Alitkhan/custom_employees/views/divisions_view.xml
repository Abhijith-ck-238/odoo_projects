<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="division_division_tree" model="ir.ui.view">
            <field name="name">division.division.tree</field>
            <field name="model">division.division</field>
            <field name="arch" type="xml">
                <list string="Division">
                   <field name="name"/>
                </list>
            </field>
        </record>

         <record id="division_division_form" model="ir.ui.view">
            <field name="name">division.division.form</field>
            <field name="model">division.division</field>
            <field name="arch" type="xml">
                <form string="Divisions">
                    <sheet>
                        <group>
                                <field name="name" required="True"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_division" model="ir.actions.act_window">
            <field name="view_mode">list,form</field>
            <field name="name"> Divisions </field>
            <field name="res_model">division.division</field>
        </record>

        <menuitem
                id="menu_division"
                name="Divisions"
                parent="hr.menu_human_resources_configuration"
                action="action_division"
                />

    </data>
</odoo>