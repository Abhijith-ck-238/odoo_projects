    <!--    HR LEAVE VIEW-->
    <record id="hr_leave_view_form_inherit_approval" model="ir.ui.view">
        <field name="name">hr.leave.form</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <field name="holiday_status_id" position="after">
                <field name="validation_type" invisible="1"/>
            </field>
            <xpath expr="//header/button[@name='action_approve']" position="after">
                <button string="Send For Approval" name="send_for_approval"
                        invisible="validation_type not in ['direct_director'] or state not in ['draft','confirm']"
                        type="object" class="oe_highlight" />
                <button string="Approve" name="direct_manager_approve"
                        invisible="state not in ['direct_manager']"
                        type="object" class="oe_highlight"/>

                <button string="Approve" name="second_direct_manager_approve"
                        invisible="state not in ['2direct_manager']"
                        type="object" class="oe_highlight"/>

                <button string="Approve" name="manager_approve"
                        invisible="state not in ['manager']"
                        type="object" class="oe_highlight"/>

                <button string="Approve" name="director_approve"
                        invisible="state not in ['director']"
                        type="object" class="oe_highlight"/>

                <button string="Approve" name="hr_officer_approve"
                        invisible="state not in  ['hr']"
                        type="object" class="oe_highlight"/>
            </xpath>
            <xpath expr="//header/button[@name='action_refuse']" position="replace">
                                <button string="Refuse" name="action_refuse" type="object" invisible="not can_approve or state not in ['confirm','validate','validate1', 'direct_manager', '2direct_manager', 'manager', 'director', 'hr']"/>

<!--                <button string="Refuse" name="action_refuse"-->
<!--                        type="object"-->
<!--                        invisible = "not can_approve or state not in  ('confirm','validate','validate1', 'direct_manager', '2direct_manager', 'manager', 'director', 'hr')"/>-->
            </xpath>
            <xpath expr="//header/button[@name='action_approve']" position="replace">
                <button string="Approve" name="action_approve"
                        type="object"
                        class="oe_highlight"
                        invisible = "validation_type in 'direct_director' or not can_approve or state != 'confirm'"/>
            </xpath>
            <field name="request_date_from" position="replace">
                <field name="request_date_from" class="oe_inline"
                       readonly = "state not in  ('draft', 'confirm','direct_manager', '2direct_manager', 'manager', 'director', 'hr')"/>
            </field>

            <field name="request_date_to" position="replace">
                <field name="request_date_to" class="oe_inline"
                       readonly ="state not in ('draft', 'confirm', 'direct_manager', '2direct_manager', 'manager', 'director', 'hr')"
                       invisible="request_unit_half or request_unit_hours"/>
            </field>

<!--            <field name="request_date_from_period" position="replace">-->
<!--                <field name="request_date_from_period" class="oe_inline"-->
<!--                       string="In"-->
<!--                       options="{'horizontal': True}"-->
<!--                       readonly="state not in ('draft', 'confirm','direct_manager', '2direct_manager', 'manager', 'director', 'hr')"-->
<!--                       required ='request_unit_half'-->
<!--                       invisible="not request_unit_half"/>-->

<!--            </field>-->
            <!-- Domain need to be given after confirming the allocation type """domain="['&amp;', ('virtual_remaining_leaves', '&gt;', 0), '|', ('allocation_type', 'in', ['fixed_allocation', 'no']),'&amp;',('allocation_type', '=', 'fixed'), ('max_leaves', '>', '0')]"-->
<!--                                   domain="['&amp;', ('virtual_remaining_leaves', '&gt;', 0), '|', ('allocation_validation_type', 'in', ['fixed_allocation', 'no']),'&amp;',('allocation_validation_type', '=', 'fixed'), ('max_leaves', '>', '0')]"
-->
            <field name="holiday_status_id" position="replace">
                    <field name="holiday_status_id" force_save="1"
                                domain="[
                                    '|',
                                        ('requires_allocation', '=', 'no'),
                                        '&amp;',
                                            ('has_valid_allocation', '=', True),
                                            '|',
                                                ('allows_negative', '=', True),
                                                '&amp;',
                                                    ('virtual_remaining_leaves', '&gt;', 0),
                                                    ('allows_negative', '=', False),
                                ]"
                                context="{'employee_id': employee_id, 'default_date_from': date_from, 'default_date_to': date_to}"
                                options="{'no_create': True, 'no_open': True, 'request_type': 'leave'}"
                                readonly="state in ['cancel', 'refuse', 'validate', 'validate1']"/>
            </field>
            <field name="request_unit_half" position="replace">
                <field name="request_unit_half" class="oe_inline" invisible="leave_type_request_unit == 'day'" readonly="state not in ['confirm','draft']"/>
            </field>

            <field name="name" position="replace">
                 <field name="name" readonly="state not in ['confirm','draft']" widget="text" placeholder="Add a description..." />
            </field>




<!--                <field name="holiday_status_id"-->
<!--                       readonly="state not in ('draft', 'confirm','direct_manager', '2direct_manager', 'manager', 'director', 'hr')"-->
<!--                       context="{'employee_id':employee_id, 'default_date_from':date_from}"-->
<!--                       options="{'no_create': True, 'no_open': True}"-->
<!--                       domain="['&amp;', ('virtual_remaining_leaves', '&gt;', 0), '|', ('allocation_validation_type', 'in', ['fixed_allocation', 'no']),'&amp;',('allocation_validation_type', '=', 'fixed'), ('max_leaves', '>', '0')]"-->
<!--                       class="col-9 pl-0" nolabel="1"/>-->

        </field>
    </record>
</odoo>
