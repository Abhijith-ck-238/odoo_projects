<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Employee View -->
    <record id="approval_direct_manager_hr_employee_view_form" model="ir.ui.view">
        <field name="name">direct.manager.hr.employee.view.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="replace">
                <field name="direct_manager_id"/>
                <field name="second_direct_manager_id"/>
                <field name="parent_id"/>
                <field name="director_id"/>
            </xpath>

              <xpath expr="//field[@name='image_1920']" position="attributes">
                <attribute name="options">{"zoom":true,"preview_image":"image_128","size":[0,270]}</attribute>
              </xpath>

              <xpath expr="//field[@name='company_id']" position="after">
                <field invisible="1" name="x_studio_field_Qmo9K_filename"/>
              </xpath>

              <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
                <group name="studio_group_WH65U">
                  </group>
              </xpath>

             <xpath expr="//field[@name='employee_skill_ids']" position="inside">
                <form string="Skills">
                  <sheet name="studio_sheet_bd908c">
                    <group name="studio_group_2b80f0">
                      <group name="studio_group_c1a447">
                        <field name="skill_type_id"/>
                        <field name="skill_id" domain="[('skill_type_id', '=', skill_type_id)]" options="{'no_create_edit':True}"/>
                      </group>
                      <group name="studio_group_2ec4bb">
                        <field name="skill_level_id" domain="[('skill_type_id', '=', skill_type_id)]"/>
                        <field name="level_progress" widget="progressbar"/>
                      </group>
                    </group>
                  </sheet>
                </form>
              </xpath>

              <xpath expr="//field[@name='address_id']" position="after">
                <field name="related_partner_id"/>
              </xpath>


        </field>
    </record>

    <record id="view_hr_holidays_filter_inherit_all_approver" model="ir.ui.view">
        <field name="name">hr.holidays.filter.inherit.all.approver</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.view_hr_holidays_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='approve']" position="replace">
                <filter domain="[('state','in',('confirm','validate1','direct_manager', '2direct_manager' ,'manager','director','hr'))]"
                        string="To Approve" name="approve"/>
            </xpath>
            <xpath expr="//filter[@name='approve']" position="replace">
                <filter domain="[('state','in',('confirm','validate1','direct_manager', '2direct_manager' ,'manager','director','hr'))]" string="To Approve" name="approve"/>
            </xpath>
             <xpath expr="//field[@name='employee_id']" position="after">
                <field name="manager_id"/>
            </xpath>

            <xpath expr="//filter[@name='group_employee']" position="before">
                <filter name="studio_group_by_hDx49" string="Department" context="{'group_by': 'department_id'}"/>
            </xpath>

        </field>
    </record>


    <record id="hr_holidays.hr_leave_action_action_approve_department" model="ir.actions.act_window">
        <field name="domain">['|','|','|','|',('employee_id.leave_manager_id', '=',
            uid),('employee_id.direct_manager_id', '=', uid),('employee_id.second_direct_manager_id', '=', uid),
            ('employee_id.director_id', '=', uid),('employee_id.parent_id.user_id', '=', uid)]
        </field>
    </record>

    <!--    Leave Type view-->
    <record id="edit_holiday_status_form_inherit" model="ir.ui.view">
        <field name="name">hr.leave.type.form</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='configuration']/field[@name='responsible_ids']" position="replace">
                <field name="responsible_ids"
                       invisible="leave_validation_type in ['no_validation', 'manager','direct_director']"
                       required="leave_validation_type in ['hr', 'both']"/>
            </xpath>
        </field>
    </record>

    <record id="hr_leave_view_form_manager_inheritt" model="ir.ui.view">
        <field name="name">hr.leave.view.form.manager</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="validation_type" invisible="1"/>
            </xpath>
        </field>
    </record>


