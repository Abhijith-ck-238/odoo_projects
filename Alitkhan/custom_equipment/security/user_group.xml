<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="module_category_equipment" model="ir.module.category">
            <field name="name">Equipment</field>
            <field name="description">Helps you to manage the Equipments</field>
        </record>

        <record id="group_equipment_user" model="res.groups">
            <field name="name">Equipment User</field>
            <field name="category_id" ref="module_category_equipment"/>
        </record>

        <record id="group_equipment_manger" model="res.groups">
            <field name="name">Equipment Manager</field>
            <field name="category_id" ref="module_category_equipment"/>
            <field name="implied_ids" eval="[(4, ref('custom_equipment.group_equipment_user'))]"/>
        </record>
    </data>
</odoo>