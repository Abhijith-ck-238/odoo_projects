<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="equipment_status_view_tree" model="ir.ui.view">
        <field name="name">equipment.status.list</field>
        <field name="model">equipment.status</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="equipment_status_view_form" model="ir.ui.view">
        <field name="name">equipment.status.form</field>
        <field name="model">equipment.status</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="equipment_status_view_search" model="ir.ui.view">
        <field name="name">equipment.status.form</field>
        <field name="model">equipment.status</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_equipment_status" model="ir.actions.act_window">
        <field name="name">Equipment Status</field>
        <field name="res_model">equipment.status</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_equipment_status" name="Equipment Status" action="action_equipment_status" parent="equipment_configuration_menu" sequence="2"/>
</odoo>