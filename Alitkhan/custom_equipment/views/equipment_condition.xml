<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="equipment_condition_view_tree" model="ir.ui.view">
        <field name="name">equipment.condition.list</field>
        <field name="model">equipment.condition</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="equipment_condition_view_form" model="ir.ui.view">
        <field name="name">equipment.condition.form</field>
        <field name="model">equipment.condition</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="equipment_condition_view_search" model="ir.ui.view">
        <field name="name">equipment.condition.form</field>
        <field name="model">equipment.condition</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_equipment_condition" model="ir.actions.act_window">
        <field name="name">Equipment Condition</field>
        <field name="res_model">equipment.condition</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_equipment_condition" name="Equipment Condition" action="action_equipment_condition" parent="equipment_configuration_menu" sequence="3"/>
</odoo>