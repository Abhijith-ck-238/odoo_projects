    <template id="itkan_offering.offering_offering_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="itkan_offering.offering_offering_document">
                    <t t-raw="0"/>
                </t>
            </t>
        </t>
    </template>

    <template id="itkan_offering.offering_offering_document">
        <t t-call="web.external_layout">
            <style>
                <link rel="stylesheet" type="text/css" href="/web/static/lib/fontawesome/css/font-awesome.css"/>
            </style>
            <t t-set="doc" t-value="doc.sudo()"/>
            <div class="page">
                <div class="row" style="padding-top: 20px; padding-bottom: 100px;">
                    <!-- &#160; means a forced space -->
                    <!-- DO NOT REMOVE THE EXTRA SPACES -->
                    <div class="col-7">
                        <p style="line-height: 1.2; font-weight: bold; font-size: large;" t-if="doc.customer">
                            <span t-field="doc.customer"/>
                        </p>
                        <p style="line-height: 0.4;" t-if="doc.ifb_no">IFB No&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;:&#160;&#160;<span
                                t-field="doc.ifb_no"/>
                        </p>
                        <p style="line-height: 0.4;" t-if="doc.project_subject">Subject&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;:&#160;&#160;<span
                                t-field="doc.project_subject"/>
                        </p>
                        <p style="line-height: 0.4;" t-if="doc.tendor_no">Tendor No&#160;:&#160;&#160;<span
                                t-field="doc.tendor_no"/>
                        </p>
                    </div>
                    <div class="col-5" style="margin-top: 45px;">
                        <p style="line-height: 0.4;" t-if="res_company.email">Email&#160;:&#160;&#160;<span
                                t-field="res_company.email"/>
                        </p>
                        <p style="line-height: 0.4;" t-if="doc.ref_number">Ref&#160;&#160;&#160;&#160;&#160;&#160;:&#160;&#160;<span
                                t-field="doc.ref_number"/>
                        </p>
                        <p style="line-height: 0.4;" t-if="doc.offer_date">Date&#160;&#160;&#160;:&#160;&#160;<span
                                t-field="doc.offer_date"/>
                        </p>
                        <p style="line-height: 0.4;" t-if="doc.iq">Project No:&#160;&#160;<span t-field="doc.iq"/>
                        </p>
                    </div>
                </div>
                <t t-foreach="doc.report_template_lines" t-as="section">
                    <div t-if="section_first">
                        <p syle="font-weight: bold">Dear Sir,</p>
                        <div style="margin-bottom: 100px;" t-field="section.template_body"/>

                        <p style="font-weight: bold; margin-bottom: 80px;">Should you require any further information,
                            please do not hesitate to contact us.
                        </p>
                        <p style="font-weight: bold; margin-bottom: 80px;">Thank you for your attention and remain</p>
                        <p t-if="doc.sincerely_ids" style="font-weight: bold; margin-bottom: 100px;">Yours Sincerely,
                        </p>
                        <table t-if="doc.sincerely_ids" style="width: 100%;">
                            <tr>
                                <t t-foreach="doc.sincerely_ids" t-as="employee">
                                    <td style="padding:20px; width: 20%;">
                                        <div align="center" style="font-weight: bold;" t-field="employee.name"/>
                                        <div align="center" t-field="employee.job_title"/>
                                    </td>
                                    <td t-if="not employee_last"
                                        t-attf-style="width: {{ (100 - (len(doc.sincerely_ids)*20) ) / (len(doc.sincerely_ids)-1) }}% ;">
                                    </td>
                                </t>
                            </tr>
                        </table>


                        <!-- SECTION 1: THE COVER LETTER -->

                        <div style="page-break-after: always;"/>
                        <h4 align="center" style="text-decoration: underline; padding-top: 25px;">
                            Terms and Conditions
                        </h4>

                        <p align="center" style="text-decoration: underline; font-size: large;"
                           t-field="doc.terms_and_conditions_section_id.body"/>

                        <p t-if="doc.add_refer_to_our_enclosed_offer" align="center"
                           style="text-decoration: underline;">
                            Please refer to our enclosed offer, as there are technical and commercial modifications.
                        </p>
                    </div>
                    <div t-else="else"
                         t-attf-style="margin: 25px 0; {{'page-break-after: always;' if section_index in [4, 8] else ''}}">
                        <p>
                            <t t-if="section.name">
                                <span style="font-weight: bold;">
                                    <t t-esc="section_index"/>.
                                    <t t-esc="section.name"/>
                                </span>
                                <p t-field="section.template_body"/>
                            </t>
                            <t t-else="">
                                <strong t-esc="section_index"/>.
                                <p t-field="section.template_body"/>
                            </t>
                        </p>
                    </div>
                </t>
                <div align="center" t-if="doc.add_conditions_and_warranty">
                    <p style="font-weight: bold; font-size: large;">
                        Furthermore,
                        <t t-esc="doc.vendor_id.name"/>
                        General Conditions of supply and Delivery Exports and, for certain products,
                        <t t-esc="doc.vendor_id.name"/>
                        Special warranty Conditions shall apply.
                    </p>
                </div>
                <div style="page-break-after: always;"/>

                <!-- SECTION 2 : SUMMARY LIST -->

                <h4 align="center" style="text-decoration: underline; padding-top: 50px;">
                    Summray List
                </h4>
                <p style="font-size: large;">
                    <t t-esc="doc.project_name"/>
                    <t t-esc="doc.tendor_no"/>
                    -
                    <t t-esc="doc.project_subject"/>
                </p>
                <table class="table table-sm o_main_table" style="page-break-after: always;">
                   <thead style="border-top: 2px solid #d3d3d3; border-bottom: 2px solid #d3d3d3;">
                    <tr>
                        <th align="left" name="th_item_no" style="font-weight: bold;">Item No.</th>
                        <th name="th_description" style="font-weight: bold;">Description</th>
                        <th align="left" name="th_quantity" style="font-weight: bold;">Quantity</th>
                        <th align="right" name="th_unit_price" style="font-weight: bold;">
                            Unit Price in <t t-esc="doc.offer_currency.name"/>
                        </th>
                        <th align="right" name="th_total_price" style="font-weight: bold;">
                            Total Price in <t t-esc="doc.offer_currency.name"/>
                        </th>
                        <th style="font-weight: bold;"></th>
                    </tr>
                </thead>

                    <tbody>
                        <t t-set="summary_total" t-value="0.0"/>
                        <t t-foreach="doc.product_lines.filtered(lambda x: not x.optional_product)" t-as="line">
                            <t t-if="not line.hide_from_offer_report">
                                <tr>
                                    <td align="left" name="td_index">
                                        <span t-esc="line_index + 1"/>
                                    </td>
                                    <td name="td_name">
                                        <p t-field="line.name" style="background: lightgray;"/>
                                        <p t-field="line.product_id"/>
                                    </td>
                                    <td align="left" name="th_quantity">
                                        <span align="center" t-field="line.qty"/>
                                    </td>
                                    <td style="text-align: center;" name="th_unit_price">
                                        <t t-if="doc.offer_currency.name == 'IQD'">
                                            <span t-esc='"{:,d}".format( int( line.final_unit_price_iqd) )'/>
                                            <t t-set="summary_total"
                                               t-value='summary_total + line.final_unit_price_iqd'/>
                                        </t>
                                        <t t-else="else">
                                            <span t-esc='"{:,d}".format( int( line.final_unit_price_usd) )'/>
                                            <t t-set="summary_total"
                                               t-value='summary_total + line.final_unit_price_usd'/>
                                        </t>
                                    </td>
                                    <td align="right" name="th_total_price">
                                        <span t-if="doc.offer_currency.name == 'IQD'"
                                              t-esc='"{:,d}".format( int( line.final_total_price_iqd) )'/>
                                        <span t-else="else" t-esc='"{:,d}".format( int( line.final_total_price_usd) )'/>
                                    </td>
                                </tr>
                            </t>
                            <t t-else="else">
                                <t t-set="summary_total" t-value='summary_total + line.unit_price'/>
                            </t>
                        </t>
                        <tr t-if="doc.include_section_id" name="include_section">
                            <td></td>
                            <td>
                                <p style="font-weight: bold; font-size: large;">Including:</p>
                                <p t-field="doc.include_section_id.body"/>
                            </td>
                        </tr>
                        <tr name="total_price_line"
                            style=" margin-top: 4px; border-top: solid 2px black; border-bottom: solid 2px black;">
                            <td></td>
                            <td>Total price for the project in
                                <t t-esc="doc.offer_currency.name"/>
                            </td>
                            <td></td>
                            <td></td>
                            <td>
                                <span t-esc='"{:,d}".format( int( summary_total ) )'/>
                            </td>
                        </tr>
                        <t t-foreach="doc.product_lines.filtered(lambda x: x.optional_product)" t-as="line">
                            <t t-if="line_index == 0">
                                <tr>
                                    <td></td>
                                    <td>
                                        <span style="font-weight: bold; font-size: large;">Optional:</span>
                                    </td>
                                </tr>
                            </t>
                            <tr>
                                <td></td>
                                <td name="th_optional_name">
                                    <p t-field="line.name" style="background: lightgray;"/>
                                    <p t-field="line.product_id"/>
                                </td>
                                <td name="th_optional_quantity">
                                    <span t-field="line.qty"/>
                                </td>
                                <td name="th_optional_unit_price">
                                    <span t-if="doc.offer_currency.name == 'IQD'" t-field="line.final_unit_price_iqd"/>
                                    <span t-else="else" t-field="line.final_unit_price_usd"/>
                                </td>
                                <td name="th_optional_total_price">
                                    <span t-if="doc.offer_currency.name == 'IQD'" t-field="line.final_total_price_iqd"/>
                                    <span t-else="else" t-field="line.final_total_price_usd"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>

                </table>

                <!-- SECTION 3 : PARTS DESCRIPTION -->
                <div name="parts_section" t-if="any( doc.product_lines.filtered(lambda x: x.config) )">
                    <h4 align="center" style="text-decoration: underline; padding-top: 50px;">
                        Parts Description
                    </h4>
                    <p t-if="doc.check_defect()">EXCHANGE: items are only valid in case we receive the corresponding old
                        or defective items back.
                    </p>
                    <t t-foreach="doc.product_lines.filtered(lambda x: x.hide_from_offer_report == False and x.config)"
                       t-as="item">
                        <div t-attf-style="{{ 'padding-top: 0px;' if item_first else 'padding-top: 38px;'}}">
                            <h6 style="background: lightgray; font-size: large; font-weight: bold; padding: 12px 5px;">
                                Tendor No.
                                <t t-esc="doc.tendor_no"/>
                                - Item<t t-esc="item_index + 1"/>:
                                <t t-esc="item.name if item.name else item.product_id.display_name"/>
                            </h6>
                        </div>
                        <table class="table table-sm o_main_table" style="page-break-after: always;">
                          <thead style="border-top: 2px solid #d3d3d3; border-bottom: 2px solid #d3d3d3;">
                                <tr>
                                    <th style="text-align: left; font-weight: bold;">Seq</th>
                                    <th style="text-align: center; font-weight: bold;">Part NO.</th>
                                    <th style="text-align: left; font-weight: bold;">Description</th>
                                    <th style="text-align: center; font-weight: bold;">QTY</th>
                                    <th style="text-align: center; font-weight: bold;">
                                        Unit Price in <t t-esc="doc.offer_currency.name"/>
                                    </th>
                                    <th style="text-align: center; font-weight: bold;">
                                        Total Price in <t t-esc="doc.offer_currency.name"/>
                                    </th>
                                </tr>
                            </thead>



                            <tbody>
                                <t t-set="total_config_price" t-value="0"/>
                                <t t-foreach="item.config.product_bom_lines.filtered(lambda x: not x.optional_product)"
                                   t-as="part">
                                    <t t-set="converted_unit_price"
                                       t-value="part.price_unit * part.policy * (item.currency.exchange_rate if item.currency else  1)"/>
                                    <t t-set="converted_unit_price"
                                       t-value="converted_unit_price * (item.exchange_rate if doc.offer_currency.name == 'IQD' and item.config.currency.currency_name == 'USD' else  1)"/>
                                    <t t-set="converted_total_price"
                                       t-value="part.total_price * (item.currency.exchange_rate if item.currency else  1)"/>
                                    <t t-set="converted_total_price"
                                       t-value="converted_total_price * (item.exchange_rate if doc.offer_currency.name == 'IQD' and item.config.currency.currency_name == 'USD' else  1)"/>
                                    <t t-set="total_config_price" t-value="total_config_price + converted_total_price"/>
                                    <tr t-attf-style="{{ '' if (part_index % 2 == 0) else 'background: lightgray;' }}">
                                        <td>
                                            <span t-esc="part_index + 1"/>
                                        </td>
                                        <td style="text-align: center;">
                                            <span style="text-align: center;" t-field="part.smn"/>
                                        </td>
                                        <td>
                                            <span t-esc="part.product_id.product_long_desc if part.product_id.product_long_desc else part.product_id.name"/>
                                            <span t-if="part.is_defect">(EXCHANGE)</span>
                                        </td>
                                        <td style="text-align: center;">
                                            <span t-field="part.qty"/>
                                        </td>
                                        <td align="center">
                                            <span t-if="item.config.show_price"
                                                  t-esc='"{:,d}".format( int( converted_unit_price) )'/>
                                        </td>
                                        <td align="center">
                                            <span t-if="item.config.show_price"
                                                  t-esc='"{:,d}".format( int( converted_total_price) )'/>
                                        </td>
                                    </tr>
                                </t>
                                <tr name="config_total_price_line"
                                    style=" margin-top: 4px; border-bottom: solid 2px black;">
                                    <td></td>
                                    <td></td>
                                    <td>
                                        <span style="font-weight: bold;">
                                            Total price in
                                            <t t-esc="doc.offer_currency.name"/>
                                        </span>
                                    </td>
                                    <td></td>
                                    <td></td>
                                    <td>
                                        <span t-esc='"{:,d}".format( int( total_config_price) )'/>
                                    </td>
                                </tr>
                                <t t-foreach="item.config.product_bom_lines.filtered(lambda x: x.optional_product)"
                                   t-as="op_part">
                                    <t t-if="op_part_index == 0">
                                        <tr style="border-top: solid 2px black;">
                                            <td></td>
                                            <td>
                                                <span style="font-weight: bold; font-size: large;">Optional:</span>
                                            </td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                        </tr>
                                    </t>
                                    <tr t-attf-style="{{ '' if (op_part_index % 2 == 0) else 'background: lightgray;' }}">
                                        <t t-set="converted_unit_price"
                                           t-value="op_part.price_unit * op_part.policy * (item.currency.exchange_rate if item.currency else  1)"/>
                                        <t t-set="converted_unit_price"
                                           t-value="converted_unit_price * (item.exchange_rate if doc.offer_currency.name == 'IQD' and item.config.currency.currency_name == 'USD' else  1)"/>
                                        <t t-set="converted_total_price"
                                           t-value="op_part.total_price * (item.currency.exchange_rate if item.currency else  1)"/>
                                        <t t-set="converted_total_price"
                                           t-value="converted_total_price * (item.exchange_rate if doc.offer_currency.name == 'IQD' and item.config.currency.currency_name == 'USD' else  1)"/>
                                        <td></td>
                                        <td>
                                            <span t-field="op_part.smn"/>
                                        </td>
                                        <td>
                                            <span t-esc="op_part.product_id.product_long_desc if op_part.product_id.product_long_desc else op_part.product_id.display_name"/>
                                        </td>
                                        <td>
                                            <span t-field="op_part.qty"/>
                                        </td>
                                        <td align="center">
                                            <span t-esc='"{:,d}".format( int( converted_unit_price) )'/>
                                        </td>
                                        <td align="center">
                                            <span t-esc='"{:,d}".format( int( converted_total_price) )'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>


            </div>
        </t>
    </template>

