<odoo>
    <data>
            <record id="offering_purchase_inh_form" model="ir.ui.view">
                <field name="name">offering_purchase_inh.form</field>
                <field name="model">purchase.order</field>
                <field name="inherit_id" ref="purchase.purchase_order_form" />
                <field name="arch" type="xml">
                    <xpath expr="//field[@name='date_order']" position="after">
                        <field name="related_offering_record" />
                    </xpath>
                </field>
            </record>
    </data>
</odoo>
