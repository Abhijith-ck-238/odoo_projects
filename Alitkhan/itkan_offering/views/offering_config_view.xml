<odoo>
    <record model="ir.ui.view" id="itkan_offering.offering_config_form">
        <field name="name">Offering Config Form</field>
        <field name="model">offering.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
                    <button name="confirm_config" string="Validate" type="object" invisible="state == 'confirm'"
                            groups="itkan_offering.offering_manager"/>
                    <button name="reset_to_draft" string="Reset To Draft" type="object" invisible="state == 'draft'"/>

                </header>
                <sheet>
                    <h1>
                        <field name="name" placeholder="Name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="iq" readonly="state == 'confirm'"/>
                            <field name="product_id" readonly="state == 'confirm'"
                                   context="{'default_type': 'consu'}"/>
                            <field name="vendor" readonly="state == 'confirm'"
                                   context="{'default_company_type': 'company'}"/>
                            <field name="general_policy"/>
                            <field name="create_date"/>
                            <field name="create_uid"/>
                            <field name="currency" readonly="state == 'confirm'"/>
                        </group>
                        <group>
                            <field name="parent_unit_id" readonly="state == 'confirm'"
                                   options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="child_unit_id" readonly="state == 'confirm'"
                                   options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="show_price"/>
                            <field name="total_vendor_price"/>
                        </group>
                    </group>

                    <field name="product_bom_lines">
                        <list editable="top">
                            <field name="optional_product" width="50px" optional="1"/>
                            <field name="is_defect" optional="1"/>
                            <field name="product_id" optional="show"/>
                            <field name="smn" required="product_id" optional="show"/>
                            <field name="description"/>
                            <field name="vendor"/>
                            <field name="qty" sum="Total Quantity"/>
                            <field name="price_unit" sum="Total Unit Prices"/>
                            <field name="policy"/>
                            <field name="total_price" sum="Total"/>
                        </list>
                    </field>

                </sheet>
                <chatter/>
            </form>
        </field>

    </record>

    <record model="ir.ui.view" id="itkan_offering.offering_config_form_calculcation">
        <field name="name">Offering Config Form</field>
        <field name="model">offering.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name" placeholder="Name"/>
                    </h1>
                    <group>
                    </group>
                    <field name="product_bom_lines">
                        <list editable="top">
                            <field name="optional_product" optional="1"/>
                            <field name="is_defect" optional="1"/>
                            <field name="product_id" optional="show"/>
                            <field name="smn" required="product_id" optional="show"/>
                            <field name="description"/>
                            <field name="vendor"/>
                            <field name="qty" sum="Total Quantity"/>

                            <field name="price_unit" sum="Total Unit Prices"/>
                            <field name="policy"/>
                            <field name="total_price" sum="Total"/>
                        </list>
                    </field>
                    <footer class="oe_edit_only">
                        <button string="Recalculate" name="recalculate_button" type="object" class="oe_highlight"/>
                        <button string="Discard" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>

    </record>

    <record model="ir.ui.view" id="itkan_offering.offering_config_tree">
        <field name="name">Offering Config Tree</field>
        <field name="model">offering.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_id"/>
                <field name="iq"/>
                <field name="create_date"/>
                <field name="create_uid"/>
            </list>
        </field>
    </record>
</odoo>
