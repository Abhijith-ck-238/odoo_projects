<odoo>
    <data>
        <record id="contract_contract_inh_form" model="ir.ui.view">
            <field name="name">contract_contract_inh.form</field>
            <field name="model">contract.contract</field>
            <field name="inherit_id" ref="contracts.form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='first_payment']" position="after">
                    <field name="related_offering_record"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>