    <record id="fleet_vehicle_view_kanban" model="ir.ui.view">
        <field name="name">fleet.vehicle.kanban.inherit</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='vehicle_details']" position="replace">
                <div>
                    <label for="seats"><strong>Seats:</strong></label>
                    <field name="seats"/>
                    <label for="doors"><strong>/Doors:</strong></label>
                    <field name="doors"/>
                </div>
                 <div>
                     <label for="odometer"><strong>Odometer:</strong></label>
                    <field name="odometer"/>
                 </div>
            </xpath>
<!--             <xpath expr="//kanban[1]/templates[1]/t[1]/div[1]/div[6]" position="after">-->
<!--                 <div>-->
<!--                     <label for="odometer"><strong>Odometer:</strong></label>-->
<!--                    <field name="odometer"/>-->
<!--                 </div>-->
<!--             </xpath>-->
            <xpath expr="//field[@name='driver_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='driver_id']" position="after">
                <field name="license_plate"/>
            </xpath>
            <xpath expr="//t[@t-if='record.license_plate.raw_value']" position="replace">
                <field name="car_tag"/> :
            </xpath>
            <xpath expr="//kanban" position="attributes">
                <attribute name="default_order">car_tag asc</attribute>
            </xpath>
        </field>
    </record>

