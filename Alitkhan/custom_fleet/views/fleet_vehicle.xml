    <record id="service_interval_view_inherit" model="ir.ui.view">
        <field name="name">service.interval.inherit</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="itkan_fleet_customization.fleet_vehicle_inh_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='service_lines']/field[@name='service_lines']/list/field[@name='service_type']"
                   position="after">
                <field name="odometer_value" column_invisible="True"/>
            </xpath>
        </field>
    </record>

