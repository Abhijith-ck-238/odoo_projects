<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="module_category_sp_orders" model="ir.module.category">
            <field name="name">Sp Orders</field>
            <field name="description">Helps you to manage the Sp Orders</field>
        </record>

        <record id="group_sp_order_user" model="res.groups">
            <field name="name">Sp Orders User</field>
            <field name="category_id" ref="module_category_sp_orders"/>
        </record>

        <record id="group_sp_orders_administrator" model="res.groups">
            <field name="name">SP Orders Administrator</field>
            <field name="category_id" ref="module_category_sp_orders"/>
            <field name="implied_ids" eval="[(4, ref('custom_sp_orders.group_sp_order_user'))]"/>
        </record>
    </data>
</odoo>