    <record id="view_general_letter_report_search" model="ir.ui.view">
        <field name="name">general.letter.report.search</field>
        <field name="model">general.letter.report</field>
        <field name="arch" type="xml">
            <search string="General Letters Analysis">
                <group expand="1" string="Group By">
                    <filter string="Letter" name="Letter"
                            context="{'group_by':'letter_id'}"/>
                    <filter string="Stage" name="Stage"
                            context="{'group_by':'stage_id'}"/>
                    <filter string="Letter Type" name="Letter Type"
                            context="{'group_by':'letter_type_id'}"/>
                    <filter string="Contract" name="Contract"
                            context="{'group_by':'contract_id'}"/>
                    <filter string="Modality" name="Modality"
                            context="{'group_by':'modality_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_general_letter_report" model="ir.actions.act_window">
        <field name="name">General Letters Analysis</field>
        <field name="res_model">general.letter.report</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_general_letter_report_search"/>
        <field name="help">This report performs analysis on your General
            Lettres.
        </field>
    </record>

    <menuitem
            id="menu_general_letter_reporting"
            name="Reporting"
            parent="custom_general_letters.general_letter_menu_root"
            sequence="50" groups="group_general_letters_administrator"/>
    <menuitem
            id="menu_general_letter_report"
            name="Letters"
            parent="menu_general_letter_reporting"
            action="custom_general_letters.action_general_letter_report"
            sequence="10"/>
</odoo>
