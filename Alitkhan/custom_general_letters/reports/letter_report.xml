<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_general_letter_report_tree" model="ir.ui.view">
        <field name="name">general.letter.report.tree</field>
        <field name="model">general.letter.report</field>
        <field name="arch" type="xml">
            <list string="General Letters Analysis">
                <field name="letter_id"/>
            </list>
        </field>
    </record>

    <record id="view_general_letter_report_pivot" model="ir.ui.view">
        <field name="name">general.letter.report.pivot</field>
        <field name="model">general.letter.report</field>
        <field name="arch" type="xml">
            <pivot string="General Letters Analysis" disable_linking="True">
                <field name="letter_id" type="row"/>
                <field name="stage_id" type="column"/>
                <field name="letter_type_id" type="column"/>
                <field name="contract_id" type="column"/>
                <field name="modality_id" type="column"/>
                <field name="late_letters" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_general_letter_report_graph" model="ir.ui.view">
        <field name="name">general.letter.report.graph</field>
        <field name="model">general.letter.report</field>
        <field name="arch" type="xml">
            <graph string="General Letter Analysis" type="line">
                <field name="late_letters" type="measure"/>
            </graph>
        </field>
    </record>


