<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="general_letters_ticket_view_tree" model="ir.ui.view">
        <field name="name">general.letters.ticket.list</field>
        <field name="model">general.letter.ticket</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="modality_id"/>
                <field name="letter_type_id"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="general_letter_ticket_view_form" model="ir.ui.view">
        <field name="name">general.letter.ticket.form</field>
        <field name="model">general.letter.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" string="Letter Description"/>
                        <h1>
                            <field name="name"
                                   placeholder="Enter Letter Description"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="letter_type_id"/>
                            <field name="contract_id"/>
                        </group>
                        <group>
                            <field name="modality_id"/>
                            <field name="attachment_ids"
                                   widget="many2many_binary"/>
                            <field name="approval_letter"
                                   widget="many2many_binary"/>
                        </group>
                    </group>
                </sheet>
               <chatter/>
            </form>
        </field>
    </record>

    <record id="general_letter_ticket_view_kanban" model="ir.ui.view">
        <field name="name">general.letter.ticket.kanban</field>
        <field name="model">general.letter.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                    class="o_kanban_small_column o_kanban_training_ticket"
                    quick_create="false"
                    default_order="create_date desc">
                <field name="name"/>
                <field name="letter_type_id"/>
                <field name="color"/>
                <field name="active"/>
                <field name="message_needaction_counter"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <progressbar field="activity_state"
                             colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>

                <templates>
                    <t t-name="menu">
                        <t t-if="widget.editable">
                            <a role="menuitem" type="open"
                               class="dropdown-item">Edit
                            </a>
                        </t>
                        <t t-if="widget.deletable">
                            <a role="menuitem" type="delete"
                               class="dropdown-item">Delete
                            </a>
                        </t>
                        <a role="menuitem" type="object" name="toggle_active"
                           class="dropdown-item">
                            <t t-if="record.active.raw_value">Archive</t>
                            <t t-else="">Restore</t>
                        </a>
                        <field name="color" widget="kanban_color_picker"/>
                    </t>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <field class="fw-bold fs-5" name="name"/>
                            (#<field name="id"/>)

                            <div class="mt-2">
                                <strong>Type:</strong>
                                <field name="letter_type_id"
                                       class="text-truncate"/>
                            </div>

                            <div class="mt-2">
                                <field name="activity_ids"
                                       widget="kanban_activity"/>
                                <t t-if="record.message_needaction_counter.raw_value">
                                    <span class="o_kanban_counter">
                                        <i class="fa fa-comments"/>
                                        <t t-out="record.message_needaction_counter.raw_value"/>
                                    </span>
                                </t>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="general_letter_ticket_view_search" model="ir.ui.view">
        <field name="name">general.letter.ticket.search</field>
        <field name="model">general.letter.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <searchpanel>
                    <field name="stage_id" enable_counters="1"/>
                </searchpanel>
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_by_stage"
                            context="{'group_by': 'stage_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_general_letter_ticket" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">general.letter.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first ticket
            </p>
        </field>
    </record>

    <menuitem id="general_letter_menu_root"
              name="General Letters"
              web_icon="custom_general_letters,static/description/icon.png"/>

    <menuitem id="menu_general_letter_tickets"
              name="Tickets"
              action="action_general_letter_ticket"
              parent="general_letter_menu_root"
              sequence="0"/>

    <menuitem id="general_letter_configuration"
              name="Configuration"
              parent="general_letter_menu_root"
              sequence="99"
              groups="custom_general_letters.group_general_letters_administrator"/>
</odoo>
