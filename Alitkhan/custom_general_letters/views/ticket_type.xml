<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="general_letter_type_view_tree" model="ir.ui.view">
        <field name="name">general.letter.type.list</field>
        <field name="model">general.letter.type</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="general_letter_type_view_form" model="ir.ui.view">
        <field name="name">general.letter.type.form</field>
        <field name="model">general.letter.type</field>
        <field name="arch" type="xml">
            <form string="Form Views">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="general_letter_type_view_search" model="ir.ui.view">
        <field name="name">general.letter.type.search</field>
        <field name="model">general.letter.type</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_general_letter_type" model="ir.actions.act_window">
        <field name="name">Letter Type</field>
        <field name="res_model">general.letter.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_general_letter_type" name="Letter Type" action="action_general_letter_type" parent="general_letter_configuration" sequence="5"/>
</odoo>
