<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="pledge_res_form" model="ir.ui.view">
            <field name="name">pledge_res_form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <button class="oe_stat_button"
                        type="object"
                        name="pledge_partner_re"
                        groups="pledge_assets.pledge_user">
                        <field name="pledge_count" widget="statinfo" string="Partner Pledges"/>
                        <div class="o_stat_info">
                            <span class="o_stat_text">Pledges</span>
                        </div>
                        <div class="fa fa-book" role="img" aria-label="Pledges"/>
                    </button>
                </div>
            </field>
        </record>
    </data>
</odoo>
