<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Inheriting res config settings form view    -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.announcement
        </field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='languages']" position="after">
                <block title="Announcement" name="announcement_setting_container">
                    <setting id="announcement_email" help="Send work report through email.">
                        <field name="is_email"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
    